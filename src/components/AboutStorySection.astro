---
import PageSection from './PageSection.astro';
import type { SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  surfaceTone = 'olive',
} = Astro.props;
---

<PageSection class="about-story-section" section="company-story" page={pageId} surfaceTone={surfaceTone}>
  <div class="story">
    <div class="story-inner">
      <div class="eye light"><div class="eye-dot"></div>Our Story</div>
      <h2 class="sec-h2 on-dark">Who We<br /><em>Are.</em></h2>
      <p class="story-p">
        Parrish Tree Removal started in <em>2016</em> because we saw too many homeowners getting taken advantage of
        overcharged, underserved, left with a mess and no explanation.
      </p>
      <div class="story-pull">
        <div class="story-pull-text">
          Show up.<br />Do the work.<br />
          <em>Leave it right.</em>
        </div>
      </div>
      <p class="story-p2">
        That's not a tagline. It's how we've operated every single job since day one. No shortcuts. No surprises. No leaving until
        the yard looks right. That's why homeowners across Parrish keep calling us back and why they send their neighbors.
      </p>
    </div>
  </div>
</PageSection>

<style>
  :global(.page-section.about-story-section[data-section="company-story"]) {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    margin-top: 0;
    padding: 0;
    background: #012a14;
    overflow-x: clip;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 18px), 0 100%);
  }

  :global(.page-section.about-story-section[data-section="company-story"])::before,
  :global(.page-section.about-story-section[data-section="company-story"])::after {
    content: none;
    background: none;
    box-shadow: none;
  }

  @keyframes storyDot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.35;
      transform: scale(0.55);
    }
  }

  .story {
    background: #012a14;
    padding: 44px 22px 40px;
    position: relative;
    overflow: hidden;
  }

  .story-inner {
    position: relative;
    z-index: 1;
  }

  .eye {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .eye.light {
    color: rgba(200, 150, 90, 0.72);
  }

  .eye-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
    background: #c8965a;
    animation: storyDot 2.2s ease-in-out infinite;
  }

  .sec-h2 {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 38px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }

  .sec-h2.on-dark {
    color: #fff;
  }

  .sec-h2.on-dark em {
    color: #c8965a;
  }

  .sec-h2 em {
    font-style: normal;
    display: block;
  }

  .story-p {
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .story-p em {
    color: #c8965a;
    font-style: normal;
    font-weight: 700;
  }

  .story-pull {
    padding: 22px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    margin-bottom: 22px;
    position: relative;
  }

  .story-pull::before {
    content: '';
    position: absolute;
    left: -22px;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, #c8965a, rgba(200, 150, 90, 0.2));
    border-radius: 0 999px 999px 0;
  }

  .story-pull-text {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 30px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.015em;
    color: #fff;
  }

  .story-pull-text em {
    color: #c8965a;
    font-style: normal;
    display: block;
  }

  .story-p2 {
    font-size: 12px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.75;
  }
</style>
