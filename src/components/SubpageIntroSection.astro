---
import PageSection from './PageSection.astro';
import type { SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  eyebrow?: string;
  lines: string[];
  accentLine?: string;
  body: string;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  eyebrow = 'Overview',
  lines,
  accentLine = '',
  body,
  surfaceTone = 'olive',
} = Astro.props;
---

<PageSection
  class="subpage-intro-section"
  section="subpage-outcome"
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class="subpage-outcome" data-subpage-outcome-root>
    <div class="subpage-outcome-lines">
      {lines.map((line) => (
        <div class="subpage-outcome-line" data-subpage-outcome-line>{line}</div>
      ))}
      {accentLine && <div class="subpage-outcome-line" data-subpage-outcome-line><em>{accentLine}</em></div>}
    </div>
    <div class="subpage-outcome-rule" data-subpage-outcome-rule></div>
    <p class="subpage-outcome-body">{body}</p>
  </div>
</PageSection>

<script is:inline>
  (() => {
    const roots = document.querySelectorAll('[data-subpage-outcome-root]');
    if (!('IntersectionObserver' in window)) {
      roots.forEach((root) => {
        root.querySelectorAll('[data-subpage-outcome-line], [data-subpage-outcome-rule]').forEach((el) => {
          if (el instanceof HTMLElement) el.classList.add('in');
        });
      });
      return;
    }

    roots.forEach((root) => {
      const lines = root.querySelectorAll('[data-subpage-outcome-line]');
      const rule = root.querySelector('[data-subpage-outcome-rule]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          lines.forEach((line) => line.classList.add('in'));
          if (rule instanceof HTMLElement) {
            window.setTimeout(() => rule.classList.add('in'), 180);
          }
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.28 });

      observer.observe(root);
    });
  })();
</script>

<style>
  :global(.page-section.subpage-intro-section[data-section="subpage-outcome"]) {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    padding: 0;
    background: #012a14;
    overflow-x: clip;
  }

  :global(.page-section.subpage-intro-section[data-section="subpage-outcome"])::before,
  :global(.page-section.subpage-intro-section[data-section="subpage-outcome"])::after {
    background: none;
    box-shadow: none;
  }

  .subpage-outcome {
    background: #012a14;
    padding: 36px 20px 8px;
    position: relative;
    overflow: hidden;
    overflow-x: clip;
  }

  .subpage-outcome::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 8px;
    background: #012a14;
    pointer-events: none;
  }

  .subpage-outcome-lines {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 16px;
  }

  .subpage-outcome-line {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 34px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .subpage-outcome-line::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #012a14;
    transform: translateX(0%);
    transition: transform 0.7s cubic-bezier(0.77, 0, 0.18, 1);
    z-index: 1;
  }

  .subpage-outcome-line.in::before {
    transform: translateX(101%);
  }

  .subpage-outcome-line em {
    color: #c8965a;
    font-style: normal;
  }

  .subpage-outcome-rule {
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, #c8965a, rgba(200,150,90,0.3) 60%, transparent 100%);
    box-shadow: 0 0 8px rgba(200,150,90,0.2);
    width: 0%;
    margin-bottom: 14px;
    transition: width 0.8s cubic-bezier(0.22,1,0.36,1);
    position: relative;
    z-index: 1;
  }

  .subpage-outcome-rule.in {
    width: 100%;
  }

  .subpage-outcome-body {
    font-size: 13px;
    color: rgba(255,255,255,0.72);
    line-height: 1.68;
    max-width: 240px;
    position: relative;
    z-index: 1;
    padding-bottom: 12px;
    margin: 0;
  }

  @media (min-width: 768px) {
    .subpage-outcome {
      padding: 52px 28px 32px;
    }

    .subpage-outcome-line {
      font-size: 48px;
    }

    .subpage-outcome-body {
      max-width: 420px;
      font-size: 13px;
    }
  }
</style>
