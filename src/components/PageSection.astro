---
interface Props {
  id?: string;
  class?: string;
  section?: string;
  page?: string;
  borderVariant?: string;
  surfaceTone?: string;
  ariaLabel?: string;
}

const {
  id,
  class: className,
  section,
  page,
  borderVariant,
  surfaceTone,
  ariaLabel,
} = Astro.props;
---

<section
  id={id}
  class:list={['page-section', className]}
  data-section={section}
  data-page={page}
  data-border-variant={borderVariant}
  data-surface-tone={surfaceTone}
  aria-label={ariaLabel}
>
  <slot />
</section>
