---
import PageSection from './PageSection.astro';
import type { SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  section: string;
  title: string;
  items: string[];
  softCard?: boolean;
  sectionId?: string;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  section,
  title,
  items,
  softCard = false,
  sectionId,
  surfaceTone = 'base',
} = Astro.props;

const desktopIntroBySection: Record<string, string> = {
  'estimate-tips':
    'The project details that usually make tree service quoting, scheduling, follow-up, and service planning clearer from the start, especially when multiple concerns or access questions are involved.',
  'how-requests-work':
    'What homeowners can expect after sending over tree service details, from the first review to the next practical step, estimate conversation, or scheduling discussion with the local team.',
};
---

<PageSection
  id={sectionId}
  class="section-desktop-split"
  section={section}
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
    {desktopIntroBySection[section] && (
      <p class="section-lead section-desktop-lead clone-intro">
        {desktopIntroBySection[section]}
      </p>
    )}
  </div>
  <div class:list={['page-card', softCard && 'page-card-soft']} data-block="content">
    <ul class="list-copy">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</PageSection>
