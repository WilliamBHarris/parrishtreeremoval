---
import { estimateServiceOptions } from '../data/services';

interface Props {
  heading?: string;
  intro?: string;
  buttonLabel?: string;
  serviceLabel?: string;
  headingId?: string;
}

const {
  heading = "Request A Free Estimate",
  intro = "Share your project details and we will follow up with the next best step for your property.",
  buttonLabel = "Submit Estimate Request",
  serviceLabel = "Service Needed",
  headingId,
} = Astro.props;

const instanceId = `estimate-${Math.random().toString(36).slice(2, 10)}`;
const resolvedHeadingId = headingId ?? `${instanceId}-heading`;
const introId = `${instanceId}-intro`;
const statusId = `${instanceId}-status`;
const nameId = `${instanceId}-name`;
const emailId = `${instanceId}-email`;
const phoneId = `${instanceId}-phone`;
const zipId = `${instanceId}-zip`;
const serviceId = `${instanceId}-service`;
const detailsId = `${instanceId}-details`;
---

<div class="estimate-form-shell form-card">
  <div class="estimate-form-intro">
    <h3 id={resolvedHeadingId}>{heading}</h3>
    <p id={introId}>{intro}</p>
  </div>

  <form
    class="form-grid estimate-form"
    method="post"
    action="/api/estimate.php"
    data-estimate-form
    aria-describedby={`${introId} ${statusId}`}
    novalidate
  >
    <input type="hidden" name="website" value="" autocomplete="off" />

    <div class="form-field">
      <label for={nameId}>Name</label>
      <input
        id={nameId}
        type="text"
        name="name"
        placeholder="Your name"
        required
        autocomplete="name"
      />
    </div>

    <div class="form-field">
      <label for={emailId}>Email</label>
      <input
        id={emailId}
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
    </div>

    <div class="form-field">
      <label for={phoneId}>Phone</label>
      <input
        id={phoneId}
        type="tel"
        name="phone"
        placeholder="(555) 555-0199"
        required
        autocomplete="tel"
        inputmode="tel"
      />
    </div>

    <div class="form-field">
      <label for={zipId}>ZIP Code</label>
      <input
        id={zipId}
        type="text"
        name="zip"
        placeholder="Parrish-area ZIP code"
        required
        autocomplete="postal-code"
        inputmode="numeric"
        pattern="[0-9]{5}(-[0-9]{4})?"
      />
    </div>

    <div class="form-field">
      <label for={serviceId}>{serviceLabel}</label>
      <select id={serviceId} name="service" required>
        <option value="">Select a service</option>
        {estimateServiceOptions.map((option) => (
          <option value={option}>{option}</option>
        ))}
      </select>
    </div>

    <div class="form-field">
      <label for={detailsId}>Project Details</label>
      <textarea
        id={detailsId}
        name="details"
        placeholder="Describe the tree, the property location, and anything urgent or access-related."
        required
      ></textarea>
    </div>

    <button type="submit" class="btn-primary" data-submit-button
      >{buttonLabel}</button
    >
    <p id={statusId} class="form-status" data-form-status aria-live="polite" role="status"></p>
  </form>
</div>

<script type="module" src="/scripts/estimate-form.js"></script>
