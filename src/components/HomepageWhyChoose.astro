---
import PageSection from './PageSection.astro';
import { client } from '../data/client';
import { templateConfig } from '../data/client-questionnaire';
import type { SectionTone, WhyChooseVariant } from '../data/client-questionnaire';

interface Props {
  pageId?: string;
  variant?: WhyChooseVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  variant = templateConfig.presets.whyChoose,
  surfaceTone = 'cool',
} = Astro.props;

const isHome = pageId === 'home';

const whyChooseUsItems = [
  {
    paths: [
      'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z',
      'm9 12 2 2 4-4',
    ],
    title: 'Experienced Tree Service',
    description:
      'Tree removal, trimming, stump work, and storm cleanup.',
  },
  {
    paths: [
      'M12 21s6-4.35 6-10a6 6 0 1 0-12 0c0 5.65 6 10 6 10Z',
      'M12 11.5a1.75 1.75 0 1 0 0-3.5 1.75 1.75 0 0 0 0 3.5Z',
    ],
    title: 'Local Service Area',
    description:
      'Serving Parrish and nearby communities.',
  },
  {
    paths: [
      'M9 3h6l1.1 2H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3.9L9 3Z',
      'M12 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z',
    ],
    title: 'Straightforward Communication',
    description:
      'Clear updates and prompt follow-up.',
  },
  {
    paths: [
      'M12 22v-6',
      'M12 16c0-3 2.2-5.4 5.2-6.7',
      'M12 16c0-3-2.2-5.4-5.2-6.7',
      'M12 10c1.5-3.2 4.2-5 8-5-1 4.6-3.9 7.3-8 7.8',
      'M12 10C10.5 6.8 7.8 5 4 5c1 4.6 3.9 7.3 8 7.8',
    ],
    title: 'Complete Property Support',
    description:
      'Practical help tailored to the property.',
  },
];

const homeWhyItems = [
  {
    number: '01',
    title: 'Licensed & Fully Insured',
    description: 'Every job covered. No liability on your property, no surprises after the work is done.',
  },
  {
    number: '02',
    title: 'We Show Up On Time',
    description: 'We set a window and we keep it. No all-day waits, no last-minute cancellations.',
  },
  {
    number: '03',
    title: 'Full Cleanup, Every Job',
    description: 'Debris removed, yard left clean. We do not leave until it looks right.',
  },
  {
    number: '04',
    title: 'Clear Communication',
    description: 'One point of contact from estimate through final cleanup. No runaround.',
  },
];
---

{isHome ? (
  <PageSection
    class="home-why-section"
    section="why-choose-us"
    page={pageId}
    surfaceTone={surfaceTone}
  >
    <div class="home-entry-clip" aria-hidden="true">
      <svg viewBox="0 0 320 36" preserveAspectRatio="none">
        <path d="M0 36 L320 0 L320 36 Z" fill="#f2efe6"></path>
      </svg>
    </div>

    <div class="home-why">
      <div class="home-why-eye">
        <span class="home-why-eye-dot"></span>
        <span>Why Us</span>
      </div>

      <h2 class="home-why-title">
        Built Around
        <em>Your Property.</em>
      </h2>

      <p class="home-why-intro">Four specific reasons {client.primaryLocation} homeowners keep calling us back.</p>

      <div class="home-why-list">
        {homeWhyItems.map((item) => (
          <article class="home-why-item">
            <div class="home-why-check-wrap" aria-hidden="true">
              <span class="home-why-check">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M6.5 12.5l3.2 3.2 7.8-7.8"></path>
                </svg>
              </span>
            </div>
            <div class="home-why-copy">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>

      <button
        type="button"
        class="home-why-accent"
        data-open-estimate-modal
        aria-haspopup="dialog"
        aria-controls="estimate-modal"
      >
        <span class="home-why-accent-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.19 18.85 19.5 19.5 0 0 1 3.5 9.5 19.79 19.79 0 0 1 .43.83 2 2 0 0 1 2.44 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11l-1.79 1.28a16 16 0 0 0 6.29 6.29l1.27-.78a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </span>
        <span class="home-why-accent-copy">
          <strong>Ready to get started?</strong>
          <span>Call or request a free estimate online</span>
        </span>
        <span class="home-why-accent-arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </PageSection>
) : (
  <PageSection
    class="page-section-emphasis section-clone-showcase section-desktop-split"
    section="why-choose-us"
    page={pageId}
    surfaceTone={surfaceTone}
  >
    <div class="clone-heading" data-block="heading">
      <h2 class="clone-kicker section-divider-title">Why Choose Us</h2>
      <p class="section-lead clone-intro section-mobile-lead">
        Parrish Tree Removal is built around dependable service, clear communication,
        and practical help for homeowners throughout Parrish and the surrounding area.
      </p>
      <p class="section-lead section-desktop-lead clone-intro">
        Parrish Tree Removal is built around dependable service, clear communication, and practical help that keeps tree service projects easier to understand from the first estimate through scheduling, cleanup, and final follow-through on the property.
      </p>
    </div>

    <div class:list={['clone-value-grid', `why-choose-variant-${variant}`]} data-block="cards">
      {whyChooseUsItems.map((item) => (
        <article class="clone-value-card">
          <div class="clone-value-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
              {item.paths.map((path) => (
                <path d={path}></path>
              ))}
            </svg>
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </PageSection>
)}

<style>
  :global(.page-section.home-why-section[data-page="home"][data-section="why-choose-us"]) {
    padding: 0;
    background: #f2efe6;
  }

  .home-entry-clip {
    background: transparent;
    line-height: 0;
  }

  .home-entry-clip svg {
    display: block;
    width: 100%;
    height: 18px;
  }

  .home-why {
    position: relative;
    overflow: hidden;
    padding: 22px 20px 64px;
    background: #f2efe6;
  }

  .home-why::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,150,90,0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .home-why-eye {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 12px;
    color: #8a6840;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .home-why-eye-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c8965a;
    flex-shrink: 0;
    animation: hmDotPulse 2.2s ease-in-out infinite;
  }

  .home-why-title {
    position: relative;
    z-index: 1;
    margin: 0 0 12px;
    color: #012a14;
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 40px;
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .home-why-title em {
    display: block;
    color: #c8965a;
    font-style: normal;
  }

  .home-why-intro {
    position: relative;
    z-index: 1;
    max-width: 240px;
    margin: 0 0 28px;
    color: #6b6b58;
    font-size: 11px;
    font-weight: 500;
    line-height: 1.68;
  }

  .home-why-list {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .home-why-item {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 0 16px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(1,42,20,0.07);
  }

  .home-why-item:first-child {
    padding-top: 0;
  }

  .home-why-item:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .home-why-check-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 1px;
  }

  .home-why-check {
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: #c8965a;
    border: 1px solid rgba(200,150,90,0.28);
    background: rgba(200,150,90,0.08);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
  }

  .home-why-check svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  .home-why-copy {
    padding-top: 1px;
  }

  .home-why-copy h3 {
    margin: 0 0 5px;
    color: #012a14;
    font-size: 14px;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .home-why-copy p {
    margin: 0;
    color: #7a7a66;
    font-size: 11px;
    line-height: 1.6;
  }

  .home-why-accent {
    position: relative;
    z-index: 1;
    width: 100%;
    margin-top: 28px;
    padding: 16px 18px;
    border: 0;
    border-radius: 14px;
    background: #012a14;
    display: flex;
    align-items: center;
    gap: 14px;
    text-align: left;
    cursor: pointer;
  }

  .home-why-accent-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 10px;
    border: 1px solid rgba(200,150,90,0.25);
    background: rgba(200,150,90,0.15);
    display: grid;
    place-items: center;
    color: #c8965a;
  }

  .home-why-accent-icon svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  .home-why-accent-copy {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .home-why-accent-copy strong {
    margin-bottom: 2px;
    color: #fff;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .home-why-accent-copy span {
    color: rgba(255,255,255,0.5);
    font-size: 10px;
    line-height: 1.4;
  }

  .home-why-accent-arrow {
    color: #c8965a;
    font-size: 14px;
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .home-why {
      padding: 56px 28px 56px;
      max-width: 760px;
      margin: 0 auto;
    }

    .home-why-title {
      font-size: 56px;
    }

    .home-why-intro {
      max-width: 360px;
      font-size: 13px;
    }
  }
</style>
