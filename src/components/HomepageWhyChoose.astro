---
import PageSection from './PageSection.astro';
import { templateConfig } from '../data/client-questionnaire';
import type { SectionTone, WhyChooseVariant } from '../data/client-questionnaire';

interface Props {
  pageId?: string;
  variant?: WhyChooseVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  variant = templateConfig.presets.whyChoose,
  surfaceTone = 'cool',
} = Astro.props;

const whyChooseUsItems = [
  {
    paths: [
      'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z',
      'm9 12 2 2 4-4',
    ],
    title: 'Experienced Tree Service',
    description:
      'We handle tree removal, trimming, stump grinding, and storm cleanup for common residential property needs.',
  },
  {
    paths: [
      'M12 21s6-4.35 6-10a6 6 0 1 0-12 0c0 5.65 6 10 6 10Z',
      'M12 11.5a1.75 1.75 0 1 0 0-3.5 1.75 1.75 0 0 0 0 3.5Z',
    ],
    title: 'Local Service Area',
    description:
      'We serve Parrish and nearby communities with tree service that reflects local property conditions and seasonal concerns.',
  },
  {
    paths: [
      'M9 3h6l1.1 2H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3.9L9 3Z',
      'M12 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z',
    ],
    title: 'Straightforward Communication',
    description:
      'Clear project details, honest communication, and prompt follow-up help keep the process simple from the beginning.',
  },
  {
    paths: [
      'M12 22v-6',
      'M12 16c0-3 2.2-5.4 5.2-6.7',
      'M12 16c0-3-2.2-5.4-5.2-6.7',
      'M12 10c1.5-3.2 4.2-5 8-5-1 4.6-3.9 7.3-8 7.8',
      'M12 10C10.5 6.8 7.8 5 4 5c1 4.6 3.9 7.3 8 7.8',
    ],
    title: 'Complete Property Support',
    description:
      'One project can include cleanup, trimming, stump work, or full tree removal depending on what the property needs.',
  },
];
---

<PageSection
  class="page-section-emphasis section-clone-showcase"
  section="why-choose-us"
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">Why Choose Us</h2>
    <p class="section-lead clone-intro">
      Parrish Tree Removal is built around dependable service, clear communication,
      and practical help for homeowners throughout Parrish and the surrounding area.
    </p>
  </div>

  <div class:list={['clone-value-grid', `why-choose-variant-${variant}`]} data-block="cards">
    {whyChooseUsItems.map((item) => (
      <article class="clone-value-card">
        <div class="clone-value-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            {item.paths.map((path) => (
              <path d={path}></path>
            ))}
          </svg>
        </div>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</PageSection>
