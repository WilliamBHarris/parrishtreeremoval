---
import { Image } from 'astro:assets';
import { brand } from '../data/brand';
import { client } from '../data/client';
import { serviceCardList } from '../data/services';
import { resolveConfiguredImageAsset } from '../lib/template/runtime-assets';

const socialLabelMap = {
  googleBusinessProfile: 'Google Business Profile',
  facebook: 'Facebook',
  instagram: 'Instagram',
  nextdoor: 'Nextdoor',
  yelp: 'Yelp',
  googleReviews: 'Google Reviews',
  yelpReviews: 'Yelp Reviews',
} as const;

const socialEntries = [
  ...Object.entries(client.social.profiles),
  ...Object.entries(client.social.reputation),
]
  .filter(([, href]) => Boolean(href))
  .map(([key, href]) => ({
    label: socialLabelMap[key as keyof typeof socialLabelMap] ?? key,
    href: href as string,
  }));

const normalizeFooterHours = (value: string) =>
  value
    .replace(/^\s*mon(?:day)?\s*-\s*fri(?:day)?\s*/i, '')
    .replace(/^\s*sat(?:urday)?\s*/i, '')
    .replace(/:00(?=\s*[AP]M\b)/gi, '')
    .trim();

const footerHours = [
  {
    label: 'Mon–Fri',
    value: normalizeFooterHours(client.hours.mondayFriday),
  },
  {
    label: 'Saturday',
    value: normalizeFooterHours(client.hours.saturday),
  },
  {
    label: 'Sunday',
    value: 'Closed',
  },
];

const footerServices = serviceCardList.map((service) => ({
  label: service.cardTitle,
  href: `/${service.slug}`,
}));

const footerCreditLabel = client.footer.creditText;
const usePremiumFooter = !Astro.url.pathname.startsWith('/internal/template-preview');
const footerLogo = resolveConfiguredImageAsset(brand.assets.headerLogo);
---

{usePremiumFooter ? (
  <footer class="home-footer">
    <div class="home-footer-statement">
      <div class="home-footer-grain"></div>
      <div class="home-footer-orb"></div>
      <span class="home-footer-stmt-label">Our Promise</span>
      <div class="home-footer-stmt-text" id="home-footer-stmt">
        Show up. Do the work.
        <em>Leave it right.</em>
      </div>
    </div>

    <div class="home-footer-brand">
      <div class="home-footer-brand-left">
        <div class="home-footer-name">PARRISH <em>TREE REMOVAL</em></div>
      </div>
      <a href={`tel:${client.primaryPhoneHref}`} class="home-footer-call">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="#c8965a" aria-hidden="true">
          <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.12.37 2.33.57 3.59.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.26.2 2.47.57 3.59a1 1 0 0 1-.45 1z"></path>
        </svg>
        Call Now
      </a>
    </div>

    <div class="home-footer-grid">
      <div>
        <div class="home-footer-col-head">Services</div>
        <div class="home-footer-col-body">
          {footerServices.map((entry) => (
            <a href={entry.href}>{entry.label}</a>
          ))}
        </div>
      </div>
      <div>
        <div class="home-footer-col-head">Contact</div>
        <div class="home-footer-col-body">
          <a href={`tel:${client.primaryPhoneHref}`}>{client.primaryPhoneDisplay}</a>
          <button type="button" class="home-footer-text-button" data-open-estimate-modal aria-haspopup="dialog" aria-controls="estimate-modal">Free Estimates</button>
          <a href={`tel:${client.primaryPhoneHref}`}>Emergency Line</a>
        </div>
      </div>
      <div>
        <div class="home-footer-col-head">Hours</div>
        <div class="home-footer-col-body">
          <a href="#">{`Mon–Fri ${footerHours[0].value}`}</a>
          <a href="#">{`Sat ${footerHours[1].value}`}</a>
          <a href="#">Storm 24/7</a>
        </div>
      </div>
      <div>
        <div class="home-footer-col-head">Follow Us</div>
        <div class="home-footer-col-body">
          {socialEntries.slice(0, 4).map((entry) => (
            <a href={entry.href} target="_blank" rel="noopener noreferrer">{entry.label}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="home-footer-divider"></div>

    <div class="home-footer-meta">
      <div class="home-footer-copy">
        © 2025 {client.businessName}
        <span>{footerCreditLabel}</span>
      </div>
      <a href="#site-top" class="home-footer-top">↑ Top</a>
    </div>
  </footer>
) : (
  <footer class="site-footer">
    <div class="footer-shell">
      <div class="footer-main">
        <section class="footer-column footer-column-hours" aria-labelledby="footer-hours-title">
          <h2 id="footer-hours-title" class="footer-heading">Business Hours</h2>
          <dl class="footer-hours-list">
            {footerHours.slice(0, 2).map((entry) => (
              <div>
                <dt>{entry.label}</dt>
                <dd>- {entry.value}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="footer-column footer-column-social" aria-labelledby="footer-social-title">
          <h2 id="footer-social-title" class="footer-heading">Follow Us On Social</h2>
          <ul class="footer-social-list">
            {socialEntries.map((entry) => (
              <li>
                <a href={entry.href} target="_blank" rel="noopener noreferrer">{entry.label}</a>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <div class="footer-meta">
        <a href="#site-top" class="footer-top-link">{client.ctas.backToTop}</a>
        <div class="footer-credit"><strong>{client.footer.creditText}</strong></div>
        <a href="/" class="footer-brand" aria-label={`${client.businessName} home`}>
          <Image
            src={footerLogo}
            alt=""
            aria-hidden="true"
            class="footer-logo"
            widths={[96, 144, 180]}
            sizes="120px"
            loading="lazy"
            format="png"
          />
        </a>
      </div>
    </div>
  </footer>
)}

{usePremiumFooter && (
  <script is:inline>
    (() => {
      const footerStmt = document.getElementById('home-footer-stmt');
      if (!(footerStmt instanceof HTMLElement)) return;

      const footerObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('visible');
          footerObs.disconnect();
        });
      }, { threshold: 0.3 });

      footerObs.observe(footerStmt);
    })();
  </script>
)}

<style>
  .home-footer {
    background: #011a0d;
    overflow-x: clip;
  }

  .home-footer-statement {
    background: #011a0d;
    padding: 44px 20px 40px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: relative;
    overflow: hidden;
    overflow-x: clip;
  }

  .home-footer-statement::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 20% 0%, rgba(200,150,90,0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .home-footer-statement::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(200,150,90,0.5) 0%, rgba(200,150,90,0.15) 50%, transparent 100%);
  }

  .home-footer-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.04;
    z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 160px;
  }

  .home-footer-orb {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200,150,90,0.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .home-footer-stmt-label {
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(200,150,90,0.45);
    display: block;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }

  .home-footer-stmt-text {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: #fff;
    position: relative;
    z-index: 1;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22,1,0.36,1);
  }

  .home-footer-stmt-text.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home-footer-stmt-text em {
    color: #c8965a;
    font-style: normal;
    display: block;
  }

  .home-footer-brand {
    padding: 26px 20px 22px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .home-footer-name {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 22px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    line-height: 1;
    margin-bottom: 4px;
  }

  .home-footer-name em {
    color: #c8965a;
    font-style: normal;
  }

  .home-footer-call {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(200,150,90,0.1);
    border: 1px solid rgba(200,150,90,0.2);
    border-radius: 999px;
    padding: 8px 14px;
    color: #c8965a;
    font-size: 10px;
    font-weight: 800;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background 200ms ease;
  }

  .home-footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px 16px;
    padding: 26px 20px 28px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .home-footer-col-head {
    font-size: 7.5px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.28);
    margin-bottom: 12px;
  }

  .home-footer-col-body {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .home-footer-col-body a,
  .home-footer-text-button {
    font-size: 12.5px;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    line-height: 1.3;
    display: block;
    transition: color 180ms ease;
    background: transparent;
    border: 0;
    padding: 0;
    text-align: left;
    cursor: pointer;
  }

  .home-footer-divider {
    height: 1px;
    margin: 0 20px;
    background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.07) 25%, rgba(255,255,255,0.07) 75%, rgba(255,255,255,0) 100%);
  }

  .home-footer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px 28px;
  }

  .home-footer-copy {
    font-size: 9px;
    color: rgba(255,255,255,0.32);
    line-height: 1.5;
  }

  .home-footer-copy span {
    display: block;
    color: rgba(255,255,255,0.42);
    margin-top: 2px;
  }

  .home-footer-top {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    color: rgba(255,255,255,0.38);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 6px 12px;
    border-radius: 999px;
    white-space: nowrap;
    text-decoration: none;
  }
</style>
