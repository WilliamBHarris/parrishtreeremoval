---
import { Image } from 'astro:assets';
import { brand } from '../data/brand';
import { client } from '../data/client';
import { serviceCardList } from '../data/services';
import { resolveConfiguredImageAsset } from '../lib/template/runtime-assets';

const socialLabelMap = {
  googleBusinessProfile: 'Google Business Profile',
  facebook: 'Facebook',
  instagram: 'Instagram',
  nextdoor: 'Nextdoor',
  yelp: 'Yelp',
  googleReviews: 'Google Reviews',
  yelpReviews: 'Yelp Reviews',
} as const;

const socialEntries = [
  ...Object.entries(client.social.profiles),
  ...Object.entries(client.social.reputation),
]
  .filter(([, href]) => Boolean(href))
  .map(([key, href]) => ({
    label: socialLabelMap[key as keyof typeof socialLabelMap] ?? key,
    href: href as string,
  }));

const normalizeFooterHours = (value: string) =>
  value
    .replace(/^\s*mon(?:day)?\s*-\s*fri(?:day)?\s*/i, '')
    .replace(/^\s*sat(?:urday)?\s*/i, '')
    .replace(/:00(?=\s*[AP]M\b)/gi, '')
    .trim();

const footerHours = [
  {
    label: 'Mon–Fri',
    value: normalizeFooterHours(client.hours.mondayFriday),
  },
  {
    label: 'Saturday',
    value: normalizeFooterHours(client.hours.saturday),
  },
  {
    label: 'Sunday',
    value: 'Closed',
  },
];

const footerServices = serviceCardList.map((service) => ({
  label: service.cardTitle,
  href: `/${service.slug}`,
}));

const footerCreditLabel = client.footer.creditText;
const isHomePage = Astro.url.pathname === '/';
const footerLogo = resolveConfiguredImageAsset(brand.assets.headerLogo);
---

{isHomePage ? (
  <footer class="home-footer">
    <div class="home-footer-brand">
      <div>
        <div class="home-footer-name">
          {client.businessName.split(' ')[0]}
          <em>{client.businessName.split(' ').slice(1).join(' ')}</em>
        </div>
      </div>

      <a href={`tel:${client.primaryPhoneHref}`} class="home-footer-cta">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.12.37 2.33.57 3.59.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.26.2 2.47.57 3.59a1 1 0 0 1-.45 1z" fill="currentColor"></path>
        </svg>
        Call Now
      </a>
    </div>

    <div class="home-footer-grid">
      <div>
        <div class="home-footer-col-head">Hours</div>
        <div class="home-footer-col-body">
          {footerHours.map((entry) => (
            <span>{entry.label}: {entry.value}</span>
          ))}
        </div>
      </div>

      <div>
        <div class="home-footer-col-head">Services</div>
        <div class="home-footer-col-body">
          {footerServices.map((entry) => (
            <a href={entry.href}>{entry.label}</a>
          ))}
        </div>
      </div>

      <div>
        <div class="home-footer-col-head">Contact</div>
        <div class="home-footer-col-body">
          <a href={`tel:${client.primaryPhoneHref}`}>{client.primaryPhoneDisplay}</a>
          <button type="button" class="home-footer-text-button" data-open-estimate-modal aria-haspopup="dialog" aria-controls="estimate-modal">Free Estimates</button>
          <span>Storm Response</span>
        </div>
      </div>

      <div>
        <div class="home-footer-col-head">Follow Us</div>
        <div class="home-footer-col-body">
          <span>Facebook</span>
          <span>Instagram</span>
          <span>Twitter</span>
        </div>
      </div>
    </div>

    <div class="home-footer-divider"></div>

    <div class="home-footer-meta">
      <div class="home-footer-copy">
        © 2026 {client.businessName}
        <span>{footerCreditLabel}</span>
      </div>
      <a href="#site-top" class="home-footer-top">↑ Top</a>
    </div>
  </footer>
) : (
  <footer class="site-footer">
    <div class="footer-shell">
      <div class="footer-main">
        <section class="footer-column footer-column-hours" aria-labelledby="footer-hours-title">
          <h2 id="footer-hours-title" class="footer-heading">Business Hours</h2>
          <dl class="footer-hours-list">
            {footerHours.slice(0, 2).map((entry) => (
              <div>
                <dt>{entry.label}</dt>
                <dd>- {entry.value}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section class="footer-column footer-column-social" aria-labelledby="footer-social-title">
          <h2 id="footer-social-title" class="footer-heading">Follow Us On Social</h2>
          <ul class="footer-social-list">
            {socialEntries.map((entry) => (
              <li>
                <a href={entry.href} target="_blank" rel="noopener noreferrer">{entry.label}</a>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <div class="footer-meta">
        <a href="#site-top" class="footer-top-link">{client.ctas.backToTop}</a>
        <div class="footer-credit"><strong>{client.footer.creditText}</strong></div>
        <a href="/" class="footer-brand" aria-label={`${client.businessName} home`}>
          <Image
            src={footerLogo}
            alt=""
            aria-hidden="true"
            class="footer-logo"
            widths={[96, 144, 180]}
            sizes="120px"
            loading="lazy"
            format="png"
          />
        </a>
      </div>
    </div>
  </footer>
)}

<style>
  .home-footer {
    background: #011a0d;
    padding: 28px 20px 22px;
  }

  .home-footer-brand {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .home-footer-name {
    color: #fff;
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .home-footer-name em {
    color: #c8965a;
    font-style: normal;
    margin-left: 0.22rem;
  }

  .home-footer-tagline {
    color: #f0e9de;
    font-size: 8.5px;
    line-height: 1.4;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .home-footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    text-decoration: none;
    padding: 7px 12px;
    border-radius: 999px;
    border: 1px solid rgba(200,150,90,0.22);
    background: rgba(200,150,90,0.12);
    color: #c8965a;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .home-footer-cta svg {
    width: 10px;
    height: 10px;
    display: block;
  }

  .home-footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px 16px;
    margin-bottom: 24px;
  }

  .home-footer-col-head {
    margin-bottom: 10px;
    color: rgba(255,255,255,0.28);
    font-size: 7.5px;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .home-footer-col-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .home-footer-col-body a,
  .home-footer-col-body span,
  .home-footer-text-button {
    color: #f0e9de;
    font-size: 10px;
    line-height: 1.3;
    text-decoration: none;
    display: block;
  }

  .home-footer-text-button {
    padding: 0;
    border: 0;
    background: transparent;
    text-align: left;
    cursor: pointer;
  }

  .home-footer-divider {
    height: 1px;
    margin-bottom: 16px;
    background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.07) 30%, rgba(255,255,255,0.07) 70%, rgba(255,255,255,0) 100%);
  }

  .home-footer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .home-footer-copy {
    color: #f0e9de;
    font-size: 9px;
    line-height: 1.4;
  }

  .home-footer-copy span {
    display: block;
    color: #f0e9de;
  }

  .home-footer-top {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
    text-decoration: none;
    padding: 5px 10px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    color: rgba(255,255,255,0.35);
    font-size: 9px;
    letter-spacing: 0.04em;
  }
</style>
