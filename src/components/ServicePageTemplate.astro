---
import { Image } from 'astro:assets';
import EstimateForm from './EstimateForm.astro';
import HeroOutlineCopy from './HeroOutlineCopy.astro';
import HeroTitleWords from './HeroTitleWords.astro';
import HomepageWhyChoose from './HomepageWhyChoose.astro';
import HomepageProcess from './HomepageProcess.astro';
import PageSection from './PageSection.astro';
import ServiceAreaSection from './ServiceAreaSection.astro';
import heroImage from '../assets/hero-image.png';

interface FaqItem {
  question: string;
  answer: string;
}

interface IncludedItem {
  title: string;
  description: string;
}

interface Props {
  pageId: string;
  heroTitle: string;
  heroIntro: string;
  estimateHeading: string;
  estimateIntro: string;
  whenYouNeedThisService: string[];
  whatsIncluded: Array<string | IncludedItem>;
  processSteps: string[];
  relatedServices: Array<{ href: string; label: string }>;
  faqs: FaqItem[];
  whenLayout?: 'list' | 'cards';
  includedLayout?: 'stack' | 'grid';
}

const {
  pageId,
  heroTitle,
  heroIntro,
  estimateHeading,
  estimateIntro,
  whenYouNeedThisService,
  whatsIncluded,
  processSteps,
  relatedServices,
  faqs,
  whenLayout = 'list',
  includedLayout = 'grid',
} = Astro.props;

const getVisibleRelatedLabel = (label: string) =>
  label
    .replace(' in Parrish, FL', '')
    .replace('Contact Parrish Tree Removal', 'Contact');

const heroMainTitle = heroTitle.replace(' in Parrish, FL', '');
const heroLocationTitle = heroTitle.includes(' in Parrish, FL') ? 'in Parrish, FL' : '';
const heroOutlineWords = `${heroMainTitle} ${heroLocationTitle}`.trim().split(/\s+/);

const processIconPaths = [
  ['M8 6h8', 'M8 10h8', 'M8 14h5', 'M7 3h10a2 2 0 0 1 2 2v14l-3-2-3 2-3-2-3 2V5a2 2 0 0 1 2-2Z'],
  ['M4 7h4l2-3h4l2 3h4v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z', 'M12 16a3.25 3.25 0 1 0 0-6.5 3.25 3.25 0 0 0 0 6.5Z'],
  ['M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10Z', 'M8 9h8', 'M8 13h5'],
  ['M7 3v3', 'M17 3v3', 'M4 8h16', 'M5 5h14a1 1 0 0 1 1 1v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1Z', 'm9 14 2 2 4-4'],
];

const processStepItems = processSteps.map((item, index) => ({
  title: `Step ${index + 1}`,
  description: item,
  paths: processIconPaths[index] ?? processIconPaths[processIconPaths.length - 1],
}));
---

<section class="page-hero internal-hero service-hero" data-page={pageId}>
  <div class="hero-frame">
    <div class="hero-bleed subpage-hero-bleed">
      <HeroOutlineCopy words={heroOutlineWords} />
      <Image
        src={heroImage}
        alt=""
        aria-hidden="true"
        class="hero-accent-image"
        format="webp"
        quality={75}
        loading="eager"
        decoding="async"
      />
      <div class="hero-copy">
        <h1>
          <span class="hero-title-primary"><HeroTitleWords text={heroMainTitle} /></span>
          {heroLocationTitle && <span class="hero-title-secondary">{heroLocationTitle}</span>}
        </h1>
        <p class="hero-subcopy">{heroIntro}</p>
      </div>
    </div>
    <div class="hero-cta-wrap">
      <a href="#estimate-form" class="hero-cta">Free Estimate</a>
    </div>
  </div>
</section>

<div class="page-shell" data-page={pageId}>
  <PageSection section="when-you-need-this-service" page={pageId}>
    <div class="clone-heading">
      <h2 class="clone-kicker section-divider-title">When You Need This Service</h2>
    </div>
    {whenLayout === 'cards' ? (
      <div class="stack-grid stack-grid-two">
        {whenYouNeedThisService.map((item) => (
          <article class="stack-panel">
            <p>{item}</p>
          </article>
        ))}
      </div>
    ) : (
      <div class="page-card when-needed-card">
        <ul class="list-copy">
          {whenYouNeedThisService.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    )}
  </PageSection>

  <PageSection section="whats-included" page={pageId}>
    <div class="clone-heading">
      <h2 class="clone-kicker section-divider-title">What&apos;s Included</h2>
    </div>
    <div class:list={['stack-grid', includedLayout === 'grid' && 'stack-grid-two']}>
      {whatsIncluded.map((item) => (
        <article class="stack-panel">
          {typeof item === 'string' ? (
            <p>{item}</p>
          ) : (
            <>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </>
          )}
        </article>
      ))}
    </div>
  </PageSection>

  <HomepageWhyChoose pageId={pageId} />

  <HomepageProcess steps={processStepItems} pageId={pageId} />

  <PageSection section="related-services" page={pageId}>
    <div class="clone-heading">
      <h2 class="clone-kicker section-divider-title">Services</h2>
    </div>
    <div class="service-button-row" role="navigation" aria-label="Related service links">
      {relatedServices.map((service) => (
        <a
          href={service.href}
          class="subpage-service-button"
          aria-label={`Go to ${service.label}`}
        >
          {getVisibleRelatedLabel(service.label)}
        </a>
      ))}
    </div>
  </PageSection>

  <PageSection section="faq" page={pageId}>
    <div class="clone-heading">
      <h2 class="clone-kicker section-divider-title">FAQ</h2>
    </div>
    <div class="faq-list">
      {faqs.map((item) => (
        <article class="faq-item">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))}
    </div>
  </PageSection>

  <PageSection id="estimate-form" section="estimate-form" page={pageId}>
    <div class="clone-heading">
      <h2 class="clone-kicker section-divider-title">Request A Free Estimate</h2>
    </div>
    <EstimateForm
      heading={estimateHeading}
      intro={estimateIntro}
      buttonLabel="Submit Free Estimate"
    />
  </PageSection>

  <ServiceAreaSection pageId={pageId} />
</div>
