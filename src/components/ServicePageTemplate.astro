---
import HeroSection from './HeroSection.astro';
import HomepageWhyChoose from './HomepageWhyChoose.astro';
import HomepageProcess from './HomepageProcess.astro';
import ServiceInfoSection from './ServiceInfoSection.astro';
import RelatedServicesSection from './RelatedServicesSection.astro';
import FaqSection from './FaqSection.astro';
import EstimateFormSection from './EstimateFormSection.astro';
import ServiceAreaSection from './ServiceAreaSection.astro';

interface FaqItem {
  question: string;
  answer: string;
}

interface IncludedItem {
  title: string;
  description: string;
}

interface Props {
  pageId: string;
  heroTitle: string;
  heroIntro: string;
  estimateHeading: string;
  estimateIntro: string;
  whenYouNeedThisService: string[];
  whatsIncluded: Array<string | IncludedItem>;
  processSteps: string[];
  relatedServices: Array<{ href: string; label: string }>;
  faqs: FaqItem[];
  whenLayout?: 'list' | 'cards';
  includedLayout?: 'stack' | 'grid';
}

const {
  pageId,
  heroTitle,
  heroIntro,
  estimateHeading,
  estimateIntro,
  whenYouNeedThisService,
  whatsIncluded,
  processSteps,
  relatedServices,
  faqs,
  whenLayout = 'list',
  includedLayout = 'grid',
} = Astro.props;

const getVisibleRelatedLabel = (label: string) =>
  label
    .replace(' in Parrish, FL', '')
    .replace('Contact Parrish Tree Removal', 'Contact');

const heroMainTitle = heroTitle.replace(' in Parrish, FL', '');
const heroLocationTitle = heroTitle.includes(' in Parrish, FL') ? 'in Parrish, FL' : '';
const heroOutlineWords = `${heroMainTitle} ${heroLocationTitle}`.trim().split(/\s+/);

const processIconPaths = [
  ['M8 6h8', 'M8 10h8', 'M8 14h5', 'M7 3h10a2 2 0 0 1 2 2v14l-3-2-3 2-3-2-3 2V5a2 2 0 0 1 2-2Z'],
  ['M4 7h4l2-3h4l2 3h4v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z', 'M12 16a3.25 3.25 0 1 0 0-6.5 3.25 3.25 0 0 0 0 6.5Z'],
  ['M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10Z', 'M8 9h8', 'M8 13h5'],
  ['M7 3v3', 'M17 3v3', 'M4 8h16', 'M5 5h14a1 1 0 0 1 1 1v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1Z', 'm9 14 2 2 4-4'],
];

const processStepItems = processSteps.map((item, index) => ({
  title: `Step ${index + 1}`,
  description: item,
  paths: processIconPaths[index] ?? processIconPaths[processIconPaths.length - 1],
}));
---

<HeroSection
  pageId={pageId}
  titlePrimary={heroMainTitle}
  titleSecondary={heroLocationTitle}
  intro={heroIntro}
  outlineWords={heroOutlineWords}
  cta={{ kind: 'modal', label: 'Free Estimate', target: 'estimate-modal' }}
/>

<div class="page-shell" data-page={pageId}>
  <ServiceInfoSection
    pageId={pageId}
    section="when-you-need-this-service"
    title="When You Need This Service"
    items={whenYouNeedThisService}
    layout={whenLayout === 'cards' ? 'grid' : 'list'}
    surfaceTone="base"
  />

  <ServiceInfoSection
    pageId={pageId}
    section="whats-included"
    title="What&apos;s Included"
    items={whatsIncluded}
    layout={includedLayout === 'grid' ? 'grid' : 'stack'}
    surfaceTone="warm"
  />

  <HomepageWhyChoose pageId={pageId} surfaceTone="cool" />

  <HomepageProcess steps={processStepItems} pageId={pageId} surfaceTone="olive" />

  <RelatedServicesSection
    pageId={pageId}
    ariaLabel="Related service links"
    links={relatedServices.map((service) => ({
      href: service.href,
      label: getVisibleRelatedLabel(service.label),
    }))}
    surfaceTone="base"
  />

  <FaqSection pageId={pageId} items={faqs} surfaceTone="warm" />

  <EstimateFormSection
    pageId={pageId}
    title="Request A Free Estimate"
    heading={estimateHeading}
    intro={estimateIntro}
    buttonLabel="Submit Free Estimate"
    surfaceTone="cool"
  />

  <ServiceAreaSection pageId={pageId} surfaceTone="olive" />
</div>
