---
import { getImage } from 'astro:assets';
import { client } from '../data/client';
import removalImage from '../assets/premium-services/removal.jpg';
import trimmingImage from '../assets/premium-services/trimming.jpg';
import stumpImage from '../assets/premium-services/stump.jpg';
import stormImage from '../assets/premium-services/storm.jpg';

const currentYear = new Date().getFullYear();
const estYear = client.yearsInBusiness ? currentYear - client.yearsInBusiness : 2014;

const services = [
  {
    situation: 'I need a tree removed',
    name: 'Tree Removal',
    href: '/tree-removal',
    imagePosition: '60% 28%',
    accent: '#c8965a',
    glow: 'rgba(200,150,90,.42)',
    tint: 'rgba(180,120,20,.06)',
    quote:
      '"They were here within 3 hours. Took down a massive oak and the yard was spotless when they left."',
    attr: 'Sarah K. · Parrish, FL · Tree Removal',
    desc: [
      'Any size tree, any access situation.',
      'Safe cut, clean haul-off, immaculate site.',
      `500+ trees removed in ${client.primaryLocation} since ${estYear}.`,
    ],
    trust: [
      { label: 'Full cleanup included', detail: 'Every log and chip removed' },
      { label: 'Quoted within 2 hours', detail: 'Photo to flat price, fast' },
      { label: 'Licensed and fully insured', detail: "You're never liable" },
    ],
    avail: 'Slots available this week · Call to confirm',
    response: 'Under 2 hrs',
    ctaSub: 'Typical response: same day',
    urgency: 'Same-day removal available for hazard trees',
  },
  {
    situation: 'My tree is overgrown',
    name: 'Tree Trimming',
    href: '/tree-trimming',
    imagePosition: '50% 18%',
    accent: 'rgba(132,218,72,.97)',
    glow: 'rgba(130,218,70,.36)',
    tint: 'rgba(80,160,30,.05)',
    quote:
      `"Trimmed three trees hanging over my roof. Couldn't even tell they'd been here by the time they left."`,
    attr: 'Mike R. · Ellenton, FL · Tree Trimming',
    desc: [
      'Clearance from roofs, fences, and power lines.',
      'Healthier canopy, better structure and light.',
      'Full cleanup on every single trim job.',
    ],
    trust: [
      { label: 'Cleanup on every trim', detail: 'Branches hauled, yard raked' },
      { label: 'Most jobs 2 to 4 hours', detail: 'In and out, no disruption' },
      { label: 'Licensed and insured', detail: 'Trained crew, proper gear' },
    ],
    avail: 'Available Mon-Sat',
    response: 'Same day',
    ctaSub: 'Available slots this week',
    urgency: 'Most trimming jobs booked within 3 days',
  },
  {
    situation: 'I have a stump to remove',
    name: 'Stump Grinding',
    href: '/stump-grinding',
    imagePosition: '46% 22%',
    accent: 'rgba(218,155,64,.97)',
    glow: 'rgba(215,152,62,.38)',
    tint: 'rgba(180,110,20,.05)',
    quote: `"Stump was completely gone in under an hour. Couldn't even tell where it had been."`,
    attr: 'Jennifer L. · Bradenton, FL · Stump Grinding',
    desc: [
      'Ground below grade, permanently gone.',
      'No regrowth, no trip hazard, no eyesore.',
      'Done in a single visit with commercial equipment.',
    ],
    trust: [
      { label: 'Ground below grade', detail: 'No regrowth, ever' },
      { label: 'Single visit, done', detail: 'Commercial grinder, fast' },
      { label: 'Chips hauled away', detail: 'Yard left completely clean' },
    ],
    avail: 'Next-day for most jobs',
    response: 'Next day',
    ctaSub: 'Most jobs next-day turnaround',
    urgency: 'Next-day availability for most stump jobs',
  },
  {
    situation: 'Storm damage, need help now',
    name: 'Storm Cleanup',
    href: '/emergency-tree-service',
    imagePosition: '50% 34%',
    accent: 'rgba(118,182,255,.97)',
    glow: 'rgba(112,175,255,.34)',
    tint: 'rgba(40,100,200,.06)',
    quote:
      '"Called at 7am after the storm. Crew was here by noon. Driveway clear, everything gone same day."',
    attr: 'Tom W. · Parrish, FL · Storm Cleanup',
    desc: [
      'Fast response when it matters most.',
      'Fallen limbs and blocked driveways cleared.',
      'Emergency line answered 24 hours a day.',
    ],
    trust: [
      { label: 'Same-day response', detail: 'We move fast when it matters' },
      { label: '24/7 emergency line', detail: 'Real person, not a machine' },
      { label: 'Fully insured', detail: 'Safe hazard tree removal' },
    ],
    avail: 'Emergency line 24/7',
    response: '47 min avg',
    ctaSub: 'Emergency crews standing by',
    urgency: 'Storm crews available today, call now',
  },
] as const;

const serviceImageAssets = [removalImage, trimmingImage, stumpImage, stormImage] as const;
const serviceImageSizes = '(max-width: 767px) 100vw, 100vw';
const serviceImageWidths = [560, 840, 1200] as const;
const serviceImages = await Promise.all(
  serviceImageAssets.map(async (src) => {
    const [avif, webp, jpeg] = await Promise.all([
      getImage({
        src,
        format: 'avif',
        widths: serviceImageWidths,
        sizes: serviceImageSizes,
        quality: 34,
      }),
      getImage({
        src,
        format: 'webp',
        widths: serviceImageWidths,
        sizes: serviceImageSizes,
        quality: 46,
      }),
      getImage({
        src,
        format: 'jpeg',
        widths: serviceImageWidths,
        sizes: serviceImageSizes,
        quality: 56,
      }),
    ]);

    return { avif, webp, jpeg };
  })
);

const iconSvg = {
  phone:
    '<svg width="16" height="16" viewBox="0 0 24 24" fill="rgba(200,150,90,.85)" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011-.24c1.12.37 2.33.57 3.59.57a1 1 0 011 1V20a1 1 0 01-1 1C10.3 21 3 13.7 3 4.5a1 1 0 011-1H7.5a1 1 0 011 1c0 1.26.2 2.47.57 3.59a1 1 0 01-.45 1z"/></svg>',
  check:
    '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>',
  clock:
    '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  shield:
    '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
} as const;

const trustIconKinds = [
  ['check', 'clock', 'shield'],
  ['check', 'clock', 'shield'],
  ['check', 'clock', 'shield'],
  ['check', 'clock', 'shield'],
] as const;
---

<section class="ps" data-premium-services>
  <div class="ps-side-label">SERVICES</div>

  <div class="ps-photo-wrap" aria-hidden="true">
    {services.map((service, index) => (
      <picture>
        <source
          type="image/avif"
          srcset={serviceImages[index].avif.srcSet.attribute}
          sizes={serviceImageSizes}
        />
        <source
          type="image/webp"
          srcset={serviceImages[index].webp.srcSet.attribute}
          sizes={serviceImageSizes}
        />
        <img
          class:list={['ps-photo', `ps-photo--kb${index + 1}`, index === 0 && 'is-active']}
          data-ps-photo
          src={serviceImages[index].jpeg.src}
          srcset={serviceImages[index].jpeg.srcSet.attribute}
          alt=""
          width="1024"
          height="1536"
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
          fetchpriority={index === 0 ? 'high' : 'auto'}
          sizes={serviceImageSizes}
          style={`--ps-pos:${service.imagePosition};--ps-scale:${index % 2 === 0 ? '1.06' : '1.05'};`}
        />
      </picture>
    ))}
  </div>

  <div class="ps-tint" data-ps-tint></div>
  <div class="ps-gradient-top"></div>
  <div class="ps-gradient-bottom"></div>
  <div class="ps-vignette"></div>

  <div class="ps-content">
    <div class="ps-top">
      <div class="ps-top-left">
        <div class="ps-eye"><span class="ps-eye-dot"></span>Our Services</div>
        <div class="ps-divider"></div>
        <div class="ps-tagline">One crew · Four services · {client.primaryLocation}, FL</div>
        <div class="ps-divider"></div>
        <div class="ps-live"><span class="ps-live-dot"></span>31 jobs completed this month</div>
      </div>
      <div class="ps-top-right">
        <div class="ps-phone">
          <span class="ps-phone-label">Call now:</span>
          <a href={`tel:${client.primaryPhoneHref}`} class="ps-phone-number">{client.primaryPhoneDisplay}</a>
        </div>
        <button type="button" class="ps-top-cta" data-open-estimate-modal aria-haspopup="dialog" aria-controls="estimate-modal">
          <span>Get a Free Estimate</span>
          <b>→</b>
        </button>
      </div>
    </div>

    <div class="ps-nav" role="tablist" aria-label="Homepage services">
      {services.map((service, index) => (
        <button
          type="button"
          class:list={['ps-nav-item', index === 0 && 'is-active']}
          data-ps-trigger
          data-index={String(index)}
          data-accent={service.accent}
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          tabindex={index === 0 ? '0' : '-1'}
          style={`--ps-accent:${service.accent};--ps-glow:${service.glow};`}
        >
          <span class="ps-nav-ghost">{String(index + 1).padStart(2, '0')}</span>
          <span class="ps-nav-progress"></span>
          <span class="ps-nav-num">{String(index + 1).padStart(2, '0')}</span>
          <span class="ps-nav-copy">
            <span class="ps-nav-situation">{service.situation}</span>
            <span class="ps-nav-name">{service.name}</span>
          </span>
        </button>
      ))}
    </div>

    <div class="ps-stage">
      {services.map((service, index) => (
        <article
          class:list={['ps-pane', index === 0 && 'is-active']}
          data-ps-pane
          data-accent={service.accent}
          data-service-name={service.name}
          style={`--ps-accent:${service.accent};--ps-glow:${service.glow};`}
        >
          <div class="ps-pane-main">
            <div class="ps-left">
              <div class="ps-name-wrap">
                <h2 class="ps-name" data-text={service.name}>{service.name}</h2>
              </div>
              <div class="ps-rule"></div>
              <div class="ps-desc">
                {service.desc.map((line) => (
                  <div class="ps-desc-line">
                    <span class="ps-desc-dot"></span>
                    <span>{line}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="ps-right">
              <div class="ps-proof">
                <div class="ps-quote-mark">“</div>
                <p class="ps-quote">{service.quote}</p>
                <p class="ps-attr">{service.attr}</p>
              </div>

              <div class="ps-trust">
                {service.trust.map((item, trustIndex) => (
                  <div class="ps-trust-item">
                    <div class="ps-trust-icon">
                      <span
                        class="ps-trust-icon-svg"
                        set:html={iconSvg[trustIconKinds[index][trustIndex]]}
                      ></span>
                    </div>
                    <div>
                      <div class="ps-trust-label">{item.label}</div>
                      <div class="ps-trust-detail">{item.detail}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="ps-bottom">
            <button type="button" class="ps-cta" data-open-estimate-modal aria-haspopup="dialog" aria-controls="estimate-modal">
              <span class="ps-cta-copy">
                <span class="ps-cta-label">Free · No Obligation</span>
                <span class="ps-cta-title">Get a Free Estimate</span>
                <span class="ps-cta-sub">{service.ctaSub}</span>
              </span>
              <span class="ps-cta-arrow">→</span>
            </button>

            <div class="ps-bottom-divider"></div>

            <div class="ps-bottom-col">
              <div class="ps-bottom-label">Or call directly</div>
              <a href={`tel:${client.primaryPhoneHref}`} class="ps-bottom-phone">
                <span class="ps-phone-icon" set:html={iconSvg.phone}></span>
                {client.primaryPhoneDisplay}
              </a>
              <div class="ps-bottom-meta">{service.avail}</div>
            </div>

            <div class="ps-bottom-divider"></div>

            <div class="ps-bottom-col">
              <div class="ps-bottom-label">Typical response</div>
              <div class="ps-bottom-response">{service.response}</div>
              <div class="ps-bottom-meta">from first contact</div>
            </div>

            <div class="ps-guarantee">
              <div class="ps-guarantee-icon">
                <span set:html={iconSvg.shield}></span>
              </div>
              <div class="ps-guarantee-copy">
                Satisfaction guaranteed
                <span>We come back if you're not happy</span>
              </div>
            </div>

            <div class="ps-urgency">
              <span class="ps-urgency-dot"></span>
              <span class="ps-urgency-text" data-ps-urgency-text>{service.urgency}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<div class="ps-bottom-strip">
  <div class="ps-bottom-strip-inner">
    <div class="ps-bottom-strip-text">Not sure which service? <em>Call us — we'll tell you honestly.</em></div>
    <a href="/services" class="ps-bottom-strip-link">View all services →</a>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-premium-services]');
    if (!(root instanceof HTMLElement) || root.dataset.psBound === 'true') return;
    root.dataset.psBound = 'true';

    const photos = Array.from(root.querySelectorAll('[data-ps-photo]'));
    const panes = Array.from(root.querySelectorAll('[data-ps-pane]'));
    const triggers = Array.from(root.querySelectorAll('[data-ps-trigger]'));
    const urgencyTexts = Array.from(root.querySelectorAll('[data-ps-urgency-text]'));
    const tint = root.querySelector('[data-ps-tint]');
    let activeIndex = 0;
    let autoTimer = 0;
    let urgencyTimer = 0;
    let isVisible = false;
    let hasBooted = false;
    const AUTO_MS = 9000;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const warmedPhotos = new Set();
    const idle = window.requestIdleCallback
      ? window.requestIdleCallback.bind(window)
      : (callback) => window.setTimeout(callback, 180);

    const warmPhoto = (src) => {
      if (!src || warmedPhotos.has(src)) return Promise.resolve();
      warmedPhotos.add(src);

      return new Promise((resolve) => {
        const preload = new Image();
        preload.decoding = 'async';
        preload.loading = 'eager';

        const finish = () => {
          if (typeof preload.decode === 'function') {
            preload.decode().catch(() => {}).finally(resolve);
            return;
          }
          resolve();
        };

        preload.addEventListener('load', finish, { once: true });
        preload.addEventListener('error', resolve, { once: true });
        preload.src = src;

        if (preload.complete) finish();
      });
    };

    const queuePhotoWarmup = () => {
      let chain = Promise.resolve();

      photos.slice(1).forEach((photo, index) => {
        chain = chain.then(() => new Promise((resolve) => {
          idle(() => {
            if (!(photo instanceof HTMLImageElement)) {
              resolve();
              return;
            }

            warmPhoto(photo.currentSrc || photo.src).finally(resolve);
          }, { timeout: 1000 + index * 300 });
        }));
      });
    };

    const typewriteUrgency = (index) => {
      window.clearTimeout(urgencyTimer);

      urgencyTexts.forEach((node, nodeIndex) => {
        if (!(node instanceof HTMLElement)) return;
        if (nodeIndex !== index) {
          node.textContent = node.dataset.fullText || node.textContent || '';
        }
      });

      const target = urgencyTexts[index];
      if (!(target instanceof HTMLElement)) return;

      const full = target.dataset.fullText || target.textContent || '';
      target.dataset.fullText = full;

      if (!isVisible || reduceMotion.matches) {
        target.textContent = full;
        return;
      }

      target.textContent = '';
      let cursor = 0;

      const step = () => {
        if (!(target instanceof HTMLElement)) return;
        if (cursor <= full.length) {
          target.textContent = full.slice(0, cursor);
          cursor += 1;
          urgencyTimer = window.setTimeout(step, 18);
          return;
        }

        target.textContent = full;
      };

      urgencyTimer = window.setTimeout(step, 360);
    };

    const activate = (index, userAction = false) => {
      activeIndex = index;

      triggers.forEach((trigger, triggerIndex) => {
        const isActive = triggerIndex === index;
        trigger.classList.toggle('is-active', isActive);
        trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
        trigger.tabIndex = isActive ? 0 : -1;
      });

      panes.forEach((pane, paneIndex) => {
        pane.classList.toggle('is-active', paneIndex === index);
      });

      photos.forEach((photo, photoIndex) => {
        photo.classList.toggle('is-active', photoIndex === index);
      });

      const activePane = panes[index];
      const activeTrigger = triggers[index];
      if (tint instanceof HTMLElement && activePane instanceof HTMLElement) {
        const accent = activePane.dataset.accent || '';
        tint.style.background = accent
          ? `linear-gradient(180deg, transparent 0%, ${accent}12 100%)`
          : '';
      }

      triggers.forEach((trigger) => {
        trigger.style.setProperty('--ps-progress-play', 'paused');
      });
      if (activeTrigger instanceof HTMLElement) {
        activeTrigger.style.setProperty('--ps-progress-play', 'running');
        activeTrigger.style.setProperty('--ps-progress-duration', `${AUTO_MS}ms`);
      }

      typewriteUrgency(index);

      if (userAction) schedule();
    };

    const schedule = () => {
      window.clearTimeout(autoTimer);
      if (!isVisible) return;
      autoTimer = window.setTimeout(() => {
        activate((activeIndex + 1) % panes.length, false);
        schedule();
      }, AUTO_MS);
    };

    const boot = () => {
      if (hasBooted) return;
      hasBooted = true;
      const firstPhoto = photos[0];
      if (firstPhoto instanceof HTMLImageElement) {
        warmPhoto(firstPhoto.currentSrc || firstPhoto.src).catch(() => {});
      }
      queuePhotoWarmup();
      activate(0, false);
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => activate(index, true));
      trigger.addEventListener('keydown', (event) => {
        if (!['ArrowRight', 'ArrowLeft', 'Home', 'End'].includes(event.key)) return;
        event.preventDefault();
        let nextIndex = index;
        if (event.key === 'ArrowRight') nextIndex = (index + 1) % triggers.length;
        if (event.key === 'ArrowLeft') nextIndex = (index - 1 + triggers.length) % triggers.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = triggers.length - 1;
        activate(nextIndex, true);
        const nextTrigger = triggers[nextIndex];
        if (nextTrigger instanceof HTMLButtonElement) nextTrigger.focus();
      });
    });

    const observer = new IntersectionObserver((entries) => {
      const entry = entries[0];
      isVisible = Boolean(entry?.isIntersecting);
      root.classList.toggle('is-visible', isVisible);
      if (isVisible) {
        boot();
        schedule();
        typewriteUrgency(activeIndex);
      } else {
        window.clearTimeout(autoTimer);
        window.clearTimeout(urgencyTimer);
      }
    }, { rootMargin: '200px 0px' });

    observer.observe(root);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        window.clearTimeout(autoTimer);
        window.clearTimeout(urgencyTimer);
        return;
      }
      if (isVisible) schedule();
    });
  })();
</script>

<style>
  .ps {
    --ps-accent: #c8965a;
    position: relative;
    min-height: 740px;
    overflow: clip;
    background: #011608;
    color: #fff;
    content-visibility: auto;
    contain: layout paint style;
    contain-intrinsic-size: 740px;
  }

  .ps-side-label {
    position: absolute;
    left: 14px;
    top: 50%;
    z-index: 5;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.32em;
    color: rgba(255,255,255,0.12);
  }

  .ps-photo-wrap,
  .ps-tint,
  .ps-gradient-top,
  .ps-gradient-bottom,
  .ps-vignette,
  .ps-content {
    position: absolute;
    inset: 0;
  }

  .ps-photo-wrap {
    overflow: hidden;
    transform: translateZ(0);
    contain: paint;
  }

  .ps-photo {
    position: absolute;
    inset: -4%;
    width: calc(100% + 8%);
    height: calc(100% + 8%);
    object-fit: cover;
    object-position: var(--ps-pos);
    opacity: 0;
    transform: scale(var(--ps-scale, 1.05));
    transition: opacity 320ms ease, transform 6s ease-out;
    backface-visibility: hidden;
    transform-origin: center;
    will-change: opacity, transform;
  }

  .ps.is-visible .ps-photo.is-active {
    opacity: 1;
    will-change: transform, opacity;
  }

  .ps.is-visible .ps-photo.is-active.ps-photo--kb1 {
    animation: psKenBurns1 12s ease-in-out infinite alternate;
  }

  .ps.is-visible .ps-photo.is-active.ps-photo--kb2 {
    animation: psKenBurns2 12s ease-in-out infinite alternate;
  }

  .ps.is-visible .ps-photo.is-active.ps-photo--kb3 {
    animation: psKenBurns3 12s ease-in-out infinite alternate;
  }

  .ps.is-visible .ps-photo.is-active.ps-photo--kb4 {
    animation: psKenBurns4 12s ease-in-out infinite alternate;
  }

  .ps-tint {
    background: linear-gradient(180deg, transparent 0%, rgba(200,150,90,0.08) 100%);
    transition: background 260ms ease;
    transform: translateZ(0);
  }

  .ps-gradient-top {
    height: 220px;
    background: linear-gradient(180deg, rgba(0,8,2,.84) 0%, rgba(0,8,2,.44) 40%, transparent 100%);
    transform: translateZ(0);
  }

  .ps-gradient-bottom {
    background: linear-gradient(180deg, transparent 0%, rgba(0,4,1,.32) 50%, rgba(0,4,1,.92) 82%, #000401 100%);
    transform: translateZ(0);
  }

  .ps-vignette {
    background: radial-gradient(ellipse 120% 100% at 50% 50%, transparent 32%, rgba(0,2,1,.34) 70%, rgba(0,2,1,.64) 100%);
    transform: translateZ(0);
  }

  .ps-content {
    z-index: 2;
    display: flex;
    flex-direction: column;
    transform: translateZ(0);
  }

  .ps-top {
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 0 64px 0 52px;
    border-bottom: 1px solid rgba(255,255,255,.08);
    background: rgba(0,0,0,.18);
  }

  .ps-top-left,
  .ps-top-right,
  .ps-phone,
  .ps-eye,
  .ps-live {
    display: flex;
    align-items: center;
  }

  .ps-top-left {
    gap: 14px;
  }

  .ps-eye,
  .ps-live {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .ps-eye {
    gap: 7px;
    color: rgba(200,150,90,.78);
  }

  .ps-eye-dot,
  .ps-live-dot,
  .ps-desc-dot {
    width: 6px;
    height: 6px;
