---
import PageSection from './PageSection.astro';
import { templateConfig } from '../data/client-questionnaire';
import type { EstimateCtaVariant, SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  sectionId?: string;
  eyebrow: string;
  heading: string;
  intro: string;
  desktopIntro?: string;
  buttonLabel: string;
  variant?: EstimateCtaVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  sectionId,
  eyebrow,
  heading,
  intro,
  desktopIntro,
  buttonLabel,
  variant = templateConfig.presets.estimateCta,
  surfaceTone = 'olive',
} = Astro.props;

const desktopIntroByPageId: Record<string, string> = {
  home:
    'Tell us what is happening at the property, which tree service you need, and any timing, access, or storm-related details so we can help you move toward the right next step without unnecessary back-and-forth or guesswork.',
};

const resolvedDesktopIntro = desktopIntro ?? desktopIntroByPageId[pageId];
---

<PageSection
  id={sectionId}
  class="estimate-cta-section"
  section="estimate-cta"
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class:list={['estimate-cta-card', `estimate-cta-variant-${variant}`]} data-block="content">
    <h2 class="clone-kicker section-divider-title" data-block="heading">{eyebrow}</h2>
    <p class="estimate-cta-heading" data-block="title">{heading}</p>
    <p class="section-mobile-lead" data-block="intro">{intro}</p>
    <p class="section-desktop-lead" data-block="intro-desktop">{resolvedDesktopIntro ?? intro}</p>
    <button
      type="button"
      class="btn-primary"
      data-open-estimate-modal
      aria-haspopup="dialog"
      aria-controls="estimate-modal"
      data-block="cta"
    >
      {buttonLabel}
    </button>
  </div>
</PageSection>
