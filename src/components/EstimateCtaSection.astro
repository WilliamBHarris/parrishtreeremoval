---
import PageSection from './PageSection.astro';
import { client } from '../data/client';
import { templateConfig } from '../data/client-questionnaire';
import type { EstimateCtaVariant, SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  sectionId?: string;
  eyebrow: string;
  heading: string;
  intro: string;
  desktopIntro?: string;
  buttonLabel: string;
  variant?: EstimateCtaVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  sectionId,
  eyebrow,
  heading,
  intro,
  desktopIntro,
  buttonLabel,
  variant = templateConfig.presets.estimateCta,
  surfaceTone = 'olive',
} = Astro.props;

const desktopIntroByPageId: Record<string, string> = {
  home:
    'Tell us what is happening at the property, which tree service you need, and any timing, access, or storm-related details so we can help you move toward the right next step without unnecessary back-and-forth or guesswork.',
};

const resolvedDesktopIntro = desktopIntro ?? desktopIntroByPageId[pageId];
const isHome = pageId === 'home';
---

{isHome ? (
  <PageSection
    id={sectionId}
    class="home-estimate-section"
    section="estimate-cta"
    page={pageId}
    surfaceTone={surfaceTone}
  >
    <div class="home-estimate-wrap">
      <div class="home-estimate-card">
        <div class="home-estimate-grain" aria-hidden="true"></div>
        <div class="home-estimate-eyebrow">{eyebrow}</div>
        <h2 class="home-estimate-title">{heading}</h2>
        <p class="home-estimate-body">{intro}</p>
        <button
          type="button"
          class="home-estimate-btn"
          data-open-estimate-modal
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          {buttonLabel} →
        </button>
        <div class="home-estimate-divider" aria-hidden="true">
          <span class="home-estimate-divider-line"></span>
          <span>or call directly</span>
          <span class="home-estimate-divider-line"></span>
        </div>
        <a href={`tel:${client.primaryPhoneHref}`} class="home-estimate-call">
          <span>Call us:</span>
          <strong>{client.primaryPhoneDisplay}</strong>
        </a>
      </div>
    </div>
  </PageSection>
) : (
  <PageSection
    id={sectionId}
    class="estimate-cta-section"
    section="estimate-cta"
    page={pageId}
    surfaceTone={surfaceTone}
  >
    <div class:list={['estimate-cta-card', `estimate-cta-variant-${variant}`]} data-block="content">
      <h2 class="clone-kicker section-divider-title" data-block="heading">{eyebrow}</h2>
      <p class="estimate-cta-heading" data-block="title">{heading}</p>
      <p class="section-mobile-lead" data-block="intro">{intro}</p>
      <p class="section-desktop-lead" data-block="intro-desktop">{resolvedDesktopIntro ?? intro}</p>
      <button
        type="button"
        class="btn-primary"
        data-open-estimate-modal
        aria-haspopup="dialog"
        aria-controls="estimate-modal"
        data-block="cta"
      >
        {buttonLabel}
      </button>
    </div>
  </PageSection>
)}

<style>
  :global(.page-section.home-estimate-section[data-page="home"][data-section="estimate-cta"]) {
    padding: 0;
    background: #f2efe6;
  }

  .home-estimate-wrap {
    background: #f2efe6;
    margin-top: -1px;
    padding: 37px 20px 40px;
  }

  .home-estimate-card {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    padding: 30px 22px 26px;
    background: #012a14;
    text-align: center;
  }

  .home-estimate-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 72% 52% at 50% -8%, rgba(200,150,90,0.26) 0%, rgba(200,150,90,0.08) 38%, transparent 64%);
    pointer-events: none;
  }

  .home-estimate-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200,150,90,0.6), transparent);
  }

  .home-estimate-grain {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    pointer-events: none;
    border-radius: 8px;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 160px 160px;
  }

  .home-estimate-eyebrow,
  .home-estimate-title,
  .home-estimate-body,
  .home-estimate-btn,
  .home-estimate-divider,
  .home-estimate-call {
    position: relative;
    z-index: 1;
  }

  .home-estimate-eyebrow {
    margin-bottom: 14px;
    color: rgba(200,150,90,0.65);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .home-estimate-title {
    margin: 0 0 14px;
    color: #fff;
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 42px;
    font-weight: 800;
    line-height: 0.87;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .home-estimate-body {
    max-width: 210px;
    margin: 0 auto 24px;
    color: #f0e9de;
    font-size: 11px;
    line-height: 1.7;
  }

  .home-estimate-btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 0;
    border-radius: 12px;
    padding: 15px 32px;
    background: linear-gradient(180deg, #d4a060 0%, #b07840 100%);
    color: #fff;
    box-shadow: 0 12px 32px rgba(180,110,40,0.45), inset 0 1px 0 rgba(255,255,255,0.2);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: -0.01em;
    cursor: pointer;
  }

  .home-estimate-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0;
  }

  .home-estimate-divider-line {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  .home-estimate-divider span:not(.home-estimate-divider-line) {
    color: rgba(255,255,255,0.25);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .home-estimate-call {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.06);
    text-decoration: none;
  }

  .home-estimate-call span {
    color: #f0e9de;
    font-size: 11px;
  }

  .home-estimate-call strong {
    color: #f0e9de;
    font-size: 11px;
    font-weight: 800;
  }

  @media (min-width: 768px) {
    .home-estimate-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 40px 28px 48px;
    }
  }
</style>
