---
import { client } from '../data/client';
import { templateConfig } from '../data/client-questionnaire';
import type { HeaderVariant } from '../lib/template/intake-types';

interface Props {
  variant?: HeaderVariant;
  previewMode?: boolean;
  instanceId?: string;
}

const {
  variant = templateConfig.presets.header,
  previewMode = false,
  instanceId = 'site-header',
} = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const drawerId = `${instanceId}-mobile-drawer`;
const navLinks = client.navigation.primaryLinks;
const desktopNavLinks = navLinks.flatMap((link) => [link, ...(link.children ?? [])]);
const brandWords = client.businessName.split(' ');
const brandLead = brandWords[0] ?? client.businessName;
const brandAccent = brandWords.slice(1).join(' ');
---

<div
  class:list={['site-header-shell', previewMode && 'site-header-shell--preview']}
  data-header-root
  data-header-instance={instanceId}
>
  <header
    class:list={['site-header', `site-header-variant-${variant}`, previewMode && 'site-header--preview']}
    data-header-variant={variant}
  >
    <div class="site-header-inner">
      <a href="/" class="site-brand" aria-label={`${client.businessName} home`}>
        <span class="site-wordmark" aria-hidden="true">
          <span class="site-wordmark-base">{brandLead}</span>
          <span class="site-wordmark-accent">{brandAccent}</span>
        </span>
      </a>

      <nav class="desktop-nav" aria-label="Primary navigation">
        {desktopNavLinks.map((link) => {
          const normalizedHref = link.href.replace(/\/+$/, '') || '/';
          const isCurrent = currentPath === normalizedHref;

          return (
            <a href={link.href} aria-current={isCurrent ? 'page' : undefined}>
              {link.label}
            </a>
          );
        })}
      </nav>

      <div class="header-actions">
        <button
          type="button"
          class="desktop-estimate-link"
          aria-label={`Request an estimate from ${client.businessName}`}
          data-open-estimate-modal
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          <span>{client.ctas.heroEstimate}</span>
        </button>

        <a
          href={`tel:${client.primaryPhoneHref}`}
          class="desktop-call-link"
          aria-label={`Call ${client.businessName} at ${client.primaryPhoneDisplay}`}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.07.36 2.22.55 3.41.55a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1h3.51a1 1 0 0 1 1 1c0 1.19.19 2.34.55 3.41a1 1 0 0 1-.24 1z"
              fill="currentColor"
            ></path>
          </svg>
          <span>{client.ctas.secondaryButtonLabel}</span>
        </a>

        <a
          href={`tel:${client.primaryPhoneHref}`}
          class="sticky-call-fab"
          aria-label={`Call ${client.businessName}`}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.07.36 2.22.55 3.41.55a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1h3.51a1 1 0 0 1 1 1c0 1.19.19 2.34.55 3.41a1 1 0 0 1-.24 1z"
              fill="currentColor"
            ></path>
          </svg>
        </a>

        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls={drawerId}
          aria-label="Open menu"
        >
          <span class="menu-toggle-lines" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      </div>
    </div>
  </header>

  <div class="menu-scrim" hidden></div>

  <aside
    id={drawerId}
    class="mobile-drawer"
    aria-label="Primary navigation"
    hidden
    inert
  >
    <div class="mobile-drawer-panel">
      <div class="menu-bg-orb1" aria-hidden="true"></div>
      <div class="menu-bg-orb2" aria-hidden="true"></div>
      <div class="menu-grain" aria-hidden="true"></div>

      <div class="menu-location">
        <div class="menu-location-dot"></div>
        <span class="menu-location-text">Parrish, FL · Est. 2016</span>
      </div>

      <nav class="mobile-drawer-nav" aria-label="Primary navigation">
        {navLinks.map((link) => {
          const normalizedHref = link.href.replace(/\/+$/, '') || '/';
          const isCurrent = currentPath === normalizedHref;
          const hasChildren = Array.isArray(link.children);
          const isSectionCurrent = hasChildren
            ? link.children.some((child) => currentPath === (child.href.replace(/\/+$/, '') || '/'))
            : false;

          return hasChildren ? (
            <div class="drawer-submenu-group">
              <a
                href={link.href}
                class:list={['menu-link', (isCurrent || isSectionCurrent) && 'active']}
                aria-current={isCurrent ? 'page' : undefined}
              >
                <span class="menu-link-text">{link.label}</span>
                <span class="menu-link-arrow" aria-hidden="true">→</span>
              </a>
              <div class="menu-sub">
                {link.children.map((child) => {
                  const childPath = child.href.replace(/\/+$/, '') || '/';
                  const isChildCurrent = currentPath === childPath;

                  return (
                    <a
                      href={child.href}
                      class="menu-sub-link"
                      aria-current={isChildCurrent ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  );
                })}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={['menu-link', isCurrent && 'active']}
              aria-current={isCurrent ? 'page' : undefined}
            >
              <span class="menu-link-text">{link.label}</span>
              <span class="menu-link-arrow" aria-hidden="true">→</span>
            </a>
          );
        })}
      </nav>

      <div class="mobile-drawer-footer menu-cta">
        <div class="menu-cta-rule"></div>
        <button
          type="button"
          class="drawer-cta menu-cta-btn"
          data-open-estimate-modal
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          {client.ctas.heroEstimate}
        </button>
        <a
          href={`tel:${client.primaryPhoneHref}`}
          class="menu-cta-phone"
          aria-label={`Call ${client.businessName} at ${client.primaryPhoneDisplay}`}
        >
          <span class="menu-cta-phone-icon" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="rgba(255,255,255,0.5)">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011-.24c1.12.37 2.33.57 3.59.57a1 1 0 011 1V20a1 1 0 01-1 1C10.3 21 3 13.7 3 4.5a1 1 0 011-1H7.5a1 1 0 011 1c0 1.26.2 2.47.57 3.59a1 1 0 01-.45 1z"></path>
            </svg>
          </span>
          <strong>{client.primaryPhoneDisplay}</strong>
        </a>
      </div>
    </div>
  </aside>
</div>
