---
import PageSection from './PageSection.astro';
import type { IncludedItem } from '../data/services';
import type { SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  items: Array<string | IncludedItem>;
  closePrefix?: string;
  closeAccent?: string;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  items,
  closePrefix = 'All of this.',
  closeAccent = 'Every job. No exceptions.',
  surfaceTone = 'olive',
} = Astro.props;
---

<PageSection
  class="premium-included-section"
  section="whats-included"
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class="premium-included">
    <div class="inc-header">
      <div class="inc-eye"><div class="inc-eye-dot"></div>What&apos;s Included</div>
      <h2 class="inc-h2">What You<br><em>Actually Get.</em></h2>
      <p class="inc-intro">Every job. Regardless of size, access, or complexity. No exceptions.</p>
    </div>

    <div class="promises" data-premium-included>
      {items.map((item) => {
        const title = typeof item === 'string' ? item : item.title;
        const description = typeof item === 'string' ? item : item.description;
        return (
          <div class="promise">
            <div class="promise-burst" aria-hidden="true"></div>
            <button type="button" class="promise-closed" data-reveal-trigger aria-expanded="false">
              <div class="promise-label">{title}</div>
              <div class="promise-toggle" aria-hidden="true"></div>
            </button>
            <div class="promise-body">
              <div class="promise-inner">
                <div class="promise-content">
                  <div class="promise-stmt">{description}</div>
                  <div class="promise-sweep"></div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <div class="inc-close">
      <div class="inc-close-inner">
        <div class="inc-close-text">
          {closePrefix}<br />
          <em>{closeAccent}</em>
        </div>
      </div>
    </div>
  </div>
</PageSection>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-premium-included]').forEach((group) => {
      const items = Array.from(group.querySelectorAll('.promise'));
      items.forEach((item) => {
        const trigger = item.querySelector('[data-reveal-trigger]');
        if (!(trigger instanceof HTMLButtonElement)) return;
        trigger.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          items.forEach((entry) => {
            entry.classList.remove('open');
            const button = entry.querySelector('[data-reveal-trigger]');
            if (button instanceof HTMLButtonElement) button.setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  })();
</script>

<style>
  :global(.page-section.premium-included-section[data-section="whats-included"]) {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    margin-top: -3px;
    padding: 0;
    background: #012a14;
    overflow-x: clip;
    z-index: 2;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  :global(.page-section.premium-included-section[data-section="whats-included"])::before,
  :global(.page-section.premium-included-section[data-section="whats-included"])::after {
    content: none;
    background: none;
    box-shadow: none;
  }

  @keyframes dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.35;
      transform: scale(0.55);
    }
  }

  @keyframes lp {
    0% {
      opacity: 0.55;
    }

    100% {
      opacity: 1;
    }
  }

  .premium-included {
    background: #012a14;
    padding: 44px 0 0;
    position: relative;
    overflow: hidden;
  }

  .inc-header {
    position: relative;
    z-index: 1;
    padding: 0 22px 32px;
  }

  .inc-eye {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(200, 150, 90, 0.72);
    margin-bottom: 6px;
  }

  .inc-eye-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c8965a;
    flex-shrink: 0;
    animation: dot 2.2s ease-in-out infinite;
  }

  .inc-h2 {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 40px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.88;
    color: #fff;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }

  .inc-h2 em {
    color: #c8965a;
    font-style: normal;
    display: block;
  }

  .inc-intro {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.65;
    max-width: 235px;
    margin-bottom: 16px;
  }

  .promises {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .promise {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(200, 150, 90, 0.55);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: background 320ms ease, border-color 320ms ease;
    background: transparent;
  }

  .promise:last-child {
    border-bottom: 1px solid rgba(200, 150, 90, 0.55);
  }

  .promise.open {
    background: rgba(200, 150, 90, 0.05);
    border-top-color: rgba(200, 150, 90, 0.8);
  }

  .promise.open + .promise {
    border-top-color: rgba(200, 150, 90, 0.8);
  }

  .promise-burst {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse 80% 60% at 80% -20%, rgba(200, 150, 90, 0.14) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 400ms ease;
  }

  .promise.open .promise-burst {
    opacity: 1;
  }

  .promise-closed {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    gap: 12px;
    position: relative;
    z-index: 2;
    background: transparent;
    border: 0;
    text-align: left;
  }

  .promise-label {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 17px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    line-height: 1;
    color: #fff;
    transition: color 280ms ease, opacity 280ms ease, font-size 280ms ease, transform 280ms ease;
    flex: 1;
  }

  .promise.open .promise-label {
    color: #fff;
    font-size: 24px;
    transform: translateY(1px);
  }

  .promise-toggle {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 50%;
    border: 1.5px solid #c8965a;
    background: transparent;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1), border-color 280ms ease, background 280ms ease;
    position: relative;
    z-index: 2;
  }

  .promise.open .promise-toggle {
    transform: rotate(45deg);
    border-color: #c8965a;
    background: transparent;
  }

  .promise-toggle::before,
  .promise-toggle::after {
    content: '';
    position: absolute;
    background: #c8965a;
    border-radius: 999px;
    transition: background 280ms ease;
  }

  .promise-toggle::before {
    width: 10px;
    height: 1.5px;
  }

  .promise-toggle::after {
    width: 1.5px;
    height: 10px;
  }

  .promise.open .promise-toggle::before,
  .promise.open .promise-toggle::after {
    background: #c8965a;
  }

  .promise-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 420ms cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    z-index: 2;
  }

  .promise.open .promise-body {
    grid-template-rows: 1fr;
  }

  .promise-inner {
    overflow: hidden;
  }

  .promise-content {
    padding: 0 22px 24px;
  }

  .promise-stmt {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: #c8965a;
    margin-bottom: 14px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 320ms ease 80ms, transform 320ms cubic-bezier(0.22, 1, 0.36, 1) 80ms;
    margin-top: 2px;
  }

  .promise.open .promise-stmt {
    opacity: 1;
    transform: translateY(0);
  }

  .promise-sweep {
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, #c8965a, rgba(200, 150, 90, 0.3) 65%, transparent);
    box-shadow: 0 0 8px rgba(200, 150, 90, 0.2);
    width: 0%;
    margin-bottom: 12px;
    transition: width 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.15s;
  }

  .promise.open .promise-sweep {
    width: 100%;
  }

  .inc-close {
    position: relative;
    z-index: 1;
    padding: 28px 22px 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 0;
  }

  .inc-close-inner {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .inc-close-text {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: #fff;
    text-align: right;
    flex-shrink: 0;
  }

  .inc-close-text em {
    color: #c8965a;
    font-style: normal;
  }
</style>
