</div>
</div>

<script is:inline>
  (() => {
    const hdr = document.getElementById('hdr');
    const si = document.getElementById('si');
    const hero = document.getElementById('hero');
    const photoTrigger = document.querySelector('[data-hero-photo-trigger]');
    const estimateTrigger = document.querySelector('.cta-est[data-open-estimate-modal]');
    if (!hdr || !si || !hero) return;

    let latestY = window.scrollY;
    let gone = false;
    let ticking = false;

    const updateScene = () => {
      ticking = false;
      const y = latestY;
      hdr.classList.toggle('dark', y > 80);
      if (y > 50 && !gone) {
        gone = true;
        si.classList.add('gone');
      }
    };

    const scheduleSceneUpdate = () => {
      latestY = window.scrollY;
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateScene);
    };

    updateScene();
    window.addEventListener('scroll', scheduleSceneUpdate, { passive: true });
    window.addEventListener('resize', scheduleSceneUpdate, { passive: true });

    if (photoTrigger instanceof HTMLElement && estimateTrigger instanceof HTMLElement) {
      photoTrigger.addEventListener('click', () => {
        estimateTrigger.click();
      });
    }

    function countUp(el, target, dur, cb) {
      const t0 = performance.now();
      (function f(now) {
        const p = Math.min((now - t0) / dur, 1);
        const eased = p < .5 ? 4 * p * p * p : 1 - Math.pow(-2 * p + 2, 3) / 2;
        el.textContent = String(Math.round(eased * target));
        if (p < 1) requestAnimationFrame(f);
        else {
          el.textContent = String(target);
          if (cb) cb();
        }
      })(performance.now());
    }

    const els = [...document.querySelectorAll('.stat-v')];
    const tgts = els.map((el) => Number(el.getAttribute('data-target') || '0'));
    const durs = [900, 550, 350, 650];
    setTimeout(() => {
      let d = 0;
      els.forEach((el, i) => {
        setTimeout(() => countUp(el, tgts[i], durs[i] || 650, null), d);
        d += (durs[i] || 650) + 100;
      });
    }, 1600);
  })();
</script>

<style>
