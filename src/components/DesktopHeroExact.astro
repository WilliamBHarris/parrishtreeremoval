  .hero-scene > .hero{position:relative;width:100%;flex:1 1 auto;min-height:0 !important;max-height:none !important;height:auto !important;overflow:hidden;display:flex;flex-direction:column;opacity:0;animation:heroIn .8s ease .1s forwards;margin-top:0 !important;padding-top:0 !important;background:transparent !important;contain:paint}
