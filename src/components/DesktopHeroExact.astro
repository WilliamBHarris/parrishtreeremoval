  .grain{position:absolute;inset:0;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:160px;}
  .hdr{position:fixed;top:0;left:0;right:0;z-index:200;background:transparent !important;border-bottom:1px solid transparent !important;box-shadow:none !important;transition:background 350ms ease,border-color 350ms ease,backdrop-filter 350ms ease}
