---
import { getImage } from 'astro:assets';
import { client } from '../data/client';
import treeBgAsset from '../assets/hero/treeline-bg.png';
import treeFgAsset from '../assets/hero/treeline-fg.png';

const currentYear = new Date().getFullYear();
const estYear = client.yearsInBusiness ? currentYear - client.yearsInBusiness : 2014;
const jobsCompleted = client.jobsCompleted ?? 500;
const yearsInBusiness = client.yearsInBusiness ?? 10;
const googleRating = client.googleRating ?? 5;
const brandWords = client.businessName.split(' ');
const brandLead = brandWords[0] ?? client.businessName;
const brandAccent = brandWords.slice(1).join(' ');

const treeImageSizes = '100vw';
const treeImageWidths = [1280, 1536] as const;
const [treeBgWebp, treeFgWebp] = await Promise.all([
  getImage({
    src: treeBgAsset,
    format: 'webp',
    widths: treeImageWidths,
    sizes: treeImageSizes,
    quality: 68,
  }),
  getImage({
    src: treeFgAsset,
    format: 'webp',
    widths: treeImageWidths,
    sizes: treeImageSizes,
    quality: 68,
  }),
]);
---

<header class="hdr" id="hdr">
  <div class="hdr-inner">
    <a class="logo" href="/">
      <span class="logo-wordmark" aria-hidden="true">
        <span class="logo-wordmark-base">{brandLead}</span>
        <span class="logo-wordmark-accent">{brandAccent}</span>
      </span>
    </a>
    <nav class="hdr-nav">
      <a href="/services">Services</a>
      <a href="/about">About</a>
      <a href="#desktop-area">Service Area</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="hdr-r">
      <a class="hdr-phone" href={`tel:${client.primaryPhoneHref}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.07.36 2.22.55 3.41.55a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1h3.51a1 1 0 0 1 1 1c0 1.19.19 2.34.55 3.41a1 1 0 0 1-.24 1z"
            fill="currentColor"
          ></path>
        </svg>
        <span>{client.primaryPhoneDisplay}</span>
      </a>
      <button type="button" class="hdr-btn" data-open-estimate-modal aria-haspopup="dialog" aria-controls="estimate-modal">
        <span>Get a Free Estimate →</span>
      </button>
    </div>
  </div>
</header>

