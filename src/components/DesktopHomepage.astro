    .why-card{display:flex;flex-direction:column;gap:14px;padding:30px 28px 34px;min-height:0;opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1),border-color .22s ease,background-color .22s ease;border-right:1px solid var(--rule-light);border-bottom:1px solid var(--rule-light);background:transparent;}
    .why-card:hover{transform:translateY(-2px);background:rgba(255,255,255,.24);border-color:rgba(1,42,20,.18);}
    .why-card-head{display:flex;flex-direction:column;gap:12px;align-self:start;max-width:260px;}
    .why-card-kicker{font-size:9px;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:#8a6840;margin-bottom:10px;}
    .why-card-title{font-family:'Barlow Condensed',sans-serif;font-size:35px;font-weight:800;line-height:.92;letter-spacing:-.02em;text-transform:uppercase;color:var(--green);margin:0;}
    .why-card-body{font-size:14.5px;color:var(--text-soft-light);line-height:1.84;margin:0;max-width:420px;}
    .why-proof-strip{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:0;margin-bottom:0;padding:24px 0 0;border-top:1px solid rgba(1,42,20,.14);position:relative;}
    .why-proof-strip::before{content:'';position:absolute;top:-1px;left:0;width:52px;height:2px;background:var(--gold);clip-path:polygon(0 0,100% 0,84% 100%,0 100%);opacity:.7;}
    .why-proof-item{padding:24px 30px 0 0;opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1);}
    .why-proof-item + .why-proof-item{padding-left:30px;border-left:1px solid rgba(1,42,20,.16);}
    .why-proof-copy{padding-top:0;}
    .why-proof-n{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:800;letter-spacing:.12em;color:rgba(1,42,20,.44);margin-bottom:10px;}
