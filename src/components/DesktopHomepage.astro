    .why-cta-stmt,.faq-h2,.cta-h2{font-family:'Barlow Condensed',sans-serif;font-weight:800;text-transform:uppercase;line-height:.9;letter-spacing:-.015em;}
    .why-cta-stmt{font-size:clamp(32px,2.8vw,44px);color:#fff;max-width:300px;}
    .why-cta-stmt span{color:var(--gold);}
    .why-cta-right,.cta-right{display:flex;flex-direction:column;gap:12px;min-width:280px;}
    .why-cta-btn{display:flex;align-items:center;justify-content:center;background:var(--gold-grad);color:#fff;font-size:14px;font-weight:800;padding:17px;border-radius:12px;width:100%;position:relative;overflow:hidden;letter-spacing:-.01em;box-shadow:0 12px 32px rgba(180,110,40,.42),inset 0 1px 0 rgba(255,255,255,.18);}
    .why-cta-phone,.cta-phone-row{display:flex;align-items:center;justify-content:center;gap:7px;text-decoration:none;}
    .why-cta-phone span,.cta-phone-row span{font-size:12px;color:rgba(255,255,255,.3);}
    .why-cta-phone strong,.cta-phone-row strong{font-size:12px;color:rgba(255,255,255,.62);font-weight:700;}

    .process{background:var(--green);padding:var(--section-space) 0 0;position:relative;overflow:hidden;}
    .proc-grain{position:absolute;inset:0;z-index:0;opacity:.04;}
    .proc-orb{position:absolute;bottom:-80px;left:-80px;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.045) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .proc-head{margin-bottom:var(--section-gap);display:grid;grid-template-columns:minmax(0,1fr) minmax(420px,520px);gap:72px;align-items:end;}
    .proc-eye{color:rgba(200,150,90,.72);margin-bottom:12px;}
    .proc-h2{color:#fff;}
    .proc-sub{font-size:16px;color:var(--text-soft-dark);line-height:1.8;max-width:520px;justify-self:end;}
    .proc-steps{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:0;padding:24px 0 56px;border-top:1px solid rgba(255,255,255,.16);border-bottom:1px solid rgba(255,255,255,.16);position:relative;}
    .proc-steps::before{content:'';position:absolute;top:-1px;left:0;width:52px;height:2px;background:var(--gold);clip-path:polygon(0 0,100% 0,84% 100%,0 100%);opacity:.78;}
    .proc-steps::after{content:'';position:absolute;left:0;right:0;top:84px;height:1px;background:linear-gradient(90deg,rgba(200,150,90,.22) 0%,rgba(200,150,90,.08) 100%);pointer-events:none;}
    .proc-step{position:relative;z-index:1;display:grid;grid-template-columns:auto minmax(0,1fr);column-gap:24px;align-items:start;padding:34px 40px 36px 0;min-height:0;opacity:0;transform:translateY(12px);transition:opacity .52s cubic-bezier(.22,1,.36,1),transform .52s cubic-bezier(.22,1,.36,1);}
    .proc-step + .proc-step{padding-left:40px;border-left:1px solid rgba(255,255,255,.16);}
    .proc-step:nth-child(2){transition-delay:.1s;}
    .proc-step:nth-child(3){transition-delay:.2s;}
    .proc-step-n{font-family:'Barlow Condensed',sans-serif;font-size:72px;font-weight:800;line-height:.78;letter-spacing:-.04em;color:var(--gold);}
    .proc-step-copy{display:flex;flex-direction:column;align-items:flex-start;padding-top:6px;}
    .proc-step-note{font-size:10px;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:rgba(200,150,90,.98);margin:0 0 14px;}
    .proc-step-title{font-family:'Barlow Condensed',sans-serif;font-size:36px;font-weight:800;line-height:.9;letter-spacing:-.02em;text-transform:uppercase;color:#fff;margin:0 0 12px;max-width:220px;}
    .proc-step-desc{font-size:15px;color:var(--text-soft-dark);line-height:1.8;margin:0;max-width:290px;}

    .cta{background:var(--beige);padding:var(--section-space) 64px calc(var(--section-space) + 10px);}
    .cta-card{max-width:1160px;margin:0 auto;background:var(--green);border-radius:28px;padding:56px 56px;display:grid;grid-template-columns:minmax(0,42%) minmax(0,58%);gap:46px;align-items:start;position:relative;overflow:hidden;box-shadow:0 26px 46px rgba(1,42,20,.2);}
