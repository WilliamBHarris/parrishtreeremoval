    .faq-tog::before,.faq-tog::after{content:'';position:absolute;background:rgba(255,255,255,.56);border-radius:999px;transition:background 250ms ease;}
    .faq-item.open .faq-tog::before,.faq-item.open .faq-tog::after{background:var(--gold);}
    .faq-tog::before{width:11px;height:1.5px;}
    .faq-tog::after{width:1.5px;height:11px;}
    .faq-ans-wrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows 380ms cubic-bezier(.22,1,.36,1);}
    .faq-item.open .faq-ans-wrap{grid-template-rows:1fr;}
    .faq-ans-inner{overflow:hidden;}
    .faq-ans{font-size:15.5px;color:var(--text-soft-dark);line-height:1.86;padding:10px 6px 28px;max-width:700px;}
    .faq-item.open .faq-q-row{border-bottom:1px solid rgba(200,150,90,.12);}

    .area{background:var(--beige);padding:var(--section-space) 0 92px;position:relative;overflow:hidden;}
    .area-orb{position:absolute;bottom:-60px;right:-60px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.04) 0%,transparent 65%);pointer-events:none;z-index:0;}
