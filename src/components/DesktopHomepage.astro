---
import heroImage from '../assets/hero-image.png';
import EstimateForm from './EstimateForm.astro';
import { client } from '../data/client';

const currentYear = new Date().getFullYear();
const estYear = client.yearsInBusiness ? currentYear - client.yearsInBusiness : 2014;
const jobsCompleted = client.jobsCompleted ?? 500;
const yearsInBusiness = client.yearsInBusiness ?? 10;
const googleRating = client.googleRating ?? 5;

const tickerItems = [
  'Licensed & Insured',
  'Free Estimates',
  'Same-Day Available',
  'Local & Trusted',
  'Storm Response',
  'Full Cleanup Included',
  `${client.primaryLocation} Based`,
];

const servicePanels = [
  {
    navNumber: '01',
    navName: 'Tree Removal',
    href: '/tree-removal',
    panelClass: 'sp1',
    navClass: 'sp1-nav',
    tag: 'Same-Day Available',
    watermark: `${jobsCompleted}+`,
    nameLines: ['Tree', 'Removal'],
    desc: 'Safe removal of any tree — any size, any access, any situation. Full cleanup included on every single job. Your yard left cleaner than we found it.',
    statValue: 'Full Cleanup',
    statLabel: 'Always included',
    cta: 'View Tree Removal →',
    iconStroke: '#c8965a',
    icon: 'removal',
  },
  {
    navNumber: '02',
    navName: 'Tree Trimming',
    href: '/tree-trimming',
    panelClass: 'sp2',
    navClass: 'sp2-nav',
    tag: 'Cleanup Included',
    watermark: '★ 5',
    nameLines: ['Tree', 'Trimming'],
    desc: 'Cleaner canopy, better clearance, healthier trees. Keeps your property looking sharp year-round while protecting your roof, fences, and power lines.',
    statValue: 'Year Round',
    statLabel: 'Seasonal & ongoing',
    cta: 'View Tree Trimming →',
    iconStroke: 'rgba(130,210,70,.9)',
    icon: 'trimming',
  },
  {
    navNumber: '03',
    navName: 'Stump Grinding',
    href: '/stump-grinding',
    panelClass: 'sp3',
    navClass: 'sp3-nav',
    tag: 'Ground Below Grade',
    watermark: '100%',
    nameLines: ['Stump', 'Grinding'],
    desc: 'Nothing left to trip on, mow around, or regrow. Ground below grade and the yard reclaimed. One visit, problem solved permanently.',
    statValue: '100% Gone',
    statLabel: 'Below grade, no regrowth',
    cta: 'View Stump Grinding →',
    iconStroke: 'rgba(210,145,55,.9)',
    icon: 'stump',
  },
  {
    navNumber: '04',
    navName: 'Storm Cleanup',
    href: '/emergency-tree-service',
    panelClass: 'sp4',
    navClass: 'sp4-nav',
    tag: 'Emergency Response',
    watermark: '24/7',
    nameLines: ['Storm', 'Cleanup'],
    desc: 'Fast response to any storm damage. Fallen limbs, blocked driveways, split trunks — we move quickly when you need it most. Same day when possible.',
    statValue: 'Same Day',
    statLabel: 'When possible',
    cta: 'View Storm Cleanup →',
    iconStroke: 'rgba(120,175,255,.88)',
    icon: 'storm',
  },
];

const whyRows = [
  {
    number: '01',
    statement: ['Licensed &', 'Fully Insured.'],
    accentIndex: 1,
    detail:
      "Every job covered. You're not liable for anything that happens on your property. We can show proof of insurance on request, and we've never had a claim in ten years.",
  },
  {
    number: '02',
    statement: ['Shows Up', 'On Time.'],
    accentIndex: 1,
    detail:
      'We set a window and we keep it. No all-day waits, no last-minute cancellations. Your time matters as much as ours, and we treat it that way.',
  },
  {
    number: '03',
    statement: ['Left Cleaner', 'Than We Found It.'],
    accentIndex: 1,
    detail:
      "Full debris removal on every single job. We rake, we clear, we check twice. The job isn't done until the site looks right — not good enough, actually right.",
  },
  {
    number: '04',
    statement: ['Straight Pricing.', 'No Surprises.'],
    accentIndex: 1,
    detail:
      'What we quote is what you pay. No add-ons discovered halfway through, no invoice shock at the end. The full cost is agreed before a single cut.',
  },
];

const propertyPrinciples = [
  {
    kicker: 'Site First',
    title: 'Planned Around Access',
    body:
      'Before work starts, we look at gates, driveways, fences, rooflines, utility clearance, and where debris can move without turning the yard into a mess.',
  },
  {
    kicker: 'Protection',
    title: 'Care Around Surfaces',
    body:
      'Lawns, pavers, irrigation edges, and surrounding landscape are part of the job plan. We work to protect what stays while removing what needs to go.',
  },
  {
    kicker: 'Equipment Fit',
    title: 'Right Setup For The Lot',
    body:
      'Every property is different. Tight side yards, soft ground, and awkward drop zones all change how we stage the work, what equipment comes in, and how the crew moves.',
  },
  {
    kicker: 'Finish',
    title: 'Clean And Usable After',
    body:
      'Cleanup is not an add-on. We haul debris, clear the cut area, and leave the property usable again so the job feels finished when the crew pulls out.',
  },
];

const processSteps = [
  {
    number: '01',
    title: 'Request The Estimate',
    desc: "Call or send the estimate form with photos and a quick description of the tree, access, and anything on the property we should plan around.",
    note: 'Photos help us quote faster',
  },
  {
    number: '02',
    title: 'Get A Clear Plan',
    desc: 'We send a straight quote, confirm scope, and set the arrival plan so you know what work is happening, how access will be handled, and what cleanup is included.',
    note: 'Clear price. Clear arrival plan.',
  },
  {
    number: '03',
    title: 'Work. Cleanup. Done.',
    desc: 'The crew shows up, completes the job safely, hauls debris, and leaves the site clean so the property feels finished instead of half-done when we leave.',
    note: 'Property left clean and usable',
  },
];

const faqItems = [
  {
    question: 'Do you provide free estimates?',
    answer:
      "Yes — always. Send us a photo of the tree and we'll get you a flat price back fast, usually within a few hours. No site visit required for most jobs. No obligation if you decide not to move forward.",
  },
  {
    question: 'How quickly can you come out?',
    answer:
      'Most jobs are booked within 1–3 days. For storm damage or emergencies we aim to respond same day when possible. Call us directly for urgent requests.',
  },
  {
    question: 'Is cleanup included in the price?',
    answer:
      'Always. Every branch, log, and piece of debris is hauled away as part of the job. We rake, we clear, we check. You come outside and it looks like it never happened.',
  },
  {
    question: 'Are you licensed and insured?',
    answer:
      "Fully licensed and insured for every job. You're never liable for anything that happens on your property. We can provide proof of insurance on request.",
  },
  {
    question: 'What areas do you serve?',
    answer:
      `Based in ${client.primaryLocation}. We serve all of Manatee County including Ellenton, Palmetto, Bradenton, and surrounding communities. Call us if you're not sure — we'll tell you straight.`,
  },
];

const footerColumns = [
  {
    head: 'Services',
    links: [
      { label: 'Tree Removal', href: '/tree-removal' },
      { label: 'Tree Trimming', href: '/tree-trimming' },
      { label: 'Stump Grinding', href: '/stump-grinding' },
      { label: 'Storm Cleanup', href: '/emergency-tree-service' },
    ],
  },
  {
    head: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Service Area', href: '#desktop-home-area' },
      { label: 'Services', href: '/services' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    head: 'Contact',
    links: [
      { label: client.primaryPhoneDisplay, href: `tel:${client.primaryPhoneHref}` },
      { label: client.email, href: `mailto:${client.email}` },
      { label: `${client.primaryLocation} ${client.state}`.trim(), href: '#desktop-home-area' },
    ],
  },
  {
    head: 'Coverage',
    links: [
      { label: 'Parrish, FL', href: '#desktop-home-area' },
      { label: 'Ellenton, FL', href: '#desktop-home-area' },
      { label: 'Palmetto, FL', href: '#desktop-home-area' },
      { label: 'Bradenton, FL', href: '#desktop-home-area' },
      { label: 'Sarasota, FL', href: '#desktop-home-area' },
    ],
  },
];

const renderIcon = (kind: string, stroke: string) => {
  switch (kind) {
    case 'removal':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-7"/><path d="M9 15c-3-1-5-4-4-7 2 0 4 1 5 3"/><path d="M15 15c3-1 5-4 4-7-2 0-4 1-5 3"/><path d="M8 22h8"/></svg>`;
    case 'trimming':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4L8.12 15.88"/><path d="M14.47 14.48L20 20"/><path d="M8.12 8.12L12 12"/></svg>`;
    case 'stump':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="2"/><path d="M12 5V3M12 21v-2M5 12H3M21 12h-2M7.05 7.05L5.64 5.64M18.36 18.36l-1.41-1.41"/></svg>`;
    case 'storm':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/><path d="M11 13l-2 3h4l-2 3"/></svg>`;
    case 'phone':
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011-.24c1.12.37 2.33.57 3.59.57a1 1 0 011 1V20a1 1 0 01-1 1C10.3 21 3 13.7 3 4.5a1 1 0 011-1H7.5a1 1 0 011 1c0 1.26.2 2.47.57 3.59a1 1 0 01-.45 1z"/></svg>`;
    case 'photo':
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
    case 'quote':
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg>`;
    default:
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>`;
  }
};
---

<div class="desktop-homepage" data-desktop-homepage>
  <header class="hdr" id="hdr">
    <div class="hdr-inner">
      <a class="hdr-logo" href="/">
        <span>Parrish <em>Tree Removal</em></span>
      </a>
      <nav class="hdr-nav">
        <a href="/" class="active">Home</a>
        <div class="hdr-nav-group">
          <button type="button" class="hdr-nav-parent" data-hdr-services-toggle aria-expanded="false">
            <span>Services</span>
            <span class="hdr-nav-arrow" aria-hidden="true">▾</span>
          </button>
          <div class="hdr-subnav">
            <a href="/tree-removal">Tree Removal</a>
            <a href="/tree-trimming">Tree Trimming</a>
            <a href="/stump-grinding">Stump Grinding</a>
            <a href="/emergency-tree-service">Storm Cleanup</a>
          </div>
        </div>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="hdr-right">
        <div class="hdr-tel"><strong>{client.primaryPhoneDisplay}</strong></div>
        <button type="button" class="hdr-cta" data-open-estimate-modal>Get a Free Estimate →</button>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-gl hero-gl1"></div>
    <div class="hero-gl hero-gl2"></div>
    <div class="hero-gl hero-gl3"></div>
    <div class="hero-sun"></div>
    <div class="hero-grain grain"></div>
    <div class="hero-orb-a"></div>
    <div class="hero-orb-b"></div>

    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-eye"><div class="hero-eye-dot"></div>{client.primaryLocation} · Est. {estYear}</div>
        <h1 class="hero-h1">
          <span class="w">Local Tree</span>
          <span class="w">Service</span>
          <span class="wg">Done Right.</span>
        </h1>
        <p class="hero-sub">When a tree becomes a problem, we make it disappear — clean site, clear communication, every time. Serving Manatee County since {estYear}.</p>
        <div class="hero-ctas">
          <button type="button" class="hero-btn" data-open-estimate-modal>Get a Free Estimate →</button>
          <a class="hero-call" href={`tel:${client.primaryPhoneHref}`}>or call: <strong>{client.primaryPhoneDisplay}</strong></a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hstat-n"><span data-countup data-count-target={String(jobsCompleted)}>0</span><span class="hstat-s">+</span></div>
            <div class="hstat-bar on"></div>
            <div class="hstat-l">Parrish Properties</div>
          </div>
          <div class="hero-stat">
            <div class="hstat-n"><span data-countup data-count-target={String(yearsInBusiness)}>0</span><span class="hstat-s">yr</span></div>
            <div class="hstat-bar on"></div>
            <div class="hstat-l">In Business</div>
          </div>
          <div class="hero-stat">
            <div class="hstat-n"><span data-countup data-count-target={String(googleRating)}>0</span><span class="hstat-s">★</span></div>
            <div class="hstat-bar on"></div>
            <div class="hstat-l">Google Rating</div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-image-shell">
        <svg class="hero-image-defs" viewBox="0 0 1 1" aria-hidden="true">
          <defs>
            <clipPath id="desktop-hero-image-clip" clipPathUnits="objectBoundingBox">
              <path
                d="M0.018 0 C0.058 0.126 0.046 0.316 0.068 0.51 C0.09 0.706 0.05 0.888 0.014 1 L1 1 L1 0 Z"
              ></path>
            </clipPath>
          </defs>
        </svg>
        <div class="hero-image-media">
          <img src={heroImage.src} alt="" class="hero-image" loading="eager" decoding="async" />
        </div>
        <div class="hero-image-fade" aria-hidden="true"></div>
        <div class="hero-image-edge-blob" aria-hidden="true"></div>
      </div>
    </div>

    <div class="ticker">
      <div class="ticker-track">
        <div class="ticker-group">
          {tickerItems.map((item) => (
            <div class="ti"><div class="ti-chk">✓</div>{item}<div class="ti-sep"></div></div>
          ))}
        </div>
        <div class="ticker-group" aria-hidden="true">
          {tickerItems.map((item) => (
            <div class="ti"><div class="ti-chk">✓</div>{item}<div class="ti-sep"></div></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="services" id="desktop-home-services">
    <div class="svc-grain"></div>
    <div class="svc-bg-light"></div>

    <div class="svc-hdr">
      <div class="svc-hdr-left">
        <div class="svc-eye"><div class="svc-eye-dot"></div>What We Do</div>
        <h2 class="svc-h2">Whatever The Tree.<br/><em>Whatever The Job.</em></h2>
        <p class="svc-intro">Four core services handled by one local crew, with clear communication, careful execution, and full cleanup from the first call through the final pass on the property.</p>
      </div>
    </div>

    <div class="svc-body" id="svcBody">
      <svg class="connector-svg" id="connSvg" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="glow-gold"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glow-lime"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glow-amber"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glow-blue"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
      </svg>

      <div class="svc-list" id="svcList">
        <div class="svc-row" id="row0" data-svc-row data-idx="0">
          <span class="svc-row-icon" set:html={renderIcon('removal', '#c8965a')}></span>
          <span class="svc-row-name">Tree <em>Removal</em><span class="svc-row-anchor" aria-hidden="true"></span></span>
          <div class="svc-row-underline s1-ul"></div>
        </div>
        <div class="svc-row" id="row1" data-svc-row data-idx="1">
          <span class="svc-row-icon" set:html={renderIcon('trimming', 'rgba(132,218,72,.96)')}></span>
          <span class="svc-row-name">Tree <em>Trimming</em><span class="svc-row-anchor" aria-hidden="true"></span></span>
          <div class="svc-row-underline s2-ul"></div>
        </div>
        <div class="svc-row" id="row2" data-svc-row data-idx="2">
          <span class="svc-row-icon" set:html={renderIcon('stump', 'rgba(218,155,64,.96)')}></span>
          <span class="svc-row-name">Stump <em>Grinding</em><span class="svc-row-anchor" aria-hidden="true"></span></span>
          <div class="svc-row-underline s3-ul"></div>
        </div>
        <div class="svc-row" id="row3" data-svc-row data-idx="3">
          <span class="svc-row-icon" set:html={renderIcon('storm', 'rgba(118,182,255,.96)')}></span>
          <span class="svc-row-name">Storm <em>Cleanup</em><span class="svc-row-anchor" aria-hidden="true"></span></span>
          <div class="svc-row-underline s4-ul"></div>
        </div>
      </div>

      <div class="svc-card-col">
        <div class="dsvc-card c1" id="theCard">
          <div class="card-surface">
            <div class="card-visual">
              <div class="card-visual-panel c1-panel active" id="vis0">
                <div class="cv-bg"></div>
                <div class="cv-grain"></div>
                <div class="cv-topline"></div>
                <div class="cv-ghost">500+</div>
                <div class="cv-tag"><div class="cv-dot"></div>Same-Day Available</div>
                <div class="cv-fade"></div>
              </div>
              <div class="card-visual-panel c2-panel" id="vis1">
                <div class="cv-bg"></div>
                <div class="cv-grain"></div>
                <div class="cv-topline"></div>
                <div class="cv-ghost">★ 5</div>
                <div class="cv-tag"><div class="cv-dot"></div>Cleanup Included</div>
                <div class="cv-fade"></div>
              </div>
              <div class="card-visual-panel c3-panel" id="vis2">
                <div class="cv-bg"></div>
                <div class="cv-grain"></div>
                <div class="cv-topline"></div>
                <div class="cv-ghost">100%</div>
                <div class="cv-tag"><div class="cv-dot"></div>Ground Below Grade</div>
                <div class="cv-fade"></div>
              </div>
              <div class="card-visual-panel c4-panel" id="vis3">
                <div class="cv-bg"></div>
                <div class="cv-grain"></div>
                <div class="cv-topline"></div>
                <div class="cv-ghost">24/7</div>
                <div class="cv-tag"><div class="cv-dot"></div>Emergency Response</div>
                <div class="cv-fade"></div>
              </div>
            </div>

            <div class="card-icon-stack">
              <div class="card-icon-panel active">
                <div class="card-icon">
                  <div class="icon-plate">
                    <svg width="76" height="76" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22V13"/><path d="M9 15C6 14 4 11 5 8c2 0 4 1 5 3"/><path d="M15 15c3-1 5-4 4-7-2 0-4 1-5 3"/><path d="M8 22h8"/><path d="M5 9L7 7M19 5l-6 6M15 5h4v4"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="card-icon-panel">
                <div class="card-icon">
                  <div class="icon-plate">
                    <svg width="76" height="76" viewBox="0 0 24 24" fill="none" stroke="rgba(132,218,72,.96)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4L8.12 15.88M14.47 14.48L20 20M8.12 8.12L12 12"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="card-icon-panel">
                <div class="card-icon">
                  <div class="icon-plate">
                    <svg width="76" height="76" viewBox="0 0 24 24" fill="none" stroke="rgba(218,155,64,.96)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="2"/><path d="M12 5V3M12 21v-2M5 12H3M21 12h-2"/><path d="M7.05 7.05L5.64 5.64M18.36 18.36l-1.41-1.41M7.05 16.95l-1.41 1.41M18.36 5.64l-1.41 1.41"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="card-icon-panel">
                <div class="card-icon">
                  <div class="icon-plate" style="position:relative;">
                    <svg width="76" height="76" viewBox="0 0 24 24" fill="none" stroke="rgba(118,182,255,.96)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/><path d="M11 13l-2 3h4l-2 3"/>
                    </svg>
                    <div class="s-live"></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="card-content">
              <div class="card-content-panel active" id="cc0">
                <div class="card-body">
                  <div class="cb-top">
                    <div class="cb-name">Tree <span>Removal</span></div>
                    <div class="cb-rule"></div>
                    <p class="cb-desc">Safe removal for hazardous, storm-damaged, overgrown, or unwanted trees in tight access yards, close clearances, and high-risk spots around the property. We handle the cut, rigging, haul-off, and full cleanup so the space is left open, safe, and finished when we leave.</p>
                  </div>
                  <div class="cb-foot">
                    <a class="cb-cta" href="/tree-removal"><span>View Service</span><b>→</b></a>
                    <div class="cb-stat"><div class="cb-kv">500+ Jobs</div><div class="cb-kl">Completed in Parrish</div></div>
                  </div>
                </div>
              </div>
              <div class="card-content-panel" id="cc1">
                <div class="card-body">
                  <div class="cb-top">
                    <div class="cb-name">Tree <span>Trimming</span></div>
