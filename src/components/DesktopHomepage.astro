const jobsCompleted = client.jobsCompleted ?? 500;
const yearsInBusiness = client.yearsInBusiness ?? 10;
const googleRating = client.googleRating ?? 5;

const tickerItems = [
  'Licensed & Insured',
  'Free Estimates',
  'Same-Day Available',
  'Local & Trusted',
  'Storm Response',
  'Full Cleanup Included',
  `${client.primaryLocation} Based`,
];

const servicePanels = [
  {
    navNumber: '01',
    navName: 'Tree Removal',
    href: '/tree-removal',
    panelClass: 'sp1',
    navClass: 'sp1-nav',
    tag: 'Same-Day Available',
    watermark: `${jobsCompleted}+`,
    nameLines: ['Tree', 'Removal'],
    desc: 'Safe removal of any tree — any size, any access, any situation. Full cleanup included on every single job. Your yard left cleaner than we found it.',
    statValue: 'Full Cleanup',
    statLabel: 'Always included',
    cta: 'View Tree Removal →',
    iconStroke: '#c8965a',
    icon: 'removal',
  },
  {
    navNumber: '02',
    navName: 'Tree Trimming',
    href: '/tree-trimming',
    panelClass: 'sp2',
    navClass: 'sp2-nav',
    tag: 'Cleanup Included',
    watermark: '★ 5',
    nameLines: ['Tree', 'Trimming'],
    desc: 'Cleaner canopy, better clearance, healthier trees. Keeps your property looking sharp year-round while protecting your roof, fences, and power lines.',
    statValue: 'Year Round',
    statLabel: 'Seasonal & ongoing',
    cta: 'View Tree Trimming →',
    iconStroke: 'rgba(130,210,70,.9)',
    icon: 'trimming',
  },
  {
    navNumber: '03',
    navName: 'Stump Grinding',
    href: '/stump-grinding',
    panelClass: 'sp3',
    navClass: 'sp3-nav',
    tag: 'Ground Below Grade',
    watermark: '100%',
    nameLines: ['Stump', 'Grinding'],
    desc: 'Nothing left to trip on, mow around, or regrow. Ground below grade and the yard reclaimed. One visit, problem solved permanently.',
    statValue: '100% Gone',
    statLabel: 'Below grade, no regrowth',
    cta: 'View Stump Grinding →',
    iconStroke: 'rgba(210,145,55,.9)',
    icon: 'stump',
  },
  {
    navNumber: '04',
    navName: 'Storm Cleanup',
    href: '/emergency-tree-service',
    panelClass: 'sp4',
    navClass: 'sp4-nav',
    tag: 'Emergency Response',
    watermark: '24/7',
    nameLines: ['Storm', 'Cleanup'],
    desc: 'Fast response to any storm damage. Fallen limbs, blocked driveways, split trunks — we move quickly when you need it most. Same day when possible.',
    statValue: 'Same Day',
    statLabel: 'When possible',
    cta: 'View Storm Cleanup →',
    iconStroke: 'rgba(120,175,255,.88)',
    icon: 'storm',
  },
];

const whyRows = [
  {
    number: '01',
    statement: ['Licensed &', 'Fully Insured.'],
    accentIndex: 1,
    detail:
      "Every job covered. You're not liable for anything that happens on your property. We can show proof of insurance on request, and we've never had a claim in ten years.",
  },
  {
    number: '02',
    statement: ['Shows Up', 'On Time.'],
    accentIndex: 1,
    detail:
      'We set a window and we keep it. No all-day waits, no last-minute cancellations. Your time matters as much as ours, and we treat it that way.',
  },
  {
    number: '03',
    statement: ['Left Cleaner', 'Than We Found It.'],
    accentIndex: 1,
    detail:
      "Full debris removal on every single job. We rake, we clear, we check twice. The job isn't done until the site looks right — not good enough, actually right.",
  },
  {
    number: '04',
    statement: ['Straight Pricing.', 'No Surprises.'],
    accentIndex: 1,
    detail:
      'What we quote is what you pay. No add-ons discovered halfway through, no invoice shock at the end. The full cost is agreed before a single cut.',
  },
];

const processSteps = [
  {
    verb: 'Call.',
    title: 'You Call or Request',
    desc: "Reach out by phone or the estimate form. Tell us what you're dealing with.",
    icon: 'phone',
  },
  {
    verb: 'Snap.',
    title: 'Send a Photo',
    desc: 'A quick photo lets us assess remotely and give an accurate quote without a site visit.',
    icon: 'photo',
  },
  {
    verb: 'Quote.',
    title: 'We Send the Price',
    desc: "Flat, clear, complete. You know exactly what you'll pay before anyone shows up.",
    icon: 'quote',
  },
  {
    verb: 'Done.',
    title: 'We Handle Everything',
    desc: 'We show up, do the work, clean the site, and leave your yard better than we found it.',
