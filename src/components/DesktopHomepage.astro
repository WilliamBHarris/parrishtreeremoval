    .cta-h2{font-size:clamp(46px,3.8vw,60px);color:#fff;margin-bottom:14px;}
    .cta-body{font-size:15px;color:var(--text-soft-dark);line-height:1.82;max-width:370px;margin-bottom:26px;}
