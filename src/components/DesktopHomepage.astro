    .sp1 .sp-orb{width:280px;height:280px;background:radial-gradient(circle,rgba(200,150,90,.08) 0%,transparent 65%);bottom:-60px;left:-40px;}
    .sp1 .sp-edge{background:linear-gradient(90deg,rgba(200,150,90,.9) 0%,rgba(200,150,90,.2) 45%,transparent 85%);}
    .sp1 .sp-tag{background:rgba(200,150,90,.1);border:1px solid rgba(200,150,90,.2);color:rgba(220,170,70,.9);}
    .sp1 .sp-tag-dot{background:var(--gold);}
    .sp1 .sp-ico{background:rgba(200,150,90,.1);border:1px solid rgba(200,150,90,.2);}
    .sp1 .sp-rule{background:linear-gradient(90deg,var(--gold),rgba(200,150,90,.3));box-shadow:0 0 12px rgba(200,150,90,.3);}
    .sp1 .sp-stat-val,.sp1 .sp-wm{color:var(--gold);}
    .sp2{background:linear-gradient(140deg,#182c08 0%,#0e1c04 55%,#080f03 100%);}
    .sp2 .sp-light{background:radial-gradient(ellipse 70% 60% at -8% 40%,rgba(100,185,50,.2) 0%,transparent 65%);}
    .sp2 .sp-orb{width:260px;height:260px;background:radial-gradient(circle,rgba(100,185,50,.08) 0%,transparent 65%);top:-40px;right:-30px;}
    .sp2 .sp-edge{background:linear-gradient(90deg,rgba(130,210,70,.88) 0%,rgba(100,185,50,.2) 45%,transparent 85%);}
    .sp2 .sp-tag{background:rgba(100,185,50,.09);border:1px solid rgba(130,210,70,.18);color:rgba(140,220,75,.88);}
    .sp2 .sp-tag-dot{background:rgba(130,210,70,.9);}
    .sp2 .sp-ico{background:rgba(100,185,50,.09);border:1px solid rgba(130,210,70,.16);}
    .sp2 .sp-rule{background:linear-gradient(90deg,rgba(130,210,70,.9),rgba(100,185,50,.25));box-shadow:0 0 12px rgba(100,185,50,.2);}
    .sp2 .sp-stat-val,.sp2 .sp-wm{color:rgba(130,210,70,.9);}
    .sp3{background:linear-gradient(140deg,#2a1904 0%,#160d02 55%,#0c0802 100%);}
    .sp3 .sp-light{background:radial-gradient(ellipse 80% 65% at 90% 105%,rgba(195,130,40,.26) 0%,transparent 65%);}
    .sp3 .sp-orb{width:260px;height:260px;background:radial-gradient(circle,rgba(195,130,40,.09) 0%,transparent 65%);top:-30px;left:-20px;}
    .sp3 .sp-edge{background:linear-gradient(90deg,rgba(210,145,55,.88) 0%,rgba(195,130,40,.2) 45%,transparent 85%);}
    .sp3 .sp-tag{background:rgba(195,130,40,.09);border:1px solid rgba(210,145,55,.18);color:rgba(215,150,60,.88);}
    .sp3 .sp-tag-dot{background:rgba(210,145,55,.9);}
    .sp3 .sp-ico{background:rgba(195,130,40,.09);border:1px solid rgba(210,145,55,.18);}
    .sp3 .sp-rule{background:linear-gradient(90deg,rgba(210,145,55,.9),rgba(195,130,40,.25));box-shadow:0 0 12px rgba(195,130,40,.22);}
    .sp3 .sp-stat-val,.sp3 .sp-wm{color:rgba(210,145,55,.9);}
    .sp4{background:linear-gradient(140deg,#0a1828 0%,#060e1a 55%,#030812 100%);}
    .sp4 .sp-light{background:radial-gradient(ellipse 70% 55% at 50% -18%,rgba(74,143,217,.28) 0%,rgba(50,110,195,.08) 42%,transparent 65%);}
    .sp4 .sp-orb{width:280px;height:280px;background:radial-gradient(circle,rgba(74,143,217,.09) 0%,transparent 65%);bottom:-50px;right:-40px;}
    .sp4 .sp-edge{background:linear-gradient(90deg,transparent 0%,rgba(110,170,255,.88) 50%,transparent 100%);}
    .sp4 .sp-tag{background:rgba(74,143,217,.09);border:1px solid rgba(110,170,255,.18);color:rgba(120,175,255,.9);}
    .sp4 .sp-tag-dot{background:#4a8fd9;}
    .sp4 .sp-ico{background:rgba(74,143,217,.09);border:1px solid rgba(110,170,255,.18);}
    .sp4 .sp-rule{background:linear-gradient(90deg,rgba(110,170,255,.9),rgba(74,143,217,.25));box-shadow:0 0 12px rgba(74,143,217,.25);}
    .sp4 .sp-stat-val,.sp4 .sp-wm{color:rgba(110,170,255,.8);}
    .storm-dot{position:absolute;top:-3px;right:-3px;width:9px;height:9px;border-radius:50%;background:#4a8fd9;border:2px solid #060e1a;}

    .why{background:var(--beige);padding:120px 0 0;position:relative;overflow:hidden;}
    .why-bg-orb{position:absolute;top:-80px;right:-80px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.045) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .why-inner,.proc-inner,.faq-inner,.area-inner{max-width:1400px;margin:0 auto;padding:0 64px;position:relative;z-index:1;}
    .why-head,.proc-head{display:flex;align-items:flex-end;justify-content:space-between;}
    .why-head{margin-bottom:72px;padding-bottom:40px;border-bottom:1px solid rgba(1,42,20,.1);}
    .why-eye{color:#8a6840;margin-bottom:12px;}
    .why-h2{color:var(--green);}
    .why-intro{font-size:15px;color:rgba(1,42,20,.45);line-height:1.65;max-width:380px;}
    .why-rows{margin-bottom:0;}
    .why-row{padding:36px 0;border-bottom:1px solid rgba(1,42,20,.08);display:grid;grid-template-columns:80px 1fr 320px;gap:40px;align-items:center;opacity:0;transform:translateY(20px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);}
    .why-row.in,.proc-step.in{opacity:1;transform:translateY(0);}
    .why-row-n{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:800;letter-spacing:.1em;color:rgba(1,42,20,.2);align-self:flex-start;padding-top:8px;}
    .why-row-stmt{font-family:'Barlow Condensed',sans-serif;font-size:clamp(36px,3.2vw,48px);font-weight:800;font-style:italic;text-transform:uppercase;line-height:.9;letter-spacing:-.02em;color:var(--green);display:flex;flex-direction:column;gap:2px;}
    .why-row-stmt em{color:var(--gold);font-style:italic;}
    .why-row-detail{font-size:13px;color:rgba(1,42,20,.5);line-height:1.7;padding-left:24px;border-left:2px solid rgba(200,150,90,.2);}
    .why-cta-band{background:var(--green);padding:48px 64px;display:flex;align-items:center;justify-content:space-between;gap:60px;position:relative;overflow:hidden;margin-top:72px;}
    .why-cta-band::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 50% -10%,rgba(200,150,90,.18) 0%,transparent 60%);}
    .why-cta-band::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(200,150,90,.4),transparent);}
    .why-cta-band-grain{position:absolute;inset:0;pointer-events:none;opacity:.04;}
    .why-cta-left,.why-cta-right{position:relative;z-index:1;}
    .why-cta-label{font-size:9px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(200,150,90,.6);margin-bottom:10px;}
    .why-cta-stmt,.faq-h2,.cta-h2{font-family:'Barlow Condensed',sans-serif;font-weight:800;text-transform:uppercase;line-height:.9;letter-spacing:-.015em;}
    .why-cta-stmt{font-size:clamp(32px,2.8vw,44px);color:#fff;}
    .why-cta-right,.cta-right{display:flex;flex-direction:column;gap:12px;min-width:280px;}
    .why-cta-btn{display:flex;align-items:center;justify-content:center;background:var(--gold-grad);color:#fff;font-size:14px;font-weight:800;padding:17px;border-radius:12px;width:100%;position:relative;overflow:hidden;letter-spacing:-.01em;box-shadow:0 12px 32px rgba(180,110,40,.42),inset 0 1px 0 rgba(255,255,255,.18);}
    .why-cta-phone,.cta-phone-row{display:flex;align-items:center;justify-content:center;gap:7px;text-decoration:none;}
    .why-cta-phone span,.cta-phone-row span{font-size:12px;color:rgba(255,255,255,.3);}
    .why-cta-phone strong,.cta-phone-row strong{font-size:12px;color:rgba(255,255,255,.62);font-weight:700;}

    .process{background:var(--green);padding:120px 0 0;position:relative;overflow:hidden;}
    .proc-grain{position:absolute;inset:0;z-index:0;opacity:.04;}
    .proc-orb{position:absolute;bottom:-80px;left:-80px;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.045) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .proc-head{margin-bottom:96px;}
    .proc-eye{color:rgba(200,150,90,.72);margin-bottom:12px;}
    .proc-h2{color:#fff;}
    .proc-sub{font-size:15px;color:rgba(255,255,255,.38);line-height:1.65;max-width:360px;}
    .proc-steps{display:grid;grid-template-columns:repeat(4,1fr);position:relative;padding-bottom:0;}
    .proc-line{position:absolute;top:36px;left:calc(12.5%);right:calc(12.5%);height:1px;background:rgba(255,255,255,.08);z-index:0;overflow:hidden;}
    .proc-line-fill{position:absolute;inset:0;background:linear-gradient(90deg,var(--gold),rgba(200,150,90,.4));box-shadow:0 0 8px rgba(200,150,90,.3);transform:translateX(-100%);transition:transform 1.4s cubic-bezier(.22,1,.36,1);}
    .proc-line-fill.on{transform:translateX(0);}
    .proc-step{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;padding:0 24px 60px;opacity:0;transform:translateY(24px);transition:opacity .65s cubic-bezier(.22,1,.36,1),transform .65s cubic-bezier(.22,1,.36,1);}
    .proc-circle{width:72px;height:72px;border-radius:50%;border:1.5px solid rgba(255,255,255,.12);background:var(--green);display:grid;place-items:center;margin-bottom:32px;position:relative;transition:border-color 400ms ease,box-shadow 400ms ease;box-shadow:0 0 0 0 rgba(200,150,90,.0);}
    .proc-step.in .proc-circle{border-color:rgba(200,150,90,.45);box-shadow:0 0 0 6px rgba(200,150,90,.08),0 0 24px rgba(200,150,90,.15);}
    .proc-circle-inner{width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,.04);display:grid;place-items:center;transition:background 400ms ease;}
    .proc-step.in .proc-circle-inner{background:rgba(200,150,90,.1);}
    .proc-verb{font-family:'Barlow Condensed',sans-serif;font-size:clamp(48px,4.2vw,64px);font-weight:800;text-transform:uppercase;letter-spacing:-.025em;color:var(--gold);line-height:1;text-align:center;margin-bottom:12px;}
    .proc-title{font-size:14px;font-weight:800;color:#fff;text-align:center;margin-bottom:8px;letter-spacing:-.01em;}
    .proc-desc{font-size:12.5px;color:rgba(255,255,255,.38);text-align:center;line-height:1.68;}
    .proc-close-band{border-top:1px solid rgba(255,255,255,.07);padding:48px 0 96px;text-align:center;position:relative;z-index:1;}
    .proc-close-text{font-family:'Barlow Condensed',sans-serif;font-size:clamp(24px,2.2vw,34px);font-weight:800;font-style:italic;text-transform:uppercase;line-height:.95;letter-spacing:-.015em;color:rgba(255,255,255,.22);}
    .proc-close-text em{color:rgba(200,150,90,.45);font-style:italic;}

    .cta{background:var(--beige);padding:120px 64px;}
    .cta-card{max-width:1400px;margin:0 auto;background:var(--green);border-radius:32px;padding:80px 96px;display:grid;grid-template-columns:1fr auto;gap:80px;align-items:center;position:relative;overflow:hidden;box-shadow:0 40px 80px rgba(1,42,20,.3);}
    .cta-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 65% 60% at 50% -8%,rgba(200,150,90,.2) 0%,transparent 60%);}
    .cta-card::after{content:'';position:absolute;top:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(200,150,90,.5),transparent);}
    .cta-grain{position:absolute;inset:0;pointer-events:none;opacity:.04;border-radius:32px;}
    .cta-deco-n{position:absolute;right:96px;bottom:-10px;font-family:'Barlow Condensed',sans-serif;font-size:240px;font-weight:800;line-height:.8;letter-spacing:-.04em;color:transparent;-webkit-text-stroke:1px rgba(200,150,90,.08);pointer-events:none;user-select:none;white-space:nowrap;}
    .cta-left{position:relative;z-index:1;}
    .cta-eye{font-size:9px;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:rgba(200,150,90,.6);margin-bottom:14px;}
    .cta-h2{font-size:clamp(52px,4.5vw,72px);color:#fff;margin-bottom:16px;}
    .cta-body{font-size:15px;color:rgba(255,255,255,.42);line-height:1.65;max-width:460px;}
    .cta-right{position:relative;z-index:1;min-width:300px;}
    .cta-btn{display:flex;align-items:center;justify-content:space-between;background:var(--gold-grad);color:#fff;font-size:14px;font-weight:800;padding:18px 24px;border-radius:14px;position:relative;overflow:hidden;letter-spacing:-.01em;box-shadow:0 14px 36px rgba(180,110,40,.44),inset 0 1px 0 rgba(255,255,255,.18);}
    .cta-btn-ico{width:30px;height:30px;border-radius:9px;background:rgba(255,255,255,.18);display:grid;place-items:center;flex-shrink:0;position:relative;z-index:1;font-size:14px;}
    .cta-btn-txt{position:relative;z-index:1;}

    .faq{background:var(--green);padding:0;position:relative;overflow:hidden;}
    .faq-grain{position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.04;}
    .faq-orb{position:absolute;top:-80px;right:-80px;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.045) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .faq-inner{position:relative;z-index:1;padding:120px 64px;display:grid;grid-template-columns:400px 1fr;gap:96px;}
    .faq-left{height:fit-content;}
    .faq-eye{color:rgba(200,150,90,.72);margin-bottom:12px;}
    .faq-h2{font-size:clamp(52px,4.5vw,72px);color:#fff;margin-bottom:16px;}
    .faq-intro{font-size:13px;color:rgba(255,255,255,.38);line-height:1.68;margin-bottom:28px;}
    .faq-direct{display:inline-flex;align-items:center;gap:9px;background:rgba(200,150,90,.1);border:1px solid rgba(200,150,90,.2);color:var(--gold);font-size:12px;font-weight:800;padding:12px 22px;border-radius:10px;text-decoration:none;}
    .faq-list{display:flex;flex-direction:column;}
    .faq-item{border-top:1px solid rgba(255,255,255,.07);}
    .faq-item:last-child{border-bottom:1px solid rgba(255,255,255,.07);}
    .faq-item.open,.faq-item.open + .faq-item{border-top-color:rgba(200,150,90,.2);}
    .faq-q-row{display:flex;align-items:flex-start;justify-content:space-between;gap:24px;padding:28px 0;background:none;border:0;width:100%;cursor:pointer;text-align:left;}
    .faq-q{font-family:'Barlow Condensed',sans-serif;font-size:clamp(22px,1.9vw,28px);font-weight:800;font-style:italic;text-transform:uppercase;line-height:.9;letter-spacing:-.01em;color:rgba(255,255,255,.6);flex:1;transition:color 250ms ease;}
    .faq-item.open .faq-q{color:#fff;}
    .faq-tog{width:30px;height:30px;border-radius:50%;border:1.5px solid rgba(255,255,255,.1);background:rgba(255,255,255,.03);display:grid;place-items:center;flex-shrink:0;margin-top:2px;transition:transform 350ms cubic-bezier(.22,1,.36,1),border-color 250ms ease,background 250ms ease;position:relative;}
    .faq-item.open .faq-tog{transform:rotate(45deg);border-color:rgba(200,150,90,.3);background:rgba(200,150,90,.1);}
    .faq-tog::before,.faq-tog::after{content:'';position:absolute;background:rgba(255,255,255,.4);border-radius:999px;transition:background 250ms ease;}
    .faq-item.open .faq-tog::before,.faq-item.open .faq-tog::after{background:var(--gold);}
    .faq-tog::before{width:11px;height:1.5px;}
    .faq-tog::after{width:1.5px;height:11px;}
    .faq-ans-wrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows 380ms cubic-bezier(.22,1,.36,1);}
    .faq-item.open .faq-ans-wrap{grid-template-rows:1fr;}
    .faq-ans-inner{overflow:hidden;}
    .faq-ans{font-size:14px;color:rgba(255,255,255,.5);line-height:1.72;padding-bottom:28px;}
    .faq-item.open .faq-q-row{border-bottom:1px solid rgba(200,150,90,.12);}

    .area{background:var(--beige);padding:120px 0;position:relative;overflow:hidden;}
    .area-orb{position:absolute;bottom:-60px;right:-60px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.04) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .area-inner{display:grid;grid-template-columns:1fr 440px;gap:100px;align-items:start;}
    .area-eye{color:#8a6840;margin-bottom:12px;}
    .area-h2{color:var(--green);margin-bottom:12px;}
    .area-intro{font-size:14px;color:rgba(1,42,20,.45);line-height:1.65;max-width:360px;margin-bottom:44px;}
    .area-map{display:flex;flex-wrap:wrap;align-items:baseline;gap:0;line-height:1.1;}
    .town{font-family:'Barlow Condensed',sans-serif;font-weight:800;text-transform:uppercase;letter-spacing:-.005em;color:rgba(1,42,20,.35);transition:color 300ms ease;}
    .town:hover{color:var(--green);}
    .town.primary{font-size:clamp(64px,6vw,86px);color:var(--green);display:flex;align-items:center;gap:12px;width:100%;margin-bottom:4px;}
    .town-pin{width:12px;height:12px;border-radius:50%;background:var(--gold);flex-shrink:0;}
    .town.lg{font-size:clamp(28px,2.6vw,38px);color:rgba(1,42,20,.5);}
    .town.md{font-size:clamp(20px,1.9vw,26px);color:rgba(1,42,20,.3);}
    .town.sm{font-size:clamp(15px,1.4vw,20px);color:rgba(1,42,20,.2);}
    .town-sep{font-family:'Barlow Condensed',sans-serif;font-weight:400;color:rgba(1,42,20,.15);padding:0 12px;align-self:center;}
    .town-sep.lg{font-size:28px;}
    .town-sep.sm{font-size:20px;padding:0 8px;}
    .area-card{background:var(--green);border-radius:26px;padding:40px;position:relative;overflow:hidden;box-shadow:0 28px 56px rgba(1,42,20,.22);}
    .area-card::before{content:'';position:absolute;top:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(200,150,90,.4),transparent);}
    .area-card-grain{position:absolute;inset:0;pointer-events:none;opacity:.04;border-radius:26px;}
    .area-card-inner{position:relative;z-index:1;}
    .area-card-title{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;text-transform:uppercase;color:#fff;letter-spacing:-.01em;margin-bottom:5px;}
    .area-card-sub{font-size:12px;color:rgba(255,255,255,.38);margin-bottom:22px;}
    .zip-row{display:flex;gap:10px;margin-bottom:24px;}
    .zip-input{flex:1;padding:14px 16px;border:1.5px solid rgba(255,255,255,.1);border-radius:11px;font-size:14px;color:#fff;background:rgba(255,255,255,.06);font-family:'Inter',sans-serif;outline:none;transition:border-color 200ms ease;}
    .zip-input::placeholder{color:rgba(255,255,255,.25);}
    .zip-input:focus{border-color:rgba(200,150,90,.4);}
    .zip-btn{background:var(--gold-grad);color:#fff;font-size:12.5px;font-weight:800;padding:14px 22px;border-radius:11px;white-space:nowrap;box-shadow:0 7px 18px rgba(180,110,40,.32),inset 0 1px 0 rgba(255,255,255,.18);position:relative;overflow:hidden;}
    .area-hr{height:1px;background:rgba(255,255,255,.08);margin-bottom:20px;}
    .area-contacts{display:flex;flex-direction:column;gap:2px;}
    .area-contact{display:flex;align-items:center;gap:13px;padding:13px 0;border-bottom:1px solid rgba(255,255,255,.06);cursor:pointer;transition:opacity 200ms ease;text-decoration:none;}
    .area-contact:last-child{border-bottom:none;}
    .area-contact:hover{opacity:.8;}
    .ac-ico{width:38px;height:38px;min-width:38px;border-radius:11px;background:rgba(200,150,90,.1);border:1px solid rgba(200,150,90,.18);display:grid;place-items:center;flex-shrink:0;color:#c8965a;font-size:16px;}
    .ac-text{flex:1;}
    .ac-text strong{display:block;font-size:13px;font-weight:800;color:#fff;margin-bottom:2px;letter-spacing:-.01em;}
    .ac-text span{font-size:11px;color:rgba(255,255,255,.36);}
    .ac-arr{font-size:14px;color:rgba(200,150,90,.4);}

    .footer{background:#011a0d;}
    .footer-stmt{max-width:1400px;margin:0 auto;padding:72px 64px 60px;border-bottom:1px solid rgba(255,255,255,.05);position:relative;overflow:hidden;}
    .footer-stmt::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 10% 0%,rgba(200,150,90,.08) 0%,transparent 60%);}
    .footer-stmt::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,rgba(200,150,90,.45),rgba(200,150,90,.1) 35%,transparent 65%);}
    .footer-stmt-text{position:relative;z-index:1;font-family:'Barlow Condensed',sans-serif;font-size:clamp(40px,4vw,60px);font-weight:800;text-transform:uppercase;line-height:.88;letter-spacing:-.015em;color:rgba(255,255,255,.16);}
    .footer-grid{max-width:1400px;margin:0 auto;padding:56px 64px 48px;display:grid;grid-template-columns:2.2fr 1fr 1fr 1fr 1fr;gap:56px;border-bottom:1px solid rgba(255,255,255,.05);}
    .footer-brand-name{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:#fff;line-height:1;margin-bottom:4px;}
    .footer-brand-name em{color:var(--gold);font-style:normal;}
    .footer-tag-line{font-size:8.5px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.22);margin-bottom:14px;}
    .footer-desc{font-size:12px;color:rgba(255,255,255,.36);line-height:1.65;max-width:240px;margin-bottom:18px;}
    .footer-brand-tel{display:inline-flex;align-items:center;gap:7px;background:rgba(200,150,90,.08);border:1px solid rgba(200,150,90,.18);border-radius:999px;padding:8px 16px;color:var(--gold);font-size:11px;font-weight:800;text-decoration:none;}
    .footer-col-head{font-size:8px;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.2);margin-bottom:16px;}
    .footer-col-links{display:flex;flex-direction:column;gap:10px;}
    .footer-col-links a{font-size:13px;color:rgba(255,255,255,.42);text-decoration:none;transition:color 200ms ease;}
    .footer-col-links a:hover{color:rgba(255,255,255,.82);}
    .footer-meta{max-width:1400px;margin:0 auto;padding:20px 64px 28px;display:flex;align-items:center;justify-content:space-between;}
    .footer-copy{font-size:10px;color:rgba(255,255,255,.22);}
    .footer-copy span{display:block;color:rgba(255,255,255,.28);margin-top:2px;}
    .footer-top{font-size:10px;color:rgba(255,255,255,.28);border:1px solid rgba(255,255,255,.08);padding:6px 14px;border-radius:999px;cursor:pointer;transition:color 200ms ease,border-color 200ms ease;background:transparent;}
    .footer-top:hover{color:rgba(255,255,255,.65);border-color:rgba(255,255,255,.18);}
  }
</style>

<script is:inline>
  (function () {
    var desktopQuery = window.matchMedia('(min-width: 900px)');
    if (!desktopQuery.matches) return;

    var root = document.querySelector('[data-desktop-homepage]');
    if (!root) return;

    var hdr = root.querySelector('#hdr');
    var procLine = root.querySelector('[data-proc-line]');
    var panelTriggers = Array.prototype.slice.call(root.querySelectorAll('[data-panel-trigger]'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('[data-panel]'));
    var faqItems = Array.prototype.slice.call(root.querySelectorAll('[data-faq-item]'));
    if (hdr) {
      window.addEventListener('scroll', function () {
        hdr.classList.toggle('scrolled', window.scrollY > 60);
      }, { passive: true });
    }

    var panelColors = [
      'rgba(200,150,90,1)',
      'rgba(130,210,70,1)',
      'rgba(210,145,55,1)',
      'rgba(110,170,255,1)'
    ];

    var switchPanel = function (index) {
      panels.forEach(function (panel, panelIndex) {
        panel.classList.toggle('active', panelIndex === index);
      });
      panelTriggers.forEach(function (trigger, triggerIndex) {
        trigger.classList.toggle('active', triggerIndex === index);
      });
    };

    panelTriggers.forEach(function (trigger, index) {
      var color = panelColors[index];
      trigger.style.setProperty('--accent', color);
      trigger.addEventListener('click', function () {
        switchPanel(index);
      });
      trigger.addEventListener('mouseenter', function () {
        switchPanel(index);
      });
    });

    var dynamicStyle = document.createElement('style');
    dynamicStyle.textContent = panelColors.map(function (color, index) {
      var rgba = color.slice(5, -1);
      return '.desktop-homepage .svc-nav-item:nth-child(' + (index + 1) + ').active::before{background:linear-gradient(180deg,' + color + ',rgba(' + rgba + ',.15));}';
    }).join('');
    document.head.appendChild(dynamicStyle);

    root.querySelectorAll('[data-faq-toggle]').forEach(function (toggle) {
      toggle.addEventListener('click', function () {
        var item = toggle.closest('[data-faq-item]');
        var wasOpen = item && item.classList.contains('open');
        faqItems.forEach(function (faq) {
          faq.classList.remove('open');
        });
        if (item && !wasOpen) {
          item.classList.add('open');
        }
      });
    });

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    root.querySelectorAll('[data-animate-in]').forEach(function (el) {
      io.observe(el);
    });

    if (procLine) {
      var lineObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            procLine.classList.add('on');
            lineObs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      lineObs.observe(procLine);
    }

    var scrollTopButton = root.querySelector('[data-scroll-top]');
    if (scrollTopButton) {
      scrollTopButton.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  })();
</script>
