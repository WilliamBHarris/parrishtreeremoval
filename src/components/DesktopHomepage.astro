    }

    if (
      cardLeft && cardCenter && cardRight && reviewSection && reviewHeader && reviewBottom &&
      reviewTrack && reviewPrev && reviewNext && reviewCount && reviewSets.length > 0
    ) {
      var activeReviewSet = 0;
      var reviewTimer = 0;
      var reviewVisible = false;
      var reviewInteracted = false;
      var reviewAnimating = false;
      var REVIEW_AUTO_MS = 8000;
      var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var renderReviewSet = function (index) {
        var set = reviewSets[index];
        if (!set) return;

        reviewCards.forEach(function (cardEl, slotIndex) {
          if (!cardEl) return;
          var cardData = set[slotIndex];
          if (!cardData) return;
          var quoteEl = cardEl.querySelector('[data-rev-quote]');
          var nameEl = cardEl.querySelector('[data-rev-name]');
          var locationEl = cardEl.querySelector('[data-rev-location]');
          var dateEl = cardEl.querySelector('[data-rev-date]');
          var tagEl = cardEl.querySelector('[data-rev-tag]');
          var tagLabelEl = cardEl.querySelector('[data-rev-tag-label]');

          if (quoteEl) quoteEl.innerHTML = cardData.quote;
          if (nameEl) nameEl.textContent = cardData.name;
          if (locationEl) locationEl.textContent = cardData.location;
          if (dateEl) dateEl.textContent = cardData.date;
          if (tagEl) tagEl.className = 'card-tag ' + cardData.tagClass;
          if (tagLabelEl) tagLabelEl.textContent = cardData.tag;
        });

        reviewDots.forEach(function (dot, dotIndex) {
          dot.classList.toggle('is-active', dotIndex === index);
        });

        reviewCount.textContent = String(index + 1) + ' of ' + String(reviewSets.length) + ' · ' + String(reviewSets.length * 3) + ' reviews';
      };

      var queueReviewAdvance = function () {
        window.clearTimeout(reviewTimer);
        if (!reviewVisible || reviewInteracted || reviewSets.length < 2) return;
        reviewTimer = window.setTimeout(function () {
          swapReviewSet((activeReviewSet + 1) % reviewSets.length, 'next', false);
        }, REVIEW_AUTO_MS);
      };

      var swapReviewSet = function (nextIndex, direction, userTriggered) {
        if (reviewAnimating || nextIndex === activeReviewSet) return;
        reviewAnimating = true;
        if (userTriggered) reviewInteracted = true;
        window.clearTimeout(reviewTimer);

        var exitClass = direction === 'prev' ? 'is-exiting-right' : 'is-exiting-left';
        var enterClass = direction === 'prev' ? 'is-entering-right' : 'is-entering-left';
        var finishSwap = function () {
          reviewTrack.classList.remove('is-exiting-left', 'is-exiting-right');
          activeReviewSet = nextIndex;
          renderReviewSet(activeReviewSet);
          reviewTrack.classList.add(enterClass);
          window.requestAnimationFrame(function () {
            window.requestAnimationFrame(function () {
              reviewTrack.classList.remove(enterClass);
              window.setTimeout(function () {
                reviewAnimating = false;
                queueReviewAdvance();
              }, reduceMotion ? 40 : 460);
            });
          });
        };

        if (reduceMotion) {
          finishSwap();
          return;
        }

        reviewTrack.classList.add(exitClass);
        window.setTimeout(finishSwap, 380);
      };

      var reviewSectionDocTop = reviewSection.getBoundingClientRect().top + window.scrollY;
      var reviewSectionHeight = reviewSection.offsetHeight || 1;
      window.addEventListener('resize', function () {
        reviewSectionDocTop = reviewSection.getBoundingClientRect().top + window.scrollY;
        reviewSectionHeight = reviewSection.offsetHeight || 1;
      }, { passive: true });

      updateReviewParallax = function () {
        if (reduceMotion) return;
        var top = reviewSectionDocTop - window.scrollY;
        var inView = top < window.innerHeight && top + reviewSectionHeight > 0;
        if (!inView) return;
        var progress = (window.innerHeight - top) / (window.innerHeight + reviewSectionHeight);
        var offset = (progress - 0.5) * 18;
        cardLeft.style.transform = 'translateY(' + (offset * 0.6) + 'px)';
        cardRight.style.transform = 'translateY(' + (offset * 0.6) + 'px)';
        cardCenter.style.transform = 'translateY(' + (offset * 0.15) + 'px)';
      };

      renderReviewSet(activeReviewSet);
      updateReviewParallax();

      reviewPrev.addEventListener('click', function () {
        swapReviewSet((activeReviewSet - 1 + reviewSets.length) % reviewSets.length, 'prev', true);
      });

      reviewNext.addEventListener('click', function () {
        swapReviewSet((activeReviewSet + 1) % reviewSets.length, 'next', true);
      });

      reviewDots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          var nextIndex = Number(dot.getAttribute('data-rev-dot-index') || '0');
          if (!isFinite(nextIndex)) return;
          swapReviewSet(nextIndex, nextIndex < activeReviewSet ? 'prev' : 'next', true);
        });
      });

      var reviewVisibilityHandler = function () {
        if (document.hidden) {
          window.clearTimeout(reviewTimer);
          return;
        }
        queueReviewAdvance();
      };

      document.addEventListener('visibilitychange', reviewVisibilityHandler);

      if ('IntersectionObserver' in window) {
        var reviewObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            reviewVisible = Boolean(entry.isIntersecting);
            if (!reviewVisible) {
              window.clearTimeout(reviewTimer);
              return;
            }

            reviewHeader.classList.add('visible');

            if (!cardCenter.classList.contains('anim-center')) {
              window.setTimeout(function () {
                cardCenter.classList.add('anim-center');
              }, 100);

              window.setTimeout(function () {
                cardLeft.classList.add('anim-left');
              }, 280);

              window.setTimeout(function () {
                cardRight.classList.add('anim-right');
              }, 280);

              window.setTimeout(function () {
                reviewBottom.classList.add('visible');
              }, 500);
            }

            queueReviewAdvance();
          });
        }, { threshold: 0.15 });

        reviewObserver.observe(reviewSection);
      } else {
        reviewVisible = true;
        queueReviewAdvance();
      }
    }

    var procSection = document.getElementById('proc');
    var procHeader = document.getElementById('procHeader');
    var procClose = document.getElementById('procClose');
    var procCtaBand = document.getElementById('procCtaBand');
    var procLine = document.getElementById('procLine');

    if (procSection && procHeader && procClose && procCtaBand && procLine) {
      var procSteps = [0, 1, 2, 3];
      var procCircles = procSteps.map(function (i) { return document.getElementById('pc' + i); });
      var procStepEls = procSteps.map(function (i) { return document.getElementById('ps' + i); });
      var procSequenceRun = false;

      var runProcSequence = function () {
        if (procSequenceRun) return;
        procSequenceRun = true;

        procHeader.classList.add('visible');

        window.setTimeout(function () {
          procLine.classList.add('drawn');
        }, 400);

        var lineStart = 400;
        var lineDur = 1200;
        var stepDelay = lineDur / 4;

        procSteps.forEach(function (_, i) {
          var activateAt = lineStart + (stepDelay * i) + (stepDelay * 0.5);
          window.setTimeout(function () {
            var circle = procCircles[i];
            var stepEl = procStepEls[i];
            if (circle) {
              circle.classList.add('active');
              circle.classList.add('pulse');
            }
            if (stepEl) stepEl.classList.add('active');
          }, activateAt);
        });

        window.setTimeout(function () {
          procClose.classList.add('visible');
        }, lineStart + lineDur + 200);

        window.setTimeout(function () {
          procCtaBand.classList.add('revealed');
        }, lineStart + lineDur + 600);
      };

      if ('IntersectionObserver' in window) {
        var procObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            runProcSequence();
            procObserver.disconnect();
          });
        }, { threshold: 0.25 });

        procObserver.observe(procSection);
      } else {
        runProcSequence();
      }
    }

    var faqItems = Array.prototype.slice.call(root.querySelectorAll('[data-faq-item]'));
    faqItems.forEach(function (item) {
      var toggle = item.querySelector('[data-faq-toggle]');
      if (!toggle) return;
      toggle.addEventListener('click', function () {
        var isOpen = item.classList.contains('open');
        faqItems.forEach(function (other) {
          other.classList.remove('open');
        });
        if (!isOpen) item.classList.add('open');
      });
    });

    var zipLookups = Array.prototype.slice.call(root.querySelectorAll('[data-service-area-lookup]'));
    zipLookups.forEach(function (lookup) {
      var form = lookup.querySelector('[data-zip-form]');
      var input = lookup.querySelector('[data-zip-input]');
      var message = lookup.querySelector('[data-zip-message]');
      var invalidZipMessage = String(lookup.getAttribute('data-invalid-zip-message') || 'Enter a valid 5-digit ZIP code.');
      var inAreaMessage = String(lookup.getAttribute('data-in-area-message') || "We're in your area.");
      var outOfAreaMessage = String(lookup.getAttribute('data-out-of-area-message') || "Sorry, we aren't out there yet.");
      var supported = new Set(
        String(lookup.getAttribute('data-supported-zips') || '')
          .split(',')
          .map(function (zip) { return zip.trim(); })
          .filter(Boolean)
      );

      if (!form || !(form instanceof HTMLFormElement) || !input || !(input instanceof HTMLInputElement) || !message) return;

      var renderZipMessage = function (text, isValid) {
        message.textContent = text;
        message.hidden = false;
        message.classList.toggle('is-valid', Boolean(isValid));
        message.classList.toggle('is-invalid', !isValid);
      };

      input.addEventListener('input', function () {
        var digitsOnly = input.value.replace(/\D+/g, '').slice(0, 5);
        if (input.value !== digitsOnly) input.value = digitsOnly;
        message.hidden = true;
        message.classList.remove('is-valid', 'is-invalid');
      });

      form.addEventListener('submit', function (event) {
        event.preventDefault();

        var zip = input.value.trim();

        if (!/^\d{5}$/.test(zip)) {
          renderZipMessage(invalidZipMessage, false);
          return;
        }

        if (supported.has(zip)) {
          renderZipMessage(inAreaMessage, true);
          return;
        }

        renderZipMessage(outOfAreaMessage, false);
      });
    });

    var backToTop = root.querySelector('[data-back-to-top]');
    if (backToTop) {
      backToTop.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    var countEls = Array.prototype.slice.call(root.querySelectorAll('[data-count-to]'));
    var animateCount = function (el) {
      if (!el || el.dataset.counted === 'true') return;
      var target = parseFloat(el.getAttribute('data-count-to') || '0');
      if (!isFinite(target)) return;
      el.dataset.counted = 'true';

      var decimals = (String(target).split('.')[1] || '').length;
      var duration = 1200;
      var startTime = null;

      var renderValue = function (value) {
        if (decimals > 0) {
          el.textContent = value.toFixed(decimals);
        } else {
          el.textContent = String(Math.round(value));
        }
      };

      renderValue(0);

      var step = function (timestamp) {
        if (startTime === null) startTime = timestamp;
        var progress = Math.min((timestamp - startTime) / duration, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        renderValue(target * eased);
        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          renderValue(target);
        }
      };

      window.requestAnimationFrame(step);
    };

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.18 });

      root.querySelectorAll('[data-reveal]').forEach(function (el) {
        io.observe(el);
      });

      var countIo = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            animateCount(entry.target);
            countIo.unobserve(entry.target);
          }
        });
      }, { threshold: 0.45 });

      countEls.forEach(function (el) {
        countIo.observe(el);
      });
    } else {
      root.querySelectorAll('[data-reveal]').forEach(function (el) {
        el.classList.add('is-visible');
      });
      countEls.forEach(function (el) {
        var target = parseFloat(el.getAttribute('data-count-to') || '0');
        if (!isFinite(target)) return;
        el.textContent = String(target);
      });
    }
  })();
</script>
