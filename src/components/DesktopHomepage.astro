      --text-mute-dark: rgba(255,255,255,.72);
      --text-soft-light: rgba(1,42,20,.84);
      --text-mute-light: rgba(1,42,20,.68);
      --rule-dark: rgba(255,255,255,.14);
      --rule-light: rgba(1,42,20,.12);
    }

    *, *::before, *::after { box-sizing: border-box; }
    :global(html) { scroll-behavior: smooth; }
    :root{
      --green:#012a14; --green-mid:#014820; --gold:#c8965a; --gold-grad:linear-gradient(180deg,#d4a060,#b07840); --beige:#f2efe6;
    }
    @keyframes g1{0%,100%{opacity:1}33%{opacity:.08}66%{opacity:.5}}
    @keyframes g2{0%,100%{opacity:.08}33%{opacity:1}66%{opacity:.18}}
    @keyframes g3{0%,100%{opacity:.18}33%{opacity:.06}66%{opacity:1}}
    @keyframes lp{0%{opacity:.55}100%{opacity:1}}
    @keyframes o1{0%{transform:translate(0,0)scale(1)}100%{transform:translate(-18px,22px)scale(1.09)}}
    @keyframes o2{0%{transform:translate(0,0)scale(1)}100%{transform:translate(22px,-18px)scale(1.08)}}
    @keyframes dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.55)}}
    @keyframes tick{0%{transform:translate3d(0,0,0)}100%{transform:translate3d(-50%,0,0)}}
    @keyframes sweep{from{width:0;opacity:.4}to{width:100%;opacity:1}}
    @keyframes stormP{0%{box-shadow:0 0 0 0 rgba(74,143,217,.6)}70%{box-shadow:0 0 0 9px rgba(74,143,217,0)}100%{box-shadow:0 0 0 0 rgba(74,143,217,0)}}
    @keyframes pinP{0%{box-shadow:0 0 0 0 rgba(200,150,90,.5)}70%{box-shadow:0 0 0 10px rgba(200,150,90,0)}100%{box-shadow:0 0 0 0 rgba(200,150,90,0)}}
    @keyframes svcPillLoad{from{width:0}to{width:100%}}
    @keyframes tagGlow{0%,100%{box-shadow:0 0 0 0 var(--pulse);}50%{box-shadow:0 0 12px 3px var(--pulse);}}

    .grain{display:none;}
    .hdr{position:fixed;top:0;left:0;right:0;z-index:100;background:linear-gradient(180deg,rgba(1,42,20,.98) 0%,rgba(1,42,20,.95) 72%,rgba(1,42,20,.84) 100%);transition:background 220ms ease,border-color 220ms ease;border-bottom:1px solid rgba(255,255,255,.02);}
    .hdr.scrolled{background:linear-gradient(180deg,rgba(1,42,20,.98) 0%,rgba(1,42,20,.95) 72%,rgba(1,42,20,.84) 100%);border-color:rgba(255,255,255,.02);}
    .hdr-inner{width:min(calc(100% - 64px),1680px);margin:0 auto;padding:0 8px;min-height:92px;display:grid;grid-template-columns:auto 1fr auto;align-items:center;column-gap:52px;}
    .hdr-logo{font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;text-transform:uppercase;letter-spacing:.03em;color:#fff;line-height:.9;text-decoration:none;white-space:nowrap;}
    .hdr-logo em{color:var(--gold);font-style:normal;}
    .hdr-nav{display:flex;align-items:center;justify-content:flex-end;gap:42px;}
