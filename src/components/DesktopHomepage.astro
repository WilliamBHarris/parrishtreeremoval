---
import DesktopHeroExact from './DesktopHeroExact.astro';
import PremiumServicesScene from './PremiumServicesScene.astro';
import { client } from '../data/client';

const currentYear = new Date().getFullYear();
const estYear = client.yearsInBusiness ? currentYear - client.yearsInBusiness : 2014;
const supportedZips = client.serviceAreaZipCodes;
const serviceAreaLookupCopy = client.sharedContent.serviceAreaLookup;
const reviewSlotMeta = [
  { id: 'cardLeft', className: 'rev-card flank' },
  { id: 'cardCenter', className: 'rev-card center' },
  { id: 'cardRight', className: 'rev-card flank' },
] as const;

const reviewSets = [
  [
    {
      tagClass: 'tag-stump',
      quote: '"The stump was gone, <em>the chips were cleaned,</em> and the yard looked finished. One visit, done permanently."',
      name: 'Chris P.',
      location: 'Ellenton, FL',
      date: 'February 2025',
      tag: 'Stump Grinding',
    },
    {
      tagClass: 'tag-removal',
      quote:
        `"They showed up when they said, <em>left the yard cleaner than before the tree was there,</em> and charged exactly what they quoted. I've already sent three neighbors their way."`,
      name: 'Sarah K.',
      location: 'Parrish, FL',
      date: 'March 2025',
      tag: 'Tree Removal',
    },
    {
      tagClass: 'tag-storm',
      quote:
        '"Called at 7am after the storm. <em>Crew was here by noon,</em> driveway cleared, everything gone. Couldn\'t believe how fast."',
      name: 'Robert S.',
      location: 'Palmetto, FL',
      date: 'January 2025',
      tag: 'Storm Cleanup',
    },
  ],
  [
    {
      tagClass: 'tag-trim',
      quote:
        '"Trimmed everything back without tearing up the beds. <em>The yard looked sharper the same day,</em> and there was nothing left for us to clean."',
      name: 'Angela T.',
      location: 'Lakewood Ranch, FL',
      date: 'April 2025',
      tag: 'Tree Trimming',
    },
    {
      tagClass: 'tag-removal',
      quote:
        '"Fast quote, clear price, <em>clean finish from start to end,</em> and the crew handled the whole thing without us having to chase a single detail."',
      name: 'Daniel M.',
      location: 'Bradenton, FL',
      date: 'May 2025',
      tag: 'Tree Removal',
    },
    {
      tagClass: 'tag-storm',
      quote:
        '"They showed up, <em>handled the mess immediately,</em> and left nothing behind. Exactly what you want after a storm hits your property."',
      name: 'Lauren B.',
      location: 'Parrish, FL',
      date: 'June 2025',
      tag: 'Storm Cleanup',
    },
  ],
] as const;

const faqItems = [
  {
    question: 'Do you provide free estimates?',
    answer:
      "Yes. Send us a photo and we'll get you a flat price back fast, usually within a few hours. No site visit required for most jobs and no obligation to book.",
  },
  {
    question: 'How quickly can you come out?',
    answer:
      'Most jobs are booked within one to three days. Storm damage and emergencies are handled the same day when possible. Call us directly for urgent work.',
  },
  {
    question: 'Is cleanup included in the price?',
    answer:
      'Always. Every branch, log, and piece of debris is removed as part of every job. We rake, clear, and check before we leave.',
  },
  {
    question: 'Are you licensed and insured?',
    answer:
      "Fully licensed and insured. You're never liable for anything that happens on your property. We can provide proof of insurance before work starts.",
  },
  {
    question: "What if I'm not happy with the job?",
    answer:
      "We come back and finish it. No charge and no argument. That policy has been in place since 2014.",
  },
  {
    question: 'What areas do you serve?',
    answer:
      `Based in ${client.primaryLocation}, FL. We cover Manatee County, including Ellenton, Palmetto, Bradenton, and surrounding areas.`,
  },
];

const footerColumns = [
  {
    head: 'Services',
    links: [
      { label: 'Tree Removal', href: '/tree-removal' },
      { label: 'Tree Trimming', href: '/tree-trimming' },
      { label: 'Stump Grinding', href: '/stump-grinding' },
      { label: 'Storm Cleanup', href: '/emergency-tree-service' },
    ],
  },
  {
    head: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Service Area', href: '#desktop-area' },
      { label: 'Reviews', href: '#desktop-testimonials' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    head: 'Contact',
    links: [
      { label: client.primaryPhoneDisplay, href: `tel:${client.primaryPhoneHref}` },
      { label: client.email, href: `mailto:${client.email}` },
      { label: `${client.primaryLocation}, ${client.state}`.trim(), href: '#desktop-area' },
    ],
  },
  {
    head: 'Coverage',
    links: [
      { label: `${client.primaryLocation}, FL`, href: '#desktop-area' },
      { label: 'Ellenton, FL', href: '#desktop-area' },
      { label: 'Palmetto, FL', href: '#desktop-area' },
      { label: 'Bradenton, FL', href: '#desktop-area' },
      { label: 'Sarasota, FL', href: '#desktop-area' },
    ],
  },
];

const icon = (kind: string) => {
  switch (kind) {
    case 'removal':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M9 15c-3-1-5-4-4-7 2 0 4 1 5 3"/><path d="M15 15c3-1 5-4 4-7-2 0-4 1-5 3"/><path d="M8 22h8"/></svg>`;
    case 'trimming':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4L8.12 15.88"/><path d="M14.47 14.48L20 20"/><path d="M8.12 8.12L12 12"/></svg>`;
    case 'stump':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="2"/><path d="M12 5V3M12 21v-2M5 12H3M21 12h-2"/></svg>`;
    case 'storm':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/><path d="M11 13l-2 3h4l-2 3"/></svg>`;
    case 'phone':
      return `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011-.24c1.12.37 2.33.57 3.59.57a1 1 0 011 1V20a1 1 0 01-1 1C10.3 21 3 13.7 3 4.5a1 1 0 011-1H7.5a1 1 0 011 1c0 1.26.2 2.47.57 3.59a1 1 0 01-.45 1z"/></svg>`;
    case 'photo':
      return `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
    case 'quote':
      return `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg>`;
    case 'clock':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`;
    case 'chat':
      return `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`;
    case 'mail':
      return `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`;
    case 'check':
      return `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>`;
    default:
      return '';
  }
};
---

<div class="desktop-homepage" data-desktop-homepage>
  <div class="scroll-prog"><div class="scroll-fill" data-scroll-fill></div></div>
  <button type="button" class="float-pill" data-open-estimate-modal data-float-pill><span>Get a Free Estimate</span><b>→</b></button>

  <DesktopHeroExact />

  <PremiumServicesScene />

  <section class="reviews" id="desktop-testimonials">
    <div class="rev-top-fade"></div>
    <div class="rev-glow"></div>
    <div class="grain rev-grain"></div>
    <script type="application/json" id="desktop-review-sets" set:html={JSON.stringify(reviewSets)}></script>

    <div class="rev-header" id="revHeader">
      <div class="rev-header-left">
        <div class="rev-eye"><div class="rev-eye-dot"></div>What Parrish Homeowners Say</div>
        <div class="rev-h2">Don't Take<br /><em>Our Word For It.</em></div>
      </div>
      <div class="rev-header-right">
        <div class="rev-google">
          <div class="rev-google-g">G</div>
          <div class="rev-google-txt">Verified Google Reviews</div>
          <div class="rev-google-stars">★★★★★</div>
        </div>
        <div class="rev-meta">5.0 average · Parrish, FL · 47 reviews</div>
      </div>
    </div>

    <div class="rev-slider">
      <button type="button" class="rev-nav rev-nav-prev" data-rev-prev aria-label="Previous review set">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.5 5.5 8 12l6.5 6.5" />
        </svg>
      </button>
      <div class="rev-cards-wrap" id="revCards">
        {reviewSlotMeta.map((slot, index) => {
          const card = reviewSets[0][index];
          return (
        <div class={slot.className} id={slot.id}>
          <div class="card-glow"></div>
          <div class="grain card-grain"></div>
          <div class="card-wm">&ldquo;</div>
          <div class="card-stars">★★★★★</div>
          <div class="card-quote" data-rev-quote set:html={card.quote}></div>
          <div class="card-attr">
            <div class="card-attr-left">
              <div class="card-name" data-rev-name>{card.name}</div>
              <div class="card-location" data-rev-location>{card.location}</div>
              <div class="card-date" data-rev-date>{card.date}</div>
            </div>
            <div class:list={['card-tag', card.tagClass]} data-rev-tag>
              <div class="card-tag-dot"></div>
              <span data-rev-tag-label>{card.tag}</span>
            </div>
          </div>
        </div>
          );
        })}
      </div>
      <button type="button" class="rev-nav rev-nav-next" data-rev-next aria-label="Next review set">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9.5 5.5 16 12l-6.5 6.5" />
        </svg>
      </button>
    </div>

    <div class="rev-status" id="revStatus">
      <div class="rev-dots">
        {reviewSets.map((_, index) => (
          <button
            type="button"
            class:list={['rev-dot', index === 0 && 'is-active']}
            data-rev-dot
            data-rev-dot-index={String(index)}
            aria-label={`Go to review set ${index + 1}`}
          ></button>
        ))}
      </div>
      <div class="rev-count" data-rev-count>{`1 of ${reviewSets.length} · ${reviewSets.length * 3} reviews`}</div>
    </div>

    <div class="rev-bottom" id="revBottom">
      <div class="rev-bottom-left">
        <div class="rev-bottom-txt">
          Join <strong>500+</strong> Parrish homeowners who've trusted us with their property.
        </div>
      </div>
      <div class="rev-google-link">Read all reviews on Google →</div>
    </div>
  </section>

  <section class="proc" id="proc">
    <div class="proc-glow"></div>
    <div class="grain proc-grain"></div>
    <div class="proc-orb"></div>

    <div class="proc-header" id="procHeader">
      <div class="proc-eye"><div class="proc-eye-dot"></div>How It Works</div>
      <div class="proc-h2">Simple Process.<br /><em>No Guesswork.</em></div>
    </div>

    <div class="proc-steps-zone">
      <div class="proc-steps" id="procSteps">
        <div class="proc-line-track">
          <div class="proc-line-fill" id="procLine"></div>
        </div>

        <div class="proc-step" id="ps0">
          <div class="proc-circle" id="pc0">
            <div class="proc-circle-inner" set:html={icon('phone')}></div>
          </div>
          <div class="proc-verb">Call.</div>
          <div class="proc-title">You Call or Request</div>
          <p class="proc-desc">Reach out by phone or online. Tell us what you're dealing with.</p>
        </div>

        <div class="proc-step" id="ps1">
          <div class="proc-circle" id="pc1">
            <div class="proc-circle-inner" set:html={icon('chat')}></div>
          </div>
          <div class="proc-verb">Talk.</div>
          <div class="proc-title">We Have a Quick Chat</div>
          <p class="proc-desc">We ask a few questions to understand the job and assess what's needed.</p>
        </div>

        <div class="proc-step" id="ps2">
          <div class="proc-circle" id="pc2">
            <div class="proc-circle-inner" set:html={icon('quote')}></div>
          </div>
          <div class="proc-verb">Quote.</div>
          <div class="proc-title">We Send the Price</div>
          <p class="proc-desc">Flat, clear, complete. You know exactly what you'll pay before anyone shows up.</p>
        </div>

        <div class="proc-step" id="ps3">
          <div class="proc-circle" id="pc3">
            <div class="proc-circle-inner" set:html={icon('check')}></div>
          </div>
          <div class="proc-verb">Done.</div>
          <div class="proc-title">We Handle Everything</div>
          <p class="proc-desc">We show up, do the work, clean the site, and leave it better than we found it.</p>
        </div>
      </div>
    </div>

    <div class="proc-close" id="procClose">
      <div class="proc-close-rule"></div>
      <div class="proc-close-txt">First call to clean yard. <em>Usually same day.</em></div>
    </div>

    <div class="proc-cta-band" id="procCtaBand">
      <div class="grain proc-cta-band-grain"></div>
      <div class="proc-cta-band-glow"></div>
      <div class="proc-cta-left">
        <div class="proc-cta-ready">Ready to get started?</div>
        <div class="proc-cta-stmt">Four steps.<br /><em>Starting with one call.</em></div>
      </div>
      <div class="proc-cta-center">
        <button type="button" class="proc-est-btn" data-open-estimate-modal>
          <div class="est-btn-inner">
            <div class="est-btn-lbl">Free · No Obligation</div>
            <div class="est-btn-txt">Get a Free Estimate</div>
          </div>
          <div class="est-btn-arr">→</div>
        </button>
      </div>
      <div class="proc-cta-right">
        <div class="proc-cta-ph-lbl">Or call directly</div>
        <a class="proc-cta-ph-num" href={`tel:${client.primaryPhoneHref}`}>
          <span set:html={icon('phone')}></span>
          {client.primaryPhoneDisplay}
        </a>
        <div class="proc-cta-avail">Slots available this week</div>
      </div>
    </div>
  </section>

  <section class="guar">
    <div class="grain guar-grain"></div>
    <div class="guar-glow"></div>
    <div class="guar-inner">
      <div class="guar-badge"><div class="guar-dot"></div><div class="guar-badge-txt">Our Promise to Every Customer</div></div>
      <h2 class="guar-decl">We Guarantee<br /><span>The Work.</span></h2>
      <p class="guar-sub">If you&apos;re not satisfied with the cleanup when we leave, <strong>we come back and finish it. No charge. No argument.</strong> That has been our policy since {estYear}.</p>
      <div class="guar-action">
        <button type="button" class="proc-est-btn" data-open-estimate-modal>
          <div class="est-btn-inner">
            <div class="est-btn-lbl">Free · No Obligation</div>
            <div class="est-btn-txt">Get a Free Estimate</div>
          </div>
          <div class="est-btn-arr">→</div>
        </button>
        <div class="proc-cta-right">
          <div class="proc-cta-ph-lbl">Or call directly</div>
          <a class="proc-cta-ph-num" href={`tel:${client.primaryPhoneHref}`}>
            <span set:html={icon('phone')}></span>
            {client.primaryPhoneDisplay}
          </a>
          <div class="proc-cta-avail">Slots available this week</div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="grain faq-grain"></div>
    <div class="faq-orb"></div>
    <div class="faq-inner">
      <div class="faq-left">
        <div class="faq-eye"><div class="faq-eye-dot"></div>FAQ</div>
        <h2 class="faq-h2">Got<br /><span>Questions?</span></h2>
        <p class="faq-intro">Everything {client.primaryLocation} homeowners ask before they call. Don&apos;t see yours? Call us directly.</p>
        <div class="faq-cta-stack">
          <button type="button" class="proc-est-btn" data-open-estimate-modal>
            <div class="est-btn-inner">
              <div class="est-btn-lbl">Free · No Obligation</div>
              <div class="est-btn-txt">Get a Free Estimate</div>
            </div>
            <div class="est-btn-arr">→</div>
          </button>
          <div class="proc-cta-right">
            <div class="proc-cta-ph-lbl">Or call directly</div>
            <a class="proc-cta-ph-num" href={`tel:${client.primaryPhoneHref}`}>
              <span set:html={icon('phone')}></span>
              {client.primaryPhoneDisplay}
            </a>
            <div class="proc-cta-avail">Slots available this week</div>
          </div>
        </div>
      </div>
      <div class="faq-list">
        {faqItems.slice(0, 3).map((item, index) => (
          <div class:list={['faq-item', index === 0 && 'open']} data-faq-item>
            <button type="button" class="faq-q-row" data-faq-toggle>
              <div class="faq-q">{item.question}</div>
              <div class="faq-tog"></div>
            </button>
            <div class="faq-ans-wrap">
              <div class="faq-ans-inner"><p class="faq-ans">{item.answer}</p></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="area" id="desktop-area">
    <div class="area-orb"></div>
    <div class="area-inner">
      <div>
        <div class="area-eye"><div class="area-eye-dot"></div>Where We Work</div>
        <h2 class="area-h2">Serving {client.primaryLocation}<br /><span>& Beyond.</span></h2>
        <p class="area-sub">Based in {client.primaryLocation}, FL. Covering Manatee County and surrounding communities since {estYear}.</p>
        <div class="area-map">
          <div class="town p1"><div class="town-pin"></div>{client.primaryLocation}</div>
          <div class="town p2">Ellenton</div><div class="sep lg">·</div>
          <div class="town p2">Palmetto</div><div class="sep lg">·</div>
          <div class="town p2">Bradenton</div>
          <div class="area-spacer"></div>
          <div class="town p3">Sarasota</div><div class="sep sm">·</div>
          <div class="town p3">Ruskin</div><div class="sep sm">·</div>
          <div class="town p3">Wimauma</div><div class="sep sm">·</div>
          <div class="town p4">Sun City Center</div><div class="sep sm">·</div>
          <div class="town p4">Terra Ceia</div>
        </div>
      </div>
      <div class="area-right">
        <div
          class="area-card"
          data-service-area-lookup
          data-supported-zips={supportedZips.join(',')}
          data-invalid-zip-message={serviceAreaLookupCopy.invalidZipMessage}
          data-in-area-message={serviceAreaLookupCopy.inAreaMessage}
          data-out-of-area-message={serviceAreaLookupCopy.outOfAreaMessage}
        >
          <div class="grain area-card-grain"></div>
          <div class="area-card-inner">
            <div class="area-card-title">Check Your ZIP Code</div>
            <div class="area-card-sub">See if we cover your area</div>
            <form class="zip-row" data-zip-form novalidate>
              <input
                class="zip-input"
                type="text"
                name="zip"
                inputmode="numeric"
                autocomplete="postal-code"
                pattern="[0-9]{5}"
                placeholder="e.g. 34219"
                maxlength="5"
                aria-describedby="desktop-zip-message"
                data-zip-input
              />
              <button type="submit" class="zip-btn" data-zip-submit><span>Check →</span></button>
            </form>
            <p class="zip-message" id="desktop-zip-message" data-zip-message role="status" aria-live="polite" hidden></p>
            <div class="area-hr"></div>
            <div class="area-contacts">
              <a class="area-contact" href={`tel:${client.primaryPhoneHref}`}><div class="ac-ico" set:html={icon('phone')}></div><div class="ac-body"><strong>Call Us</strong><span>{client.primaryPhoneDisplay}</span></div><div class="ac-arr">→</div></a>
              <a class="area-contact" href={`sms:${client.primaryPhoneHref.replace('tel:', '')}`}><div class="ac-ico" set:html={icon('chat')}></div><div class="ac-body"><strong>Text Us</strong><span>{client.primaryPhoneDisplay}</span></div><div class="ac-arr">→</div></a>
              <a class="area-contact" href={`mailto:${client.email}`}><div class="ac-ico" set:html={icon('mail')}></div><div class="ac-body"><strong>Email Us</strong><span>{client.email}</span></div><div class="ac-arr">→</div></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-stmt">
      <div class="footer-stmt-txt">Show up. Do the work. <span>Leave it right.</span></div>
    </div>
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">PARRISH <span>TREE</span></div>
        <div class="footer-brand-tag">Removal · Trimming · Grinding · Storm</div>
        <p class="footer-brand-desc">Local tree service done right. Serving {client.primaryLocation}, FL and Manatee County since {estYear}. Licensed, insured, and built on showing up when we say we will.</p>
        <a class="footer-brand-tel" href={`tel:${client.primaryPhoneHref}`}>{client.primaryPhoneDisplay}</a>
      </div>
      {footerColumns.map((column) => (
        <div>
          <div class="footer-col-head">{column.head}</div>
          <div class="footer-links">
            {column.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="footer-meta">
      <div class="footer-copy">© {currentYear} Parrish Tree Removal. All rights reserved.<span>Licensed & Insured · Manatee County, FL</span></div>
      <button type="button" class="footer-back" data-back-to-top>↑ Back to top</button>
    </div>
