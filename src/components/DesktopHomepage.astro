    .cta-right{position:relative;z-index:1;min-width:0;max-width:560px;width:100%;padding:0 0 0 16px;}
    .cta-btn{display:flex;align-items:center;justify-content:space-between;background:var(--gold-grad);color:#fff;font-size:14px;font-weight:800;padding:18px 24px;border-radius:14px;position:relative;overflow:hidden;letter-spacing:-.01em;box-shadow:0 14px 36px rgba(180,110,40,.44),inset 0 1px 0 rgba(255,255,255,.18);}
    .cta-btn-ico{width:30px;height:30px;border-radius:9px;background:rgba(255,255,255,.18);display:grid;place-items:center;flex-shrink:0;position:relative;z-index:1;font-size:14px;}
    .cta-btn-txt{position:relative;z-index:1;}
    .cta-right :global(.estimate-form-shell){width:100%;gap:0;}
    .cta-right :global(.form-card){
      padding:28px;
      border:1px solid rgba(255,255,255,.12);
      border-radius:22px;
      background:linear-gradient(180deg,rgba(255,255,255,.06) 0%,rgba(255,255,255,.03) 100%);
      box-shadow:0 16px 28px rgba(0,0,0,.14);
      transition:transform 220ms ease,box-shadow 220ms ease,border-color 220ms ease;
    }
    .cta-right:hover :global(.form-card){transform:translateY(-2px);box-shadow:0 20px 34px rgba(0,0,0,.18);border-color:rgba(200,150,90,.22);}
    .cta-right :global(.estimate-form){display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px 14px;align-items:start;}
    .cta-right :global(.form-field){gap:6px;}
    .cta-right :global(.form-grid label){color:rgba(255,255,255,.9);font-size:12px;letter-spacing:.01em;}
    .cta-right :global(.form-grid input),
    .cta-right :global(.form-grid textarea),
    .cta-right :global(.form-grid select){
      min-height:46px;
      border:1px solid rgba(255,255,255,.16);
      border-radius:12px;
      background:rgba(0,0,0,.14);
      color:#fff;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
      padding:0.78rem 0.9rem;
      font-size:14px;
      transition:border-color 200ms ease,background-color 200ms ease;
    }
    .cta-right :global(.form-grid input::placeholder),
    .cta-right :global(.form-grid textarea::placeholder){color:rgba(255,255,255,.42);}
    .cta-right :global(.form-grid textarea){min-height:104px;}
    .cta-right :global(.form-grid select){appearance:none;}
    .cta-right :global(.form-grid input:focus),
    .cta-right :global(.form-grid textarea:focus),
    .cta-right :global(.form-grid select:focus){border-color:rgba(200,150,90,.34);background:rgba(0,0,0,.2);outline:none;}
    .cta-right :global(.form-field:nth-of-type(6)),
    .cta-right :global(.btn-primary),
    .cta-right :global(.form-status){grid-column:1 / -1;}
    .cta-right :global(.btn-primary){width:100%;min-height:50px;border-radius:12px;font-size:13px;padding:0.85rem 1rem;margin-top:2px;}
    .cta-right :global(.form-status){min-height:18px;color:rgba(255,255,255,.8);}
    .cta-phone-row{margin-top:12px;}
    .cta-phone-row span{font-size:12px;color:rgba(255,255,255,.58);}
    .cta-phone-row strong{font-size:12px;color:rgba(255,255,255,.84);}

    .faq{background:var(--green);padding:0;position:relative;overflow:hidden;border-top:1px solid rgba(255,255,255,.08);}
    .faq-grain{position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.04;}
    .faq-orb{position:absolute;top:-80px;right:-80px;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.045) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .faq-inner{position:relative;z-index:1;padding:var(--section-space) 64px 96px;display:grid;grid-template-columns:minmax(0,36%) minmax(0,64%);gap:48px;align-items:start;}
    .faq-left{height:fit-content;padding-top:34px;padding-right:28px;opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1);}
    .faq-eye{color:rgba(200,150,90,.72);margin-bottom:12px;}
    .faq-h2{font-size:clamp(60px,5vw,82px);color:#fff;margin-bottom:20px;}
    .faq-intro{font-size:16px;color:var(--text-soft-dark);line-height:1.84;margin-bottom:30px;max-width:410px;}
    .faq-direct{display:inline-flex;align-items:center;gap:9px;background:rgba(200,150,90,.1);border:1px solid rgba(200,150,90,.2);color:var(--gold);font-size:12px;font-weight:800;padding:12px 22px;border-radius:10px;text-decoration:none;transition:transform 200ms ease,border-color 200ms ease;}
    .faq-direct:hover{transform:translateY(-2px);border-color:rgba(200,150,90,.32);}
    .faq-side-note{margin-top:22px;max-width:320px;font-size:13px;line-height:1.74;color:rgba(255,255,255,.66);}
    .faq-list{display:flex;flex-direction:column;max-width:860px;padding:10px 22px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);box-shadow:0 18px 30px rgba(0,0,0,.12);border-radius:24px;opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1);}
    .faq-item{padding:0;background:transparent;box-shadow:none;border-radius:0;border-top:1px solid rgba(255,255,255,.1);transition:background-color 220ms ease,border-color 220ms ease,transform 220ms ease;}
    .faq-item:first-child{border-top:none;}
    .faq-item:last-child{border-bottom:none;}
    .faq-item.open,.faq-item.open + .faq-item{border-top-color:rgba(200,150,90,.2);}
    .faq-item:hover{background:rgba(255,255,255,.02);}
    .faq-q-row{display:flex;align-items:flex-start;justify-content:space-between;gap:26px;padding:28px 6px;background:none;border:0;width:100%;cursor:pointer;text-align:left;transition:padding-left 220ms ease;}
    .faq-item:hover .faq-q-row{padding-left:10px;}
    .faq-q{font-family:'Barlow Condensed',sans-serif;font-size:clamp(28px,2.1vw,34px);font-weight:800;font-style:normal;text-transform:uppercase;line-height:.9;letter-spacing:-.01em;color:rgba(255,255,255,.9);flex:1;transition:color 250ms ease;}
    .faq-item.open .faq-q{color:#fff;}
    .faq-tog{width:32px;height:32px;border-radius:50%;border:1.5px solid rgba(255,255,255,.16);background:rgba(255,255,255,.04);display:grid;place-items:center;flex-shrink:0;margin-top:2px;transition:transform 350ms cubic-bezier(.22,1,.36,1),border-color 250ms ease,background 250ms ease;position:relative;}
