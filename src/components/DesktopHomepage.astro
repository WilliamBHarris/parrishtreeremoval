    .hero-inner{position:relative;z-index:6;flex:1;width:min(calc(100% - 64px),1680px);margin:0 auto;padding:clamp(110px,11vh,148px) 0 clamp(128px,13vh,168px) clamp(56px,5.6vw,80px);display:flex;align-items:center;overflow:visible;min-height:calc(90vh - 72px);}
