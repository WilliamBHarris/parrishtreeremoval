    .town.lg{font-size:clamp(28px,2.6vw,38px);color:rgba(1,42,20,.5);}
    .town.md{font-size:clamp(20px,1.9vw,26px);color:rgba(1,42,20,.3);}
    .town.sm{font-size:clamp(15px,1.4vw,20px);color:rgba(1,42,20,.2);}
    .town-sep{font-family:'Barlow Condensed',sans-serif;font-weight:400;color:rgba(1,42,20,.15);padding:0 12px;align-self:center;}
    .town-sep.lg{font-size:28px;}
    .town-sep.sm{font-size:20px;padding:0 8px;}
    .area-card{background:var(--green);border-radius:24px;padding:30px;position:relative;overflow:hidden;box-shadow:0 18px 30px rgba(1,42,20,.12);margin-top:6px;transition:transform 220ms ease,box-shadow 220ms ease;}
    .area-card:hover{transform:translateY(-2px);box-shadow:0 24px 36px rgba(1,42,20,.14);}
    .area-card::before{content:'';position:absolute;top:0;left:10%;right:10%;height:1px;background:linear-gradient(90deg,transparent,rgba(200,150,90,.4),transparent);}
    .area-card-grain{position:absolute;inset:0;pointer-events:none;opacity:.04;border-radius:26px;}
    .area-card-inner{position:relative;z-index:1;}
    .area-card-title{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:800;text-transform:uppercase;color:#fff;letter-spacing:-.01em;margin-bottom:5px;}
    .area-card-sub{font-size:13px;color:var(--text-soft-dark);margin-bottom:18px;}
    .zip-row{display:flex;gap:10px;margin-bottom:24px;}
    .zip-input{flex:1;padding:14px 16px;border:1.5px solid rgba(255,255,255,.1);border-radius:11px;font-size:14px;color:#fff;background:rgba(255,255,255,.06);font-family:'Inter',sans-serif;outline:none;transition:border-color 200ms ease;}
    .zip-input::placeholder{color:rgba(255,255,255,.46);}
    .zip-input:focus{border-color:rgba(200,150,90,.4);}
    .zip-btn{background:var(--gold-grad);color:#fff;font-size:12.5px;font-weight:800;padding:14px 22px;border-radius:11px;white-space:nowrap;box-shadow:0 7px 18px rgba(180,110,40,.32),inset 0 1px 0 rgba(255,255,255,.18);position:relative;overflow:hidden;}
    .area-hr{height:1px;background:rgba(255,255,255,.12);margin-bottom:22px;}
    .area-contacts{display:flex;flex-direction:column;gap:2px;}
    .area-contact{display:flex;align-items:center;gap:13px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.08);cursor:pointer;transition:opacity 200ms ease;text-decoration:none;}
    .area-contact:last-child{border-bottom:none;}
    .area-contact:hover{opacity:.8;}
    .ac-ico{width:38px;height:38px;min-width:38px;border-radius:11px;background:rgba(200,150,90,.1);border:1px solid rgba(200,150,90,.18);display:grid;place-items:center;flex-shrink:0;color:#c8965a;font-size:16px;}
    .ac-text{flex:1;}
    .ac-text strong{display:block;font-size:13.5px;font-weight:800;color:#fff;margin-bottom:2px;letter-spacing:-.01em;}
    .ac-text span{font-size:12px;color:var(--text-mute-dark);}
    .ac-arr{font-size:14px;color:rgba(200,150,90,.4);}

    .footer{background:#011a0d;}
    .footer-stmt{max-width:1320px;margin:0 auto;padding:58px 64px 40px;border-bottom:1px solid rgba(255,255,255,.06);position:relative;overflow:hidden;}
    .footer-stmt::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 10% 0%,rgba(200,150,90,.08) 0%,transparent 60%);}
    .footer-stmt::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,rgba(200,150,90,.45),rgba(200,150,90,.1) 35%,transparent 65%);}
    .footer-stmt-text{position:relative;z-index:1;font-family:'Barlow Condensed',sans-serif;font-size:clamp(52px,4.4vw,72px);font-weight:800;text-transform:uppercase;line-height:.84;letter-spacing:-.02em;color:#fff;max-width:760px;opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1);}
    .footer-stmt-text span{color:rgba(200,150,90,.96);}
    .footer-grid{max-width:1400px;margin:0 auto;padding:50px 64px 40px;display:grid;grid-template-columns:2.6fr .9fr .9fr .9fr 1.05fr;gap:42px;border-bottom:1px solid rgba(255,255,255,.05);opacity:0;transform:translateY(12px);transition:opacity .5s cubic-bezier(.22,1,.36,1),transform .5s cubic-bezier(.22,1,.36,1);}
    .footer-brand-name{font-family:'Barlow Condensed',sans-serif;font-size:26px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#fff;line-height:1;margin-bottom:6px;}
    .footer-brand-name em{color:var(--gold);font-style:normal;}
    .footer-tag-line{font-size:9px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.46);margin-bottom:14px;}
    .footer-desc{font-size:13.5px;color:rgba(255,255,255,.78);line-height:1.76;max-width:310px;margin-bottom:18px;}
    .footer-brand-tel{display:inline-flex;align-items:center;gap:7px;background:rgba(200,150,90,.08);border:1px solid rgba(200,150,90,.18);border-radius:999px;padding:8px 16px;color:var(--gold);font-size:11px;font-weight:800;text-decoration:none;margin-top:4px;}
    .footer-col-head{font-size:8px;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:16px;}
    .footer-col-links{display:flex;flex-direction:column;gap:10px;}
    .footer-col-links a{font-size:13.5px;color:rgba(255,255,255,.74);text-decoration:none;transition:color 200ms ease,text-decoration-color 200ms ease;text-decoration:underline;text-decoration-color:transparent;text-underline-offset:3px;}
    .footer-col-links a:hover{color:rgba(255,255,255,.88);text-decoration-color:rgba(200,150,90,.55);}
    .footer-meta{max-width:1400px;margin:0 auto;padding:18px 64px 24px;display:flex;align-items:center;justify-content:space-between;}
    .footer-copy{font-size:11px;color:rgba(255,255,255,.58);}
    .footer-copy span{display:block;color:rgba(255,255,255,.6);margin-top:2px;}
    .footer-top{font-size:10px;color:rgba(255,255,255,.56);border:1px solid rgba(255,255,255,.12);padding:6px 14px;border-radius:999px;cursor:pointer;transition:color 200ms ease,border-color 200ms ease;background:transparent;}
    .footer-top:hover{color:rgba(255,255,255,.72);border-color:rgba(255,255,255,.18);}

    @media (prefers-reduced-motion: reduce) {
      .why-summary,
      .why-card,
      .why-proof-item,
      .proc-step,
      .faq-left,
      .faq-list,
      .area-left,
      .area-right,
      .footer-stmt-text,
      .footer-grid {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      .why-card:hover,
      .cta-right:hover :global(.form-card),
      .area-card:hover,
      .faq-item:hover .faq-q-row,
      .faq-direct:hover {
        transform: none !important;
      }
    }
  }
</style>

<script is:inline>
  (function () {
    var desktopQuery = window.matchMedia('(min-width: 900px)');
    if (!desktopQuery.matches) return;

    var root = document.querySelector('[data-desktop-homepage]');
    if (!root) return;

    var hdr = root.querySelector('#hdr');
    var faqItems = Array.prototype.slice.call(root.querySelectorAll('[data-faq-item]'));
    if (hdr) {
      window.addEventListener('scroll', function () {
        hdr.classList.toggle('scrolled', window.scrollY > 60);
      }, { passive: true });
    }

    var servicesGroup = root.querySelector('.hdr-nav-group');
    var servicesToggle = root.querySelector('[data-hdr-services-toggle]');
    if (servicesGroup && servicesToggle) {
      servicesToggle.addEventListener('click', function (event) {
        event.stopPropagation();
        var willOpen = !servicesGroup.classList.contains('open');
        servicesGroup.classList.toggle('open', willOpen);
        servicesToggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      });

      window.addEventListener('click', function (event) {
        if (!servicesGroup.contains(event.target)) {
          servicesGroup.classList.remove('open');
          servicesToggle.setAttribute('aria-expanded', 'false');
        }
      });
    }

    var colors = ['#c8965a', 'rgba(130,210,70,1)', 'rgba(210,145,55,1)', 'rgba(110,170,255,1)'];
    var cardClasses = ['c1', 'c2', 'c3', 'c4'];
    var rows = Array.prototype.slice.call(root.querySelectorAll('[data-svc-row]'));
    var visPanels = Array.prototype.slice.call(root.querySelectorAll('.card-visual-panel'));
    var iconPanels = Array.prototype.slice.call(root.querySelectorAll('.card-icon-panel'));
    var ccPanels = Array.prototype.slice.call(root.querySelectorAll('.card-content-panel'));
    var pills = Array.prototype.slice.call(root.querySelectorAll('.svc-pill'));
    var svcList = root.querySelector('#svcList');
    var card = root.querySelector('#theCard');
    var svg = root.querySelector('#connSvg');
    var body = root.querySelector('#svcBody');
    var current = -1;
    var animTimer = null;
    var autoTimer = null;
    var autoDelay = 5000;

    var drawConnector = function (idx) {
      if (!svg || !body || !card) return;
      while (svg.children.length > 1) svg.removeChild(svg.lastChild);
      if (animTimer) {
        clearTimeout(animTimer);
        animTimer = null;
      }

      var rowEl = rows[idx];
      if (!rowEl) return;
      var bodyRect = body.getBoundingClientRect();
      var nameEl = rowEl.querySelector('.svc-row-name');
      var anchorEl = rowEl.querySelector('.svc-row-anchor');
      var nameRect = nameEl ? nameEl.getBoundingClientRect() : rowEl.getBoundingClientRect();
      var anchorRect = anchorEl ? anchorEl.getBoundingClientRect() : nameRect;
      var cardRect = card.getBoundingClientRect();

      var sx = anchorRect.left - bodyRect.left;
      var sy = anchorRect.top + (anchorRect.height * 0.5) - bodyRect.top;
      var tx = cardRect.left - bodyRect.left;
      var ty = cardRect.top + cardRect.height * 0.45 - bodyRect.top;
      var col = colors[idx];

      var cpx1 = sx + (tx - sx) * 0.45;
      var cpy1 = sy;
      var cpx2 = tx - 40;
      var cpy2 = ty;
      var d = 'M ' + sx + ' ' + sy + ' C ' + cpx1 + ' ' + cpy1 + ', ' + cpx2 + ' ' + cpy2 + ', ' + tx + ' ' + ty;

      var tmpPath = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      tmpPath.setAttribute('d', d);
      svg.appendChild(tmpPath);
      var len = tmpPath.getTotalLength();
      svg.removeChild(tmpPath);

      var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', d);
      path.setAttribute('fill', 'none');
      path.setAttribute('stroke', col);
      path.setAttribute('stroke-width', '1.5');
      path.setAttribute('stroke-linecap', 'round');
      path.style.strokeDasharray = String(len);
      path.style.strokeDashoffset = String(len);
      path.style.filter = idx === 0 ? 'url(#glow-gold)' : idx === 1 ? 'url(#glow-lime)' : idx === 2 ? 'url(#glow-amber)' : 'url(#glow-blue)';
      path.style.transition = 'stroke-dashoffset 500ms cubic-bezier(.22,1,.36,1)';
      svg.appendChild(path);

      var dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('r', '4');
      dot.setAttribute('fill', col);
      dot.style.filter = path.style.filter;
      svg.appendChild(dot);

      requestAnimationFrame(function () {
        path.style.strokeDashoffset = '0';
      });

      var tmpPath2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      tmpPath2.setAttribute('d', d);
      tmpPath2.style.visibility = 'hidden';
      svg.appendChild(tmpPath2);

      var start = null;
      var dur = 520;
      var animDot = function (ts) {
        if (!start) start = ts;
        var progress = Math.min((ts - start) / dur, 1);
        var eased = 1 - Math.pow(1 - progress, 3);
        var pt = tmpPath2.getPointAtLength(eased * len);
        dot.setAttribute('cx', String(pt.x));
        dot.setAttribute('cy', String(pt.y));
        dot.style.opacity = progress < 0.05 ? String(progress / 0.05) : progress > 0.85 ? String(1 - (progress - 0.85) / 0.15) : '1';
        if (progress < 1) requestAnimationFrame(animDot);
      };
      requestAnimationFrame(animDot);

      animTimer = setTimeout(function () {
        var cr = card.getBoundingClientRect();
        var br = body.getBoundingClientRect();
        var cx = cr.left - br.left;
        var cy = cr.top - br.top;
        var cw = cr.width;
        var ch = cr.height;
        var r = 26;
        var entryY = Math.max(cy + r, Math.min(ty, cy + ch - r));
        var borderPath = 'M ' + cx + ' ' + entryY +
          ' L ' + cx + ' ' + (cy + r) +
          ' Q ' + cx + ' ' + cy + ' ' + (cx + r) + ' ' + cy +
          ' L ' + (cx + cw - r) + ' ' + cy +
          ' Q ' + (cx + cw) + ' ' + cy + ' ' + (cx + cw) + ' ' + (cy + r) +
          ' L ' + (cx + cw) + ' ' + (cy + ch - r) +
          ' Q ' + (cx + cw) + ' ' + (cy + ch) + ' ' + (cx + cw - r) + ' ' + (cy + ch) +
          ' L ' + (cx + r) + ' ' + (cy + ch) +
          ' Q ' + cx + ' ' + (cy + ch) + ' ' + cx + ' ' + (cy + ch - r) +
          ' L ' + cx + ' ' + entryY;

        var borderEl = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        borderEl.setAttribute('d', borderPath);
        borderEl.setAttribute('fill', 'none');
        borderEl.setAttribute('stroke', col);
        borderEl.setAttribute('stroke-width', '1.5');
        borderEl.setAttribute('stroke-linecap', 'round');
        borderEl.style.filter = path.style.filter;

        var t = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        t.setAttribute('d', borderPath);
        svg.appendChild(t);
        var totalLen = t.getTotalLength();
        svg.removeChild(t);

        borderEl.style.strokeDasharray = String(totalLen);
        borderEl.style.strokeDashoffset = String(totalLen);
        borderEl.style.transition = 'stroke-dashoffset 700ms cubic-bezier(.22,1,.36,1)';
        svg.appendChild(borderEl);

        requestAnimationFrame(function () {
          borderEl.style.strokeDashoffset = '0';
        });
        animTimer = null;
      }, 480);
    };

    var activateService = function (idx) {
      if (idx === current) return;
      current = idx;

      rows.forEach(function (row, rowIndex) {
        row.classList.toggle('active', rowIndex === idx);
      });
      if (svcList) svcList.classList.add('has-active');

      if (card) {
        card.className = 'dsvc-card';
        cardClasses[idx].split(' ').forEach(function (cls) {
          if (cls) card.classList.add(cls);
        });
      }

      visPanels.forEach(function (panel, panelIndex) {
        panel.classList.toggle('active', panelIndex === idx);
      });

      iconPanels.forEach(function (panel, panelIndex) {
        panel.classList.toggle('active', panelIndex === idx);
      });

      ccPanels.forEach(function (panel, panelIndex) {
        panel.classList.toggle('active', panelIndex === idx);
      });

      pills.forEach(function (pill, pillIndex) {
        pill.classList.toggle('on', pillIndex === idx);
        pill.style.setProperty('--pill-color', colors[pillIndex]);
      });

      drawConnector(idx);
    };

    var restartAutoplay = function () {
      if (autoTimer) {
        clearTimeout(autoTimer);
      }
      autoTimer = window.setTimeout(function () {
        activateService((current + 1) % rows.length);
        restartAutoplay();
      }, autoDelay);
    };

    rows.forEach(function (row, index) {
      var name = row.querySelector('.svc-row-name');
      var hoverTarget = name || row;
      hoverTarget.addEventListener('click', function () {
        activateService(index);
        restartAutoplay();
      });
    });

    setTimeout(function () {
      activateService(0);
      restartAutoplay();
    }, 400);

    root.querySelectorAll('[data-faq-toggle]').forEach(function (toggle) {
      toggle.addEventListener('click', function () {
        var item = toggle.closest('[data-faq-item]');
        var wasOpen = item && item.classList.contains('open');
        faqItems.forEach(function (faq) {
          faq.classList.remove('open');
        });
        if (item && !wasOpen) {
          item.classList.add('open');
        }
      });
    });

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    root.querySelectorAll('[data-animate-in]').forEach(function (el) {
      io.observe(el);
    });

    var scrollTopButton = root.querySelector('[data-scroll-top]');
    if (scrollTopButton) {
      scrollTopButton.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    var statNumbers = Array.prototype.slice.call(root.querySelectorAll('[data-countup]'));
    var heroStats = root.querySelector('.hero-stats');
    if (heroStats && statNumbers.length) {
      var statsAnimated = false;
      var runCountup = function () {
        if (statsAnimated) return;
        statsAnimated = true;

        statNumbers.forEach(function (el, index) {
          var target = Number(el.getAttribute('data-count-target') || '0');
          var duration = 1200 + (index * 140);
          var startTime = null;

          var tickCount = function (ts) {
            if (!startTime) startTime = ts;
            var progress = Math.min((ts - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(target * eased));
            if (progress < 1) {
              window.requestAnimationFrame(tickCount);
            }
          };

          window.requestAnimationFrame(tickCount);
        });
      };

      var statsObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            runCountup();
            statsObs.disconnect();
          }
        });
      }, { threshold: 0.45 });

      statsObs.observe(heroStats);
    }
  })();
</script>
