    .area-h2{color:var(--green);margin-bottom:12px;}
    .area-intro{font-size:16px;color:var(--text-soft-light);line-height:1.82;max-width:480px;margin-bottom:16px;}
    .area-note{font-size:14px;color:var(--text-mute-light);line-height:1.76;max-width:440px;margin-bottom:30px;}
