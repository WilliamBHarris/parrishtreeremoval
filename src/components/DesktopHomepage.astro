    .faq{background:var(--green);padding:0;position:relative;overflow:hidden;}
    .faq-grain{position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.04;}
    .faq-orb{position:absolute;top:-80px;right:-80px;width:480px;height:480px;border-radius:50%;background:radial-gradient(circle,rgba(200,150,90,.045) 0%,transparent 65%);pointer-events:none;z-index:0;}
    .faq-inner{position:relative;z-index:1;padding:120px 64px;display:grid;grid-template-columns:400px 1fr;gap:96px;}
    .faq-left{height:fit-content;}
    .faq-eye{color:rgba(200,150,90,.72);margin-bottom:12px;}
