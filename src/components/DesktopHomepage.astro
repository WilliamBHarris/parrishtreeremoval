---
import { client } from '../data/client';

const currentYear = new Date().getFullYear();
const estYear = client.yearsInBusiness ? currentYear - client.yearsInBusiness : 2014;
const jobsCompleted = client.jobsCompleted ?? 500;
const yearsInBusiness = client.yearsInBusiness ?? 10;
const googleRating = client.googleRating ?? 5;

const tickerItems = [
  'Licensed & Insured',
  'Free Estimates',
  'Same-Day Available',
  'Local & Trusted',
  'Storm Response',
  'Full Cleanup Included',
  `${client.primaryLocation} Based`,
];

const servicePanels = [
  {
    navNumber: '01',
    navName: 'Tree Removal',
    href: '/tree-removal',
    panelClass: 'sp1',
    navClass: 'sp1-nav',
    tag: 'Same-Day Available',
    watermark: `${jobsCompleted}+`,
    nameLines: ['Tree', 'Removal'],
    desc: 'Safe removal of any tree — any size, any access, any situation. Full cleanup included on every single job. Your yard left cleaner than we found it.',
    statValue: 'Full Cleanup',
    statLabel: 'Always included',
    cta: 'View Tree Removal →',
    iconStroke: '#c8965a',
    icon: 'removal',
  },
  {
    navNumber: '02',
    navName: 'Tree Trimming',
    href: '/tree-trimming',
    panelClass: 'sp2',
    navClass: 'sp2-nav',
    tag: 'Cleanup Included',
    watermark: '★ 5',
    nameLines: ['Tree', 'Trimming'],
    desc: 'Cleaner canopy, better clearance, healthier trees. Keeps your property looking sharp year-round while protecting your roof, fences, and power lines.',
    statValue: 'Year Round',
    statLabel: 'Seasonal & ongoing',
    cta: 'View Tree Trimming →',
    iconStroke: 'rgba(130,210,70,.9)',
    icon: 'trimming',
  },
  {
    navNumber: '03',
    navName: 'Stump Grinding',
    href: '/stump-grinding',
    panelClass: 'sp3',
    navClass: 'sp3-nav',
    tag: 'Ground Below Grade',
    watermark: '100%',
    nameLines: ['Stump', 'Grinding'],
    desc: 'Nothing left to trip on, mow around, or regrow. Ground below grade and the yard reclaimed. One visit, problem solved permanently.',
    statValue: '100% Gone',
    statLabel: 'Below grade, no regrowth',
    cta: 'View Stump Grinding →',
    iconStroke: 'rgba(210,145,55,.9)',
    icon: 'stump',
  },
  {
    navNumber: '04',
    navName: 'Storm Cleanup',
    href: '/emergency-tree-service',
    panelClass: 'sp4',
    navClass: 'sp4-nav',
    tag: 'Emergency Response',
    watermark: '24/7',
    nameLines: ['Storm', 'Cleanup'],
    desc: 'Fast response to any storm damage. Fallen limbs, blocked driveways, split trunks — we move quickly when you need it most. Same day when possible.',
    statValue: 'Same Day',
    statLabel: 'When possible',
    cta: 'View Storm Cleanup →',
    iconStroke: 'rgba(120,175,255,.88)',
    icon: 'storm',
  },
];

const whyRows = [
  {
    number: '01',
    statement: ['Licensed &', 'Fully Insured.'],
    accentIndex: 1,
    detail:
      "Every job covered. You're not liable for anything that happens on your property. We can show proof of insurance on request, and we've never had a claim in ten years.",
  },
  {
    number: '02',
    statement: ['Shows Up', 'On Time.'],
    accentIndex: 1,
    detail:
      'We set a window and we keep it. No all-day waits, no last-minute cancellations. Your time matters as much as ours, and we treat it that way.',
  },
  {
    number: '03',
    statement: ['Left Cleaner', 'Than We Found It.'],
    accentIndex: 1,
    detail:
      "Full debris removal on every single job. We rake, we clear, we check twice. The job isn't done until the site looks right — not good enough, actually right.",
  },
  {
    number: '04',
    statement: ['Straight Pricing.', 'No Surprises.'],
    accentIndex: 1,
    detail:
      'What we quote is what you pay. No add-ons discovered halfway through, no invoice shock at the end. The full cost is agreed before a single cut.',
  },
];

const processSteps = [
  {
    verb: 'Call.',
    title: 'You Call or Request',
    desc: "Reach out by phone or the estimate form. Tell us what you're dealing with.",
    icon: 'phone',
  },
  {
    verb: 'Snap.',
    title: 'Send a Photo',
    desc: 'A quick photo lets us assess remotely and give an accurate quote without a site visit.',
    icon: 'photo',
  },
  {
    verb: 'Quote.',
    title: 'We Send the Price',
    desc: "Flat, clear, complete. You know exactly what you'll pay before anyone shows up.",
    icon: 'quote',
  },
  {
    verb: 'Done.',
    title: 'We Handle Everything',
    desc: 'We show up, do the work, clean the site, and leave your yard better than we found it.',
    icon: 'check',
  },
];

const faqItems = [
  {
    question: 'Do you provide free estimates?',
    answer:
      "Yes — always. Send us a photo of the tree and we'll get you a flat price back fast, usually within a few hours. No site visit required for most jobs. No obligation if you decide not to move forward.",
  },
  {
    question: 'How quickly can you come out?',
    answer:
      'Most jobs are booked within 1–3 days. For storm damage or emergencies we aim to respond same day when possible. Call us directly for urgent requests.',
  },
  {
    question: 'Is cleanup included in the price?',
    answer:
      'Always. Every branch, log, and piece of debris is hauled away as part of the job. We rake, we clear, we check. You come outside and it looks like it never happened.',
  },
  {
    question: 'Are you licensed and insured?',
    answer:
      "Fully licensed and insured for every job. You're never liable for anything that happens on your property. We can provide proof of insurance on request.",
  },
  {
    question: 'What areas do you serve?',
    answer:
      `Based in ${client.primaryLocation}. We serve all of Manatee County including Ellenton, Palmetto, Bradenton, and surrounding communities. Call us if you're not sure — we'll tell you straight.`,
  },
];

const footerColumns = [
  {
    head: 'Services',
    links: [
      { label: 'Tree Removal', href: '/tree-removal' },
      { label: 'Tree Trimming', href: '/tree-trimming' },
      { label: 'Stump Grinding', href: '/stump-grinding' },
      { label: 'Storm Cleanup', href: '/emergency-tree-service' },
    ],
  },
  {
    head: 'Company',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Service Area', href: '#desktop-home-area' },
      { label: 'Services', href: '/services' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    head: 'Contact',
    links: [
      { label: client.primaryPhoneDisplay, href: `tel:${client.primaryPhoneHref}` },
      { label: client.email, href: `mailto:${client.email}` },
      { label: `${client.primaryLocation} ${client.state}`.trim(), href: '#desktop-home-area' },
    ],
  },
  {
    head: 'Coverage',
    links: [
      { label: 'Parrish, FL', href: '#desktop-home-area' },
      { label: 'Ellenton, FL', href: '#desktop-home-area' },
      { label: 'Palmetto, FL', href: '#desktop-home-area' },
      { label: 'Bradenton, FL', href: '#desktop-home-area' },
      { label: 'Sarasota, FL', href: '#desktop-home-area' },
    ],
  },
];

const renderIcon = (kind: string, stroke: string) => {
  switch (kind) {
    case 'removal':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-7"/><path d="M9 15c-3-1-5-4-4-7 2 0 4 1 5 3"/><path d="M15 15c3-1 5-4 4-7-2 0-4 1-5 3"/><path d="M8 22h8"/></svg>`;
    case 'trimming':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4L8.12 15.88"/><path d="M14.47 14.48L20 20"/><path d="M8.12 8.12L12 12"/></svg>`;
    case 'stump':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="2"/><path d="M12 5V3M12 21v-2M5 12H3M21 12h-2M7.05 7.05L5.64 5.64M18.36 18.36l-1.41-1.41"/></svg>`;
    case 'storm':
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="${stroke}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/><path d="M11 13l-2 3h4l-2 3"/></svg>`;
    case 'phone':
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011-.24c1.12.37 2.33.57 3.59.57a1 1 0 011 1V20a1 1 0 01-1 1C10.3 21 3 13.7 3 4.5a1 1 0 011-1H7.5a1 1 0 011 1c0 1.26.2 2.47.57 3.59a1 1 0 01-.45 1z"/></svg>`;
    case 'photo':
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
    case 'quote':
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg>`;
    default:
      return `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>`;
  }
};
---

<div class="desktop-homepage" data-desktop-homepage>
  <header class="hdr" id="hdr">
    <div class="hdr-inner">
      <a class="hdr-logo" href="/">
        <span>{client.businessName.split(' ')[0]} <em>{client.businessName.split(' ').slice(1, 2).join(' ') || 'TREE'}</em></span>
        <span class="hdr-logo-sub">Removal · Trimming · Grinding</span>
      </a>
      <nav class="hdr-nav">
        <a href="/" class="active">Home</a>
        <a href="/tree-removal">Tree Removal</a>
        <a href="/tree-trimming">Tree Trimming</a>
        <a href="/stump-grinding">Stump Grinding</a>
        <a href="/emergency-tree-service">Storm Cleanup</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="hdr-right">
        <div class="hdr-tel">or call: <strong>{client.primaryPhoneDisplay}</strong></div>
        <button type="button" class="hdr-cta" data-open-estimate-modal>Get a Free Estimate →</button>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-gl hero-gl1"></div>
    <div class="hero-gl hero-gl2"></div>
    <div class="hero-gl hero-gl3"></div>
    <div class="hero-sun"></div>
    <div class="hero-grain grain"></div>
    <div class="hero-orb-a"></div>
    <div class="hero-orb-b"></div>

    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-eye"><div class="hero-eye-dot"></div>{client.primaryLocation} · Est. {estYear}</div>
        <h1 class="hero-h1">
          <span class="w">Local Tree</span>
          <span class="w">Service</span>
          <span class="wg">Done Right.</span>
        </h1>
        <p class="hero-sub">When a tree becomes a problem, we make it disappear — clean site, clear communication, every time. Serving Manatee County since {estYear}.</p>
        <div class="hero-ctas">
          <button type="button" class="hero-btn" data-open-estimate-modal>Get a Free Estimate →</button>
          <a class="hero-call" href={`tel:${client.primaryPhoneHref}`}>or call: <strong>{client.primaryPhoneDisplay}</strong></a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="hstat-n"><span>{jobsCompleted}</span><span class="hstat-s">+</span></div>
            <div class="hstat-bar on"></div>
            <div class="hstat-l">Parrish Properties</div>
          </div>
          <div class="hero-stat">
            <div class="hstat-n"><span>{yearsInBusiness}</span><span class="hstat-s">yr</span></div>
            <div class="hstat-bar on"></div>
            <div class="hstat-l">In Business</div>
          </div>
          <div class="hero-stat">
            <div class="hstat-n"><span>{googleRating}</span><span class="hstat-s">★</span></div>
            <div class="hstat-bar on"></div>
            <div class="hstat-l">Google Rating</div>
          </div>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-deco">
          <span class="hero-deco-n">{jobsCompleted}+</span>
          <div class="hero-deco-label">Properties served in Parrish</div>
        </div>
        <div class="hero-trust">
          <div class="hero-trust-item"><div class="htrust-dot"></div><span class="htrust-text">Licensed & Fully Insured</span><div class="htrust-check">✓</div></div>
          <div class="hero-trust-item"><div class="htrust-dot"></div><span class="htrust-text">Same-Day Emergency Response</span><div class="htrust-check">✓</div></div>
          <div class="hero-trust-item"><div class="htrust-dot"></div><span class="htrust-text">Full Cleanup On Every Job</span><div class="htrust-check">✓</div></div>
          <div class="hero-trust-item"><div class="htrust-dot"></div><span class="htrust-text">Straight Pricing, No Surprises</span><div class="htrust-check">✓</div></div>
        </div>
      </div>
    </div>

  </section>

  <div class="ticker">
    <div class="ticker-track">
      <div class="ticker-group">
        {tickerItems.map((item) => (
          <div class="ti"><div class="ti-chk">✓</div>{item}<div class="ti-sep"></div></div>
        ))}
      </div>
      <div class="ticker-group" aria-hidden="true">
        {tickerItems.map((item) => (
          <div class="ti"><div class="ti-chk">✓</div>{item}<div class="ti-sep"></div></div>
        ))}
      </div>
    </div>
  </div>
  <div class="bridge">
    <svg viewBox="0 0 1280 36" preserveAspectRatio="none">
      <rect width="1280" height="36" fill="#012a14"></rect>
    </svg>
  </div>

  <section class="services" id="desktop-home-services">
    <div class="svc-bg-grain grain"></div>
    <div class="svc-bg-orb"></div>
    <div class="svc-layout">
      <div class="svc-sidebar">
        <div class="svc-sidebar-head">
          <div class="svc-eye"><div class="svc-eye-dot"></div>What We Do</div>
          <h2 class="svc-h2">Whatever<br/>The Tree.<br/><em>Whatever<br/>The Job.</em></h2>
        </div>
        <nav class="svc-nav" data-svc-nav>
          {servicePanels.map((panel, index) => (
            <button type="button" class:list={['svc-nav-item', panel.navClass, index === 0 && 'active']} data-panel-trigger={index}>
              <span class="svc-nav-n">{panel.navNumber}</span>
              <span class="svc-nav-name">{panel.navName}</span>
              <span class="svc-nav-arrow">→</span>
            </button>
          ))}
        </nav>
        <div class="svc-sidebar-foot">
          <p class="svc-sidebar-copy">One local crew handles all four. First call to final cleanup, done right the first time.</p>
          <a class="svc-sidebar-link" href="/services">View all services →</a>
        </div>
      </div>

      <div class="svc-panel-wrap">
        {servicePanels.map((panel, index) => (
          <div class:list={['svc-panel', panel.panelClass, index === 0 && 'active']} data-panel={index}>
            <div class="sp-grain grain"></div>
            <div class="sp-light"></div>
            <div class="sp-orb"></div>
            <div class="sp-edge"></div>
            <div class="sp-top">
              <div class="sp-tag"><div class="sp-tag-dot"></div>{panel.tag}</div>
              <div class="sp-ico" set:html={renderIcon(panel.icon, panel.iconStroke)}></div>
            </div>
            <div class="sp-mid">
              <div class="sp-wm">{panel.watermark}</div>
              <div class="sp-name">{panel.nameLines[0]}<br/>{panel.nameLines[1]}</div>
              <div class="sp-rule"></div>
              <p class="sp-desc">{panel.desc}</p>
            </div>
            <div class="sp-foot">
              <div>
                <div class="sp-stat-val">{panel.statValue}</div>
                <div class="sp-stat-lbl">{panel.statLabel}</div>
              </div>
              <a class="sp-cta" href={panel.href}>{panel.cta}</a>
            </div>
            {panel.icon === 'storm' && <div class="storm-dot"></div>}
          </div>
        ))}
      </div>
    </div>
    <div class="svc-clip">
      <svg viewBox="0 0 1280 36" preserveAspectRatio="none">
        <path d="M0 36 L1280 0 L1280 36 Z" fill="#f2efe6"></path>
      </svg>
    </div>
  </section>

  <section class="why">
    <div class="why-bg-orb"></div>
    <div class="why-inner">
      <div class="why-head">
        <div>
          <div class="why-eye"><div class="why-eye-dot"></div>Why Choose Us</div>
          <h2 class="why-h2">Built Around<br/><em>Your Property.</em></h2>
        </div>
        <p class="why-intro">Four reasons Parrish homeowners keep calling us back — and sending their neighbors.</p>
      </div>

      <div class="why-rows">
        {whyRows.map((row) => (
          <div class="why-row" data-animate-in>
            <div class="why-row-n">{row.number}</div>
            <div class="why-row-stmt">
              {row.statement.map((part, idx) => idx === row.accentIndex ? <em>{part}</em> : <span>{part}</span>)}
            </div>
            <p class="why-row-detail">{row.detail}</p>
          </div>
        ))}
      </div>

      <div class="why-cta-band">
        <div class="why-cta-band-grain grain"></div>
        <div class="why-cta-left">
          <div class="why-cta-label">Free Estimate · No Obligation</div>
          <div class="why-cta-stmt">Ready to Get<br/><em>Started?</em></div>
        </div>
        <div class="why-cta-right">
          <button type="button" class="why-cta-btn" data-open-estimate-modal>Request a Free Estimate →</button>
          <a class="why-cta-phone" href={`tel:${client.primaryPhoneHref}`}><span>or call us:</span><strong>{client.primaryPhoneDisplay}</strong></a>
        </div>
      </div>
    </div>
    <div class="why-clip">
      <svg viewBox="0 0 1280 36" preserveAspectRatio="none">
        <path d="M0 0 L1280 36 L0 36 Z" fill="#012a14"></path>
      </svg>
    </div>
  </section>

  <section class="process">
    <div class="proc-grain grain"></div>
    <div class="proc-orb"></div>
    <div class="proc-inner">
      <div class="proc-head">
        <div>
          <div class="proc-eye"><div class="proc-eye-dot"></div>How It Works</div>
          <h2 class="proc-h2">Simple Process.<br/><em>No Guesswork.</em></h2>
        </div>
        <p class="proc-sub">Four steps from first call to clean yard. Most jobs are completed same day or next.</p>
      </div>
      <div class="proc-steps">
        <div class="proc-line"><div class="proc-line-fill" data-proc-line></div></div>
        {processSteps.map((step) => (
          <div class="proc-step" data-animate-in>
            <div class="proc-circle"><div class="proc-circle-inner" set:html={renderIcon(step.icon, '#c8965a')}></div></div>
            <div class="proc-verb">{step.verb}</div>
            <div class="proc-title">{step.title}</div>
            <p class="proc-desc">{step.desc}</p>
          </div>
        ))}
      </div>
      <div class="proc-close-band">
        <div class="proc-close-text">First call to clean yard. <em>Usually same day.</em></div>
      </div>
    </div>
    <div class="proc-clip">
      <svg viewBox="0 0 1280 36" preserveAspectRatio="none">
        <path d="M0 36 L1280 0 L1280 36 Z" fill="#f2efe6"></path>
      </svg>
    </div>
  </section>

  <section class="cta">
    <div class="cta-card">
      <div class="cta-grain grain"></div>
      <div class="cta-deco-n">5★</div>
      <div class="cta-left">
        <div class="cta-eye">Free Estimate · No Obligation</div>
        <h2 class="cta-h2">Need Help With<br/><em>A Tree Project?</em></h2>
        <p class="cta-body">Tell us about the tree and we'll get back to you fast — usually within a few hours. Most jobs are quoted same day.</p>
      </div>
      <div class="cta-right">
        <button type="button" class="cta-btn" data-open-estimate-modal>
          <span class="cta-btn-txt">Request a Free Estimate</span>
          <div class="cta-btn-ico">→</div>
        </button>
        <a class="cta-phone-row" href={`tel:${client.primaryPhoneHref}`}><span>or call us directly:</span><strong>{client.primaryPhoneDisplay}</strong></a>
      </div>
    </div>
  </section>

  <section class="faq" id="desktop-home-faq">
    <div class="faq-clip-in">
      <svg viewBox="0 0 1280 36" preserveAspectRatio="none">
        <path d="M0 0 L1280 36 L0 36 Z" fill="#012a14"></path>
      </svg>
    </div>
    <div class="faq-grain grain"></div>
    <div class="faq-orb"></div>
    <div class="faq-inner">
      <div class="faq-left">
        <div class="faq-eye"><div class="faq-eye-dot"></div>FAQ</div>
        <h2 class="faq-h2">Got<br/><em>Questions?</em></h2>
        <p class="faq-intro">Everything Parrish homeowners ask before booking. Don't see yours? Just call.</p>
        <a class="faq-direct" href={`tel:${client.primaryPhoneHref}`}>Call Us Directly</a>
      </div>

      <div class="faq-list">
        {faqItems.map((item, index) => (
          <div class:list={['faq-item', index === 0 && 'open']} data-faq-item>
            <button type="button" class="faq-q-row" data-faq-toggle>
              <div class="faq-q">{item.question}</div>
              <div class="faq-tog"></div>
            </button>
            <div class="faq-ans-wrap"><div class="faq-ans-inner"><p class="faq-ans">{item.answer}</p></div></div>
          </div>
        ))}
      </div>
    </div>
    <div class="faq-clip">
      <svg viewBox="0 0 1280 36" preserveAspectRatio="none">
        <path d="M0 36 L1280 0 L1280 36 Z" fill="#f2efe6"></path>
      </svg>
    </div>
  </section>

  <section class="area" id="desktop-home-area">
    <div class="area-orb"></div>
    <div class="area-inner">
      <div class="area-left">
        <div class="area-eye"><div class="area-eye-dot"></div>Where We Work</div>
        <h2 class="area-h2">Serving Parrish<br/><em>& Beyond.</em></h2>
        <p class="area-intro">Based in {client.primaryLocation}. Covering Manatee County and surrounding communities since {estYear}.</p>
        <div class="area-map">
          <div class="town primary"><div class="town-pin"></div>Parrish</div>
