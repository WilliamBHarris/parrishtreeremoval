    }

    :global(body.homepage-desktop-redesign main#main-content) {
      padding-top: 0 !important;
      margin-top: 0 !important;
      background: var(--green) !important;
    }

    .desktop-homepage {
      display: block;
      font-family: 'Inter', sans-serif;
      background: var(--green);
      min-width: 0;
      overflow-x: hidden;
      margin-top: -1px;
      --section-space: clamp(78px, 8vw, 118px);
      --section-gap: clamp(30px, 3.2vw, 46px);
      --content-gap: clamp(18px, 2vw, 28px);
