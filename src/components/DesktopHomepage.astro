    .why-proof-detail{font-size:13px;color:var(--text-mute-light);line-height:1.7;margin:10px 0 0;max-width:240px;}
    .why-rows{margin-bottom:0;}
    .why-row{display:none;opacity:0;transform:translateY(20px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);}
    .why-row.in,.proc-step.in{opacity:1;transform:translateY(0);}
    .why-row-n{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:800;letter-spacing:.1em;color:rgba(1,42,20,.2);align-self:flex-start;padding-top:8px;}
    .why-row-stmt{font-family:'Barlow Condensed',sans-serif;font-size:clamp(36px,3.2vw,48px);font-weight:800;font-style:normal;text-transform:uppercase;line-height:.9;letter-spacing:-.02em;color:var(--green);display:flex;flex-direction:column;gap:2px;}
    .why-row-stmt em{color:var(--gold);font-style:normal;}
    .why-row-detail{font-size:13px;color:rgba(1,42,20,.5);line-height:1.7;padding-left:24px;border-left:2px solid rgba(200,150,90,.2);}
    .why-cta-band{background:var(--green);padding:64px 64px;display:flex;align-items:center;justify-content:space-between;gap:60px;position:relative;overflow:hidden;margin:48px auto 0;max-width:720px;}
