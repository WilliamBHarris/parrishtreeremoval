<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

  .desktop-homepage {
    display: none;
  }

  @media (max-width: 899px) {
    .desktop-homepage {
      display: none;
    }
  }

  @media (min-width: 900px) {
    :global(body.homepage-desktop-redesign .site-header-shell),
    :global(body.homepage-desktop-redesign .home-footer),
    :global(body.homepage-desktop-redesign .site-footer),
    :global(body.homepage-desktop-redesign .home-mobile-stack) {
      display: none !important;
    }

    :global(body.homepage-desktop-redesign) main {
      padding-top: 0 !important;
    }

    .desktop-homepage {
      display: block;
      font-family: 'Inter', sans-serif;
      background: #f2efe6;
      min-width: 1280px;
      overflow-x: hidden;
    }

    *, *::before, *::after { box-sizing: border-box; }
    :global(html) { scroll-behavior: smooth; }
    :root{
      --green:#012a14; --green-mid:#014820; --gold:#c8965a; --gold-grad:linear-gradient(180deg,#d4a060,#b07840); --beige:#f2efe6;
    }
    @keyframes g1{0%,100%{opacity:1}33%{opacity:.08}66%{opacity:.5}}
    @keyframes g2{0%,100%{opacity:.08}33%{opacity:1}66%{opacity:.18}}
