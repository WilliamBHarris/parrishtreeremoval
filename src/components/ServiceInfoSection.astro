---
import PageSection from './PageSection.astro';
import type { IncludedItem } from '../data/services';
import type { SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  section: string;
  title: string;
  items: Array<string | IncludedItem>;
  layout?: 'list' | 'cards' | 'stack' | 'grid';
  surfaceTone?: SectionTone;
}

const {
  pageId,
  section,
  title,
  items,
  layout = 'grid',
  surfaceTone = 'base',
} = Astro.props;

const desktopIntroBySection: Record<string, string> = {
  'when-you-need-this-service':
    'Use these common situations to decide whether this service fits the condition of the tree, the property, and the kind of tree work, cleanup, or scheduling support you need next before the issue gets larger or harder to manage.',
  'whats-included':
    'A clearer look at what the service usually covers, how the work is approached, and what homeowners can expect from the overall job scope, cleanup, property care, and next-step planning.',
};
---

<PageSection class="section-desktop-split" section={section} page={pageId} surfaceTone={surfaceTone}>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
    {desktopIntroBySection[section] && (
      <p class="section-lead section-desktop-lead clone-intro">
        {desktopIntroBySection[section]}
      </p>
    )}
  </div>
  {layout === 'list' ? (
    <div class="page-card when-needed-card" data-block="content">
      <ul class="list-copy">
        {items.map((item) => <li>{typeof item === 'string' ? item : item.description}</li>)}
      </ul>
    </div>
  ) : layout === 'stack' ? (
    <div class="page-card when-needed-card" data-block="content">
      <ul class="list-copy">
        {items.map((item) => (
          <li>
            {typeof item === 'string' ? (
              item
            ) : (
              <>
                <strong class="list-copy-item-title">{item.title}:</strong>
                <span class="list-copy-item-body">{item.description}</span>
              </>
            )}
          </li>
        ))}
      </ul>
    </div>
  ) : (
    <div class:list={['stack-grid', layout === 'grid' && 'stack-grid-two']} data-block="cards">
      {items.map((item) => (
        <article class="stack-panel">
          {typeof item === 'string' ? (
            <p>{item}</p>
          ) : (
            <>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </>
          )}
        </article>
      ))}
    </div>
  )}
</PageSection>
