---
import PageSection from './PageSection.astro';
import EstimateForm from './EstimateForm.astro';
import type { SectionTone } from '../data/client-questionnaire';

interface Props {
  pageId: string;
  sectionId?: string;
  title: string;
  heading: string;
  intro: string;
  buttonLabel: string;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  sectionId = 'estimate-form',
  title,
  heading,
  intro,
  buttonLabel,
  surfaceTone = 'base',
} = Astro.props;
---

<PageSection
  id={sectionId}
  class="section-desktop-split"
  section="estimate-form"
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
    <p class="section-lead section-desktop-lead clone-intro">
      Share a few job details and the next step stays simple.
    </p>
  </div>
  <div data-block="form">
    <EstimateForm
      heading={heading}
      intro={intro}
      buttonLabel={buttonLabel}
    />
  </div>
</PageSection>
