---
import PageSection from './PageSection.astro';
import { templateConfig } from '../data/client-questionnaire';
import type { RelatedServicesVariant, SectionTone } from '../data/client-questionnaire';

interface ServiceLink {
  href: string;
  label: string;
  description?: string;
}

interface Props {
  pageId: string;
  links: ServiceLink[];
  title?: string;
  ariaLabel?: string;
  variant?: RelatedServicesVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  links,
  title = 'Services',
  ariaLabel = 'Related service links',
  variant = templateConfig.presets.relatedServices,
  surfaceTone = 'base',
} = Astro.props;
---

<PageSection class="section-desktop-split" section="related-services" page={pageId} surfaceTone={surfaceTone}>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
    <p class="section-lead section-desktop-lead clone-intro">
      Explore the other core tree services available for Parrish properties so it is easier to pair related work, compare options, or move to the next service that best fits the job, the cleanup, or the property goals.
    </p>
  </div>
  <div
    class:list={['service-button-row', `related-services-variant-${variant}`]}
    role="navigation"
    aria-label={ariaLabel}
    data-block="links"
    data-related-services-variant={variant}
  >
    {links.map((service) => (
      <a href={service.href} class="subpage-service-button" aria-label={`Go to ${service.label}`}>
        <span class="subpage-service-button-copy">
          <span class="subpage-service-button-title">{service.label}</span>
          {service.description && <span class="subpage-service-button-description">{service.description}</span>}
        </span>
      </a>
    ))}
  </div>
</PageSection>
