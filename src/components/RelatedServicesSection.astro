---
import PageSection from './PageSection.astro';
import type { RelatedServicesVariant, SectionTone } from '../data/client-questionnaire';

interface ServiceLink {
  href: string;
  label: string;
}

interface Props {
  pageId: string;
  links: ServiceLink[];
  title?: string;
  ariaLabel?: string;
  variant?: RelatedServicesVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  links,
  title = 'Services',
  ariaLabel = 'Related service links',
  variant = 'stacked-buttons',
  surfaceTone = 'base',
} = Astro.props;
---

<PageSection class="section-desktop-split" section="related-services" page={pageId} surfaceTone={surfaceTone}>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
    <p class="section-lead section-desktop-lead clone-intro">
      Explore the other core services available for Parrish properties.
    </p>
  </div>
  <div
    class:list={['service-button-row', `related-services-variant-${variant}`]}
    role="navigation"
    aria-label={ariaLabel}
    data-block="links"
  >
    {links.map((service) => (
      <a href={service.href} class="subpage-service-button" aria-label={`Go to ${service.label}`}>
        {service.label}
      </a>
    ))}
  </div>
</PageSection>
