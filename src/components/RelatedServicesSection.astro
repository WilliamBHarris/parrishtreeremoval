---
import PageSection from './PageSection.astro';
import { templateConfig } from '../data/client-questionnaire';
import type { RelatedServicesVariant, SectionTone } from '../data/client-questionnaire';

interface ServiceLink {
  href: string;
  label: string;
  description?: string;
}

interface Props {
  pageId: string;
  links: ServiceLink[];
  title?: string;
  ariaLabel?: string;
  variant?: RelatedServicesVariant;
  surfaceTone?: SectionTone;
}

const {
  pageId,
  links,
  ariaLabel = 'Related service links',
  variant = templateConfig.presets.relatedServices,
  surfaceTone = 'base',
} = Astro.props;

const panelMeta: Record<
  string,
  {
    className: string;
    hook: string;
    icon: string;
    pulse?: boolean;
  }
> = {
  'tree trimming': {
    className: 'rel-trimming',
    hook: 'Cleaner canopy. Better clearance. Healthier trees.',
    icon: 'trimming',
  },
  'stump grinding': {
    className: 'rel-stump',
    hook: 'Gone below grade. Nothing left to mow around.',
    icon: 'stump',
  },
  'storm cleanup': {
    className: 'rel-storm',
    hook: 'Fast response. Any damage. Same-day when possible.',
    icon: 'storm',
    pulse: true,
  },
  'tree removal': {
    className: 'rel-removal',
    hook: 'Safe takedown. Clean site. Clear next step.',
    icon: 'removal',
  },
  services: {
    className: 'rel-services',
    hook: 'Compare services and choose the one that fits the job.',
    icon: 'services',
  },
  contact: {
    className: 'rel-contact',
    hook: 'Tell us what is going on and get the next clear step.',
    icon: 'contact',
  },
};

const getDisplayLabel = (label: string) =>
  label
    .replace(' in Parrish, FL', '')
    .replace('Parrish Tree Removal', '')
    .trim();

const getPanelData = (link: ServiceLink) => {
  const displayLabel = getDisplayLabel(link.label);
  const key = displayLabel.toLowerCase();
  const meta = panelMeta[key] ?? {
    className: 'rel-services',
    hook: link.description ?? 'See how this service connects to the rest of the project.',
    icon: 'services',
  };

  const words = displayLabel.split(/\s+/);
  const splitIndex = words.length > 1 ? words.length - 1 : words.length;
  const lineOne = words.slice(0, splitIndex).join(' ');
  const lineTwo = words.slice(splitIndex).join(' ');

  return {
    ...link,
    displayLabel,
    lineOne,
    lineTwo,
    hook: link.description ?? meta.hook,
    className: meta.className,
    icon: meta.icon,
    pulse: meta.pulse ?? false,
  };
};

const panelLinks = links.map(getPanelData);
---

<PageSection
  class="related-services-section"
  section="related-services"
  page={pageId}
  surfaceTone={surfaceTone}
>
  <div class="related" data-related-services-variant={variant}>
    <div class="rel-header">
      <div class="rel-eye"><div class="rel-eye-dot"></div>Also Available</div>
      <h2 class="rel-h2">We Handle<br /><em>More Than This.</em></h2>
    </div>

    <div class="rel-panels" role="navigation" aria-label={ariaLabel}>
      {panelLinks.map((service) => (
        <a href={service.href} class:list={['rel-panel', service.className]} aria-label={`Go to ${service.displayLabel}`}>
          <div class="rel-panel-burst" aria-hidden="true"></div>
          <div class="rel-panel-inner">
            <div class="rel-ico-wrap">
              {service.icon === 'trimming' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(130,210,75,0.9)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="6" cy="6" r="3"></circle>
                  <circle cx="6" cy="18" r="3"></circle>
                  <path d="M20 4L8.12 15.88"></path>
                  <path d="M14.47 14.48L20 20"></path>
                  <path d="M8.12 8.12L12 12"></path>
                </svg>
              )}
              {service.icon === 'stump' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(205,140,55,0.9)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="7"></circle>
                  <circle cx="12" cy="12" r="2"></circle>
                  <path d="M12 5V3M12 21v-2M5 12H3M21 12h-2 M7.05 7.05L5.64 5.64M18.36 18.36l-1.41-1.41"></path>
                </svg>
              )}
              {service.icon === 'storm' && (
                <>
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(110,165,255,0.88)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path>
                    <path d="M11 13l-2 3h4l-2 3"></path>
                  </svg>
                  {service.pulse && <div class="storm-pulse" aria-hidden="true"></div>}
                </>
              )}
              {service.icon === 'removal' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(215,170,95,0.92)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M7 3v18"></path>
                  <path d="M7 5c6 0 10 2.5 10 6s-4 6-10 6"></path>
                  <path d="M14 8l3 3-3 3"></path>
                </svg>
              )}
              {service.icon === 'services' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(1,42,20,0.78)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="4" y="4" width="7" height="7" rx="1.5"></rect>
                  <rect x="13" y="4" width="7" height="7" rx="1.5"></rect>
                  <rect x="4" y="13" width="7" height="7" rx="1.5"></rect>
                  <rect x="13" y="13" width="7" height="7" rx="1.5"></rect>
                </svg>
              )}
              {service.icon === 'contact' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(1,42,20,0.78)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10Z"></path>
                  <path d="M8 9h8"></path>
                  <path d="M8 13h5"></path>
                </svg>
              )}
            </div>
            <div class="rel-content">
              <div class="rel-name">
                {service.lineOne}
                {service.lineTwo && <><br />{service.lineTwo}</>}
              </div>
              <div class="rel-hook">{service.hook}</div>
            </div>
            <div class="rel-arrow" aria-hidden="true">→</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</PageSection>

<script is:inline>
  (() => {
    const panels = Array.from(document.querySelectorAll('.rel-panel'));
    if (!panels.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!(entry.target instanceof HTMLElement)) return;
          if (!entry.isIntersecting) return;
          entry.target.classList.add('in');
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.3 }
    );

    panels.forEach((panel) => observer.observe(panel));
  })();
</script>

<style>
  :global(.page-section.related-services-section[data-section="related-services"]) {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    margin-top: 0;
    padding: 0;
    background: #f2efe6;
    overflow-x: clip;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  :global(.page-section.related-services-section[data-section="related-services"])::before,
  :global(.page-section.related-services-section[data-section="related-services"])::after {
    content: none;
    background: none;
    box-shadow: none;
  }

  @keyframes dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.35;
      transform: scale(0.55);
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes stormPulse {
    0% {
      box-shadow: 0 0 0 0 rgba(74, 143, 217, 0.6);
    }

    70% {
      box-shadow: 0 0 0 5px rgba(74, 143, 217, 0);
    }

    100% {
      box-shadow: 0 0 0 0 rgba(74, 143, 217, 0);
    }
  }

  .related {
    background: #f2efe6;
    padding: 44px 0 48px;
    position: relative;
    overflow: hidden;
  }


  .rel-header {
    position: relative;
    z-index: 1;
    padding: 0 22px 28px;
  }

  .rel-eye {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: #6a4e2a;
    margin-bottom: 10px;
  }

  .rel-eye-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c8965a;
    flex-shrink: 0;
    animation: dot 2.2s ease-in-out infinite 0.4s;
  }

  .rel-h2 {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    color: #012a14;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .rel-h2 em {
    color: #c8965a;
    font-style: normal;
    display: block;
  }

  .rel-panels {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .rel-panel {
    position: relative;
    overflow: hidden;
    padding: 22px 22px 22px;
    border-top: 1px solid rgba(1, 42, 20, 0.07);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    opacity: 0;
    transform: translateX(-16px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      background 200ms ease;
    background: transparent;
    text-decoration: none;
  }

  .rel-panel:last-child {
    border-bottom: 1px solid rgba(1, 42, 20, 0.07);
  }

  .rel-panel.in {
    opacity: 1;
    transform: translateX(0);
  }

  .rel-panel:nth-child(1) {
    transition-delay: 0s;
  }

  .rel-panel:nth-child(2) {
    transition-delay: 0.07s;
  }

  .rel-panel:nth-child(3) {
    transition-delay: 0.14s;
  }

  .rel-panel:active {
    background: rgba(1, 42, 20, 0.04);
  }

  .rel-panel-burst {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 300ms ease;
  }

  .rel-panel:active .rel-panel-burst {
    opacity: 1;
  }

  .rel-panel-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .rel-ico-wrap {
    width: 52px;
    height: 52px;
    min-width: 52px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    transition: transform 250ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .rel-panel:active .rel-ico-wrap {
    transform: scale(0.95);
  }

  .rel-ico-wrap::before {
    content: '';
    position: absolute;
    inset: 0 0 55% 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), transparent);
    border-radius: 16px 16px 0 0;
    pointer-events: none;
  }

  .rel-content {
    flex: 1;
    min-width: 0;
  }

  .rel-name {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.01em;
    margin-bottom: 5px;
    transition: color 200ms ease;
  }

  .rel-hook {
    font-size: 11.5px;
    font-weight: 500;
    color: #373329;
    line-height: 1.45;
  }

  .rel-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 8px;
    flex-shrink: 0;
    font-size: 14px;
    font-weight: 700;
    transition: transform 250ms cubic-bezier(0.22, 1, 0.36, 1), background 200ms ease;
  }

  .rel-panel:active .rel-arrow {
    transform: translateX(4px);
  }

  .rel-trimming .rel-ico-wrap {
    background: linear-gradient(145deg, #172a07, #0c1904);
    border: 1px solid rgba(100, 175, 50, 0.15);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(130, 210, 75, 0.08);
  }

  .rel-trimming .rel-panel-burst {
    background: radial-gradient(ellipse 70% 50% at 0% 50%, rgba(100, 175, 50, 0.06) 0%, transparent 65%);
  }

  .rel-trimming .rel-name {
    color: #2d5016;
  }

  .rel-trimming .rel-arrow {
    background: rgba(100, 175, 50, 0.1);
    border: 1px solid rgba(100, 175, 50, 0.18);
    color: rgba(80, 160, 40, 0.8);
  }

  .rel-trimming:active .rel-arrow {
    background: rgba(100, 175, 50, 0.16);
  }

  .rel-stump .rel-ico-wrap {
    background: linear-gradient(145deg, #271804, #140c02);
    border: 1px solid rgba(185, 120, 38, 0.15);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(205, 140, 55, 0.08);
  }

  .rel-stump .rel-panel-burst {
    background: radial-gradient(ellipse 70% 50% at 0% 50%, rgba(185, 120, 38, 0.06) 0%, transparent 65%);
  }

  .rel-stump .rel-name {
    color: #7a3e10;
  }

  .rel-stump .rel-arrow {
    background: rgba(185, 120, 38, 0.1);
    border: 1px solid rgba(185, 120, 38, 0.18);
    color: rgba(180, 115, 35, 0.8);
  }

  .rel-stump:active .rel-arrow {
    background: rgba(185, 120, 38, 0.16);
  }

  .rel-storm .rel-ico-wrap {
    background: linear-gradient(145deg, #091628, #050d18);
    border: 1px solid rgba(75, 130, 220, 0.15);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(110, 165, 255, 0.08);
  }

  .rel-storm .rel-panel-burst {
    background: radial-gradient(ellipse 70% 50% at 0% 50%, rgba(75, 130, 220, 0.06) 0%, transparent 65%);
  }

  .rel-storm .rel-name {
    color: #1a3a6e;
  }

  .rel-storm .rel-arrow {
    background: rgba(75, 130, 220, 0.1);
    border: 1px solid rgba(75, 130, 220, 0.18);
    color: rgba(80, 135, 225, 0.8);
  }

  .rel-storm:active .rel-arrow {
    background: rgba(75, 130, 220, 0.16);
  }

  .rel-removal .rel-ico-wrap {
    background: linear-gradient(145deg, #2a1b08, #140d03);
    border: 1px solid rgba(200, 150, 90, 0.16);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(215, 170, 95, 0.08);
  }

  .rel-removal .rel-panel-burst {
    background: radial-gradient(ellipse 70% 50% at 0% 50%, rgba(200, 150, 90, 0.06) 0%, transparent 65%);
  }

  .rel-removal .rel-name {
    color: #5d421d;
  }

  .rel-removal .rel-arrow {
    background: rgba(200, 150, 90, 0.1);
    border: 1px solid rgba(200, 150, 90, 0.18);
    color: rgba(180, 130, 65, 0.85);
  }

  .rel-removal:active .rel-arrow {
    background: rgba(200, 150, 90, 0.16);
  }

  .rel-services .rel-ico-wrap,
  .rel-contact .rel-ico-wrap {
    background: linear-gradient(145deg, #ece6d7, #dfd8c8);
    border: 1px solid rgba(1, 42, 20, 0.08);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08), 0 0 0 1px rgba(1, 42, 20, 0.04);
  }

  .rel-services .rel-panel-burst,
  .rel-contact .rel-panel-burst {
    background: radial-gradient(ellipse 70% 50% at 0% 50%, rgba(1, 42, 20, 0.04) 0%, transparent 65%);
  }

  .rel-services .rel-name,
  .rel-contact .rel-name {
    color: #012a14;
  }

  .rel-services .rel-arrow,
  .rel-contact .rel-arrow {
    background: rgba(1, 42, 20, 0.06);
    border: 1px solid rgba(1, 42, 20, 0.1);
    color: rgba(1, 42, 20, 0.76);
  }

  .rel-services:active .rel-arrow,
  .rel-contact:active .rel-arrow {
    background: rgba(1, 42, 20, 0.1);
  }

  .storm-pulse {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #4a8fd9;
    border: 2px solid #f2efe6;
    animation: stormPulse 2s ease-in-out infinite;
  }
</style>
