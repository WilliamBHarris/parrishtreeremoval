---
import PageSection from './PageSection.astro';
import { templateConfig } from '../data/client-questionnaire';
import type { ProcessVariant, SectionTone } from '../data/client-questionnaire';

interface ProcessStep {
  title: string;
  description: string;
  paths: string[];
}

interface Props {
  steps?: ProcessStep[];
  pageId?: string;
  variant?: ProcessVariant;
  surfaceTone?: SectionTone;
}

const defaultSteps = [
  {
    paths: [
      'M8 6h8',
      'M8 10h8',
      'M8 14h5',
      'M7 3h10a2 2 0 0 1 2 2v14l-3-2-3 2-3-2-3 2V5a2 2 0 0 1 2-2Z',
    ],
    title: 'Reach Out',
    description: 'Tell us about the tree, the property, and the kind of work you need done.',
  },
  {
    paths: [
      'M4 7h4l2-3h4l2 3h4v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z',
      'M12 16a3.25 3.25 0 1 0 0-6.5 3.25 3.25 0 0 0 0 6.5Z',
    ],
    title: 'Share Photos Or Notes',
    description: 'Photos and a few quick notes help clarify access, size, and any urgency.',
  },
  {
    paths: [
      'M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10Z',
      'M8 9h8',
      'M8 13h5',
    ],
    title: 'Review The Job',
    description: 'We review the work involved and talk through the service options that fit the property.',
  },
  {
    paths: [
      'M7 3v3',
      'M17 3v3',
      'M4 8h16',
      'M5 5h14a1 1 0 0 1 1 1v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a1 1 0 0 1 1-1Z',
      'm9 14 2 2 4-4',
    ],
    title: 'Schedule The Work',
    description: 'Once the scope is clear, the job can move forward into quoting and scheduling.',
  },
];

const {
  steps = defaultSteps,
  pageId,
  variant = templateConfig.presets.process,
  surfaceTone = 'olive',
} = Astro.props;

const usePremiumProcessSection = Boolean(pageId) && !String(pageId).startsWith('preview');

const homeProcessSteps = [
  {
    verb: 'Call.',
    title: 'Reach Out',
    description: "We pick up. Tell us the tree and the situation — we'll ask the right questions so we show up prepared.",
    icon: 'phone',
  },
  {
    verb: 'Snap.',
    title: 'Share a Photo',
    description: "One photo on your phone. That's all we need to assess the job and give you a clear estimate.",
    icon: 'camera',
  },
  {
    verb: 'Quote.',
    title: 'Get Your Estimate',
    description: 'Straight pricing. No vague ranges, no surprise add-ons. You know what it costs before we arrive.',
    icon: 'quote',
  },
  {
    verb: 'Done.',
    title: 'We Handle It',
    description: "On time. Work done right. Yard left clean. You don't lift a finger from first call to finished job.",
    icon: 'check',
  },
];

const premiumProcessSteps = pageId === 'home'
  ? homeProcessSteps
  : steps.map((step, index) => ({
      verb:
        index === 0 ? 'Call.'
        : index === 1 ? 'Snap.'
        : index === 2 ? 'Quote.'
        : 'Done.',
      title: step.title,
      description: step.description,
      icon:
        index === 0 ? 'phone'
        : index === 1 ? 'camera'
        : index === 2 ? 'quote'
        : 'check',
    }));
---

{usePremiumProcessSection ? (
  <PageSection
    class="home-process-section"
    section="our-process"
    page={pageId}
    surfaceTone={surfaceTone}
  >
    <div class="home-process">
      <div class="home-process-head">
        <div class="home-process-eye">
          <span class="home-process-eye-dot"></span>
          <span>How It Works</span>
        </div>

        <h2 class="home-process-title">
          Simple Process.
          <em>No Guesswork.</em>
        </h2>

        <p class="home-process-intro">Four steps. No runaround, no surprises. Here's exactly what happens from your first call to a clean yard.</p>
      </div>

      <div class="home-process-timeline" id="home-process-timeline">
        {premiumProcessSteps.map((step, index) => (
          <article class="home-process-step" data-home-process-step={index + 1}>
            <div class="home-process-marker" aria-hidden="true">
              <span class="home-process-circle">
                {step.icon === 'phone' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.12.37 2.33.57 3.59.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1H7.5a1 1 0 0 1 1 1c0 1.26.2 2.47.57 3.59a1 1 0 0 1-.45 1z"></path>
                  </svg>
                )}
                {step.icon === 'camera' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                    <circle cx="12" cy="13" r="4"></circle>
                  </svg>
                )}
                {step.icon === 'quote' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 11l3 3L22 4"></path>
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                  </svg>
                )}
                {step.icon === 'check' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c8965a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                )}
              </span>
              {index < homeProcessSteps.length - 1 && (
                <span class="home-process-connector"><span class="home-process-connector-fill"></span></span>
              )}
            </div>
            <div class="home-process-content">
              <div class="home-process-verb">{step.verb}</div>
              <div class="home-process-step-title">{step.title}</div>
              <p class="home-process-detail">{step.description}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="home-process-thesis" data-home-process-thesis>
        <div class="home-process-thesis-line"></div>
        <div class="home-process-thesis-text">
          First call to clean yard.
          <em>Usually same day.</em>
        </div>
        <div class="home-process-thesis-sub">Most estimates confirmed within a few hours.</div>
        <button
          type="button"
          class="home-process-thesis-cta"
          data-open-estimate-modal
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          Get your free estimate →
        </button>
      </div>

    </div>
  </PageSection>
) : (
  <PageSection
    class="page-section-emphasis section-clone-showcase section-desktop-split"
    section="our-process"
    page={pageId}
    surfaceTone={surfaceTone}
  >
    <div class="clone-heading" data-block="heading">
      <h2 class="clone-kicker section-divider-title">Our Process</h2>
      <p class="section-lead section-desktop-lead clone-intro">
        A clear step-by-step path that helps homeowners move from the first request to quoting, scheduling, and finished work without unnecessary confusion, especially when the property needs quick answers, clear expectations, and a dependable plan.
      </p>
    </div>

    <div class:list={['clone-process-list', `process-variant-${variant}`]} data-block="cards">
      {steps.map((step, index) => (
        <article
          class="clone-process-card"
          data-step-index={index + 1}
          data-timeline-step={variant === 'timeline' ? index + 1 : undefined}
        >
          {variant === 'timeline' ? (
            <>
              <div class="clone-process-marker" aria-hidden="true">
                <span class="clone-process-step-number">
                  <span class="clone-process-step-number-fill"></span>
                  <span class="clone-process-step-number-label">{index + 1}</span>
                </span>
                {index < steps.length - 1 && (
                  <span class="clone-process-line">
                    <span class="clone-process-line-base"></span>
                    <span class="clone-process-line-fill"></span>
                  </span>
                )}
              </div>
              <div class="clone-process-copy">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </>
          ) : (
            <>
              <div class="clone-process-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                  {step.paths.map((path) => (
                    <path d={path}></path>
                  ))}
                </svg>
              </div>
              <div class="clone-process-copy">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </>
          )}
        </article>
      ))}
    </div>

    {variant === 'timeline' && (
      <div class="clone-process-timeline-cta" data-timeline-cta hidden>
        <a
          href={`tel:${templateConfig.business.phone.href}`}
          class="btn-primary clone-process-timeline-call"
          aria-label={`Call ${templateConfig.business.businessName} at ${templateConfig.business.phone.display}`}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path
              d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.07.36 2.22.55 3.41.55a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1h3.51a1 1 0 0 1 1 1c0 1.19.19 2.34.55 3.41a1 1 0 0 1-.24 1z"
              fill="currentColor"
            ></path>
          </svg>
          <span>{templateConfig.ctas.secondaryButtonLabel}</span>
        </a>
        <button
          type="button"
          class="btn-primary"
          data-open-estimate-modal
          data-process-estimate-trigger
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          Schedule Now
        </button>
      </div>
    )}
  </PageSection>
)}

{usePremiumProcessSection && (
  <script is:inline>
    (() => {
      const timeline = document.getElementById('home-process-timeline');
      const thesis = document.querySelector('[data-home-process-thesis]');
      if (!(timeline instanceof HTMLElement)) return;

      const steps = Array.from(timeline.querySelectorAll('[data-home-process-step]'));
      const circles = steps.map((step) => step.querySelector('.home-process-circle'));
      const lines = steps.map((step) => step.querySelector('.home-process-connector-fill'));

      const stepObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('visible');
          stepObs.unobserve(entry.target);
        });
      }, { threshold: 0.25, rootMargin: '0px 0px -20px 0px' });

      steps.forEach((step) => stepObs.observe(step));

      if (thesis instanceof HTMLElement) {
        const thesisObs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('visible');
            thesisObs.disconnect();
          });
        }, { threshold: 0.3 });

        thesisObs.observe(thesis);
      }

      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
      const sequenceUnits = (steps.length * 2) - 1;
      let ticking = false;
      let timelineHeight = timeline.offsetHeight || 1;

      const syncMetrics = () => {
        timelineHeight = timeline.offsetHeight || 1;
      };

      const updateTimeline = () => {
        ticking = false;

        const rect = timeline.getBoundingClientRect();
        const viewport = window.innerHeight || 1;
        const start = viewport * 0.8;
        const travel = timelineHeight + (viewport * 0.22);
        const progress = clamp((start - rect.top) / travel, 0, 1);
        const sequenceProgress = progress * sequenceUnits;

        steps.forEach((step, i) => {
          const circle = circles[i];
          const line = lines[i];
          const circleProgress = sequenceProgress - (i * 2);
          const lineProgress = sequenceProgress - ((i * 2) + 1);
          const circleVisible = circleProgress > 0;

          step.classList.toggle('active', circleVisible);

          if (circle instanceof HTMLElement) {
            circle.classList.toggle('filled', circleVisible);
          }

          if (line instanceof HTMLElement) {
            const lineFill = clamp(lineProgress, 0, 1);
            line.style.setProperty('--line-fill-progress', String(lineFill));
            line.classList.toggle('filled', lineFill >= 0.999);
          }
        });
      };

      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateTimeline);
      };

      updateTimeline();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', () => {
        syncMetrics();
        onScroll();
      });
      if ('ResizeObserver' in window) {
        const resizeObserver = new ResizeObserver(() => {
          syncMetrics();
          onScroll();
        });
        resizeObserver.observe(timeline);
      }
    })();
  </script>
)}

{variant === 'timeline' && !usePremiumProcessSection && (
  <script is:inline>
    (() => {
      const bindTimeline = (timeline) => {
        if (!(timeline instanceof HTMLElement) || timeline.dataset.timelineBound === 'true') return;
        timeline.dataset.timelineBound = 'true';

        const steps = Array.from(timeline.querySelectorAll('[data-timeline-step]'));
        const cta = timeline.parentElement?.querySelector('[data-timeline-cta]');
        if (steps.length === 0) return;
        let ctaRevealed = false;
        let hasScrollInteraction = false;

        const getProgress = (value) => Math.max(0, Math.min(1, value));

        const syncTimeline = () => {
          const viewportMid = window.innerHeight * 0.55;

          steps.forEach((step, index) => {
            if (!(step instanceof HTMLElement)) return;

            const marker = step.querySelector('.clone-process-step-number');
            if (!(marker instanceof HTMLElement)) return;

            const markerRect = marker.getBoundingClientRect();
            const markerCenter = markerRect.top + markerRect.height / 2;
            const markerBottom = markerRect.bottom;
            const nextStep = steps[index + 1];
            const nextMarker = nextStep instanceof HTMLElement
              ? nextStep.querySelector('.clone-process-step-number')
              : null;
            const nextRect = nextMarker instanceof HTMLElement ? nextMarker.getBoundingClientRect() : null;
            const nextTop = nextRect ? nextRect.top : markerBottom;
            const lineLength = nextRect ? Math.max(nextTop - markerBottom + 4, 0) : 0;

            const circleProgress = getProgress((viewportMid - markerCenter) / Math.max(markerRect.height * 0.9, 1));
            const lineProgress = nextRect
              ? getProgress((viewportMid - markerBottom) / Math.max(nextTop - markerBottom, 1))
              : circleProgress;

            step.style.setProperty('--timeline-circle-progress', String(circleProgress));
            step.style.setProperty('--timeline-line-progress', String(lineProgress));
            step.style.setProperty('--timeline-line-length', `${lineLength}px`);
            step.dataset.timelineActive = circleProgress > 0.18 ? 'true' : 'false';

            if (
              index === steps.length - 1 &&
              hasScrollInteraction &&
              circleProgress >= 0.999 &&
              !ctaRevealed
            ) {
              ctaRevealed = true;
              if (cta instanceof HTMLElement) {
                cta.hidden = false;
                window.requestAnimationFrame(() => {
                  cta.dataset.timelineCtaVisible = 'true';
                });
              }
            }
          });
        };

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!(entry.target instanceof HTMLElement)) return;
              entry.target.dataset.timelineVisible = entry.isIntersecting ? 'true' : 'false';
            });
            syncTimeline();
          },
          {
            threshold: [0, 0.2, 0.45, 0.7, 1],
            rootMargin: '-18% 0px -20% 0px',
          },
        );

        steps.forEach((step) => observer.observe(step));
        syncTimeline();

        let ticking = false;
        const requestSync = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(() => {
            ticking = false;
            syncTimeline();
          });
        };

        window.addEventListener('scroll', () => {
          hasScrollInteraction = true;
          requestSync();
        }, { passive: true });
        window.addEventListener('resize', requestSync);
      };

      const timelines = document.querySelectorAll('.process-variant-timeline');

      if (!('IntersectionObserver' in window)) {
        timelines.forEach((timeline) => bindTimeline(timeline));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          if (!(entry.target instanceof HTMLElement)) return;
          bindTimeline(entry.target);
          observer.unobserve(entry.target);
        });
      }, { rootMargin: '220px 0px' });

      timelines.forEach((timeline) => observer.observe(timeline));
    })();
  </script>
)}

<style>
  :global(.page-section.home-process-section[data-section="our-process"]) {
    padding: 0;
    background: #012a14;
    overflow-x: clip;
    margin-top: -2px;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 18px), 0 100%);
  }

  .home-process {
    position: relative;
    overflow: hidden;
    overflow-x: clip;
    margin-top: 0;
    padding: 0;
    background: #012a14;
  }

  .home-process::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 12px;
    background: #012a14;
    z-index: 3;
    pointer-events: none;
  }

  .home-process-head {
    position: relative;
    z-index: 1;
    padding: 44px 20px 36px;
  }

  .home-process-eye {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(200,150,90,0.72);
    margin-bottom: 10px;
  }

  .home-process-eye-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #c8965a;
    flex-shrink: 0;
    animation: hmDotPulse 2.2s ease-in-out infinite;
  }

  .home-process-title {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 40px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.88;
    color: #fff;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
  }

  .home-process-title em {
    color: #c8965a;
    font-style: normal;
    display: block;
  }

  .home-process-intro {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.88);
    line-height: 1.7;
    max-width: 240px;
    margin: 0;
  }

  .home-process-timeline {
    position: relative;
    z-index: 1;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
  }

  .home-process-step {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 0 18px;
    padding-bottom: 0;
    position: relative;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.22,1,0.36,1), transform 0.6s cubic-bezier(0.22,1,0.36,1);
  }

  .home-process-step.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home-process-step:nth-child(1) { transition-delay: 0s; }
  .home-process-step:nth-child(2) { transition-delay: 0.1s; }
  .home-process-step:nth-child(3) { transition-delay: 0.2s; }
  .home-process-step:nth-child(4) { transition-delay: 0.3s; }

  .home-process-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .home-process-circle {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: 50%;
    border: 2px solid rgba(200,150,90,0.25);
    background: rgba(200,150,90,0.05);
    display: grid;
    place-items: center;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    transition: border-color 500ms ease, background 500ms ease, box-shadow 500ms ease;
  }

  .home-process-circle.filled {
    background: rgba(200,150,90,0.16);
    border-color: rgba(200,150,90,0.6);
    box-shadow: 0 0 0 5px rgba(200,150,90,0.08), 0 0 20px rgba(200,150,90,0.18);
  }

  .home-process-circle svg {
    opacity: 0.35;
    transition: opacity 500ms ease;
  }

  .home-process-circle.filled svg {
    opacity: 1;
  }

  .home-process-connector {
    width: 2px;
    flex: 1;
    min-height: 28px;
    background: transparent;
    border-radius: 999px;
    position: relative;
    overflow: hidden;
    margin: 4px 0;
  }

  .home-process-connector-fill {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 999px;
    background: linear-gradient(180deg, #c8965a 0%, rgba(200,150,90,0.6) 100%);
    box-shadow: 0 0 8px rgba(200,150,90,0.3);
    transform: translateY(calc((1 - var(--line-fill-progress, 0)) * -100%));
    transition: transform 600ms cubic-bezier(0.22,1,0.36,1);
  }

  .home-process-connector-fill.filled {
    transform: translateY(0);
  }

  .home-process-step:last-child .home-process-connector {
    display: none;
  }

  .home-process-content {
    padding: 6px 0 32px;
    min-width: 0;
  }

  .home-process-step:last-child .home-process-content {
    padding-bottom: 0;
  }

  .home-process-verb {
    font-family: 'Barlow Condensed', 'Arial Narrow', sans-serif;
    font-size: 46px;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 0.82;
    letter-spacing: -0.02em;
    color: rgba(255,255,255,0.8);
    margin-bottom: 8px;
    position: relative;
    overflow: hidden;
    transition: color 500ms ease;
  }

  .home-process-step.active .home-process-verb {
    color: #c8965a;
  }

  .home-process-step-title {
    font-size: 14px;
    font-weight: 800;
    color: rgba(255,255,255,0.88);
    letter-spacing: -0.01em;
    margin-bottom: 5px;
    transition: color 400ms ease;
  }

  .home-process-step.active .home-process-step-title {
    color: #fff;
  }

  .home-process-detail {
    margin: 0;
    max-width: 220px;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.82);
    line-height: 1.65;
    overflow-wrap: anywhere;
    transition: color 400ms ease;
  }

  .home-process-step.active .home-process-detail {
    color: rgba(255,255,255,0.92);
  }

  .home-process-thesis {
    position: relative;
    z-index: 1;
    padding: 36px 20px 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22,1,0.36,1);
  }

  .home-process-thesis.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .home-process-thesis-line {
