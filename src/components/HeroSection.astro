---
import { Image } from 'astro:assets';
import HeroOutlineCopy from './HeroOutlineCopy.astro';
import HeroTitleWords from './HeroTitleWords.astro';
import { brand } from '../data/brand';
import { client } from '../data/client';
import { templateConfig } from '../data/client-questionnaire';
import { heroImageTransform } from '../data/heroMedia';
import type { HeroVariant } from '../data/client-questionnaire';
import { resolveConfiguredImageAsset } from '../lib/template/runtime-assets';

interface HeroAction {
  kind: 'modal' | 'link' | 'anchor' | 'none';
  label: string;
  href?: string;
  target?: string;
}

interface Props {
  pageId: string;
  titlePrimary: string;
  titleSecondary?: string;
  intro: string;
  desktopIntro?: string;
  outlineWords: string[];
  variant?: HeroVariant;
  cta?: HeroAction;
}

const {
  pageId,
  titlePrimary,
  titleSecondary = '',
  intro,
  desktopIntro,
  outlineWords,
  variant = templateConfig.presets.hero,
  cta = { kind: 'none', label: '' },
} = Astro.props;

const loc = client.primaryLocation;
const desktopIntroByPageId: Record<string, string> = {
  home: `Tree removal, trimming, stump grinding, and storm cleanup in ${loc}.`,
  services: `Find the right tree service for your property in ${loc}.`,
  about: `Dependable local tree service for homeowners in ${loc}.`,
  contact: `Reach out for estimates, service questions, and scheduling in ${loc}.`,
  'tree-removal': `Safe tree removal for damaged, unsafe, or unwanted trees in ${loc}.`,
  'tree-trimming': 'Professional trimming for cleaner canopies, better clearance, and routine upkeep.',
  'stump-grinding': 'Stump grinding that clears old stumps and opens up usable yard space.',
  'emergency-tree-service': 'Fast storm cleanup and emergency tree service when damage needs attention.',
};

const resolvedDesktopIntro = desktopIntro ?? desktopIntroByPageId[pageId];
const desktopHeroTitle = `${titlePrimary}${titleSecondary ? ` ${titleSecondary}` : ''}`.trim();
const desktopHeroWords = desktopHeroTitle.split(/\s+/);
const normalizedDesktopHeroWords = desktopHeroWords.map((word) => word.replace(/[^a-z0-9]+/gi, '').toLowerCase());
const desktopHeroHasTreeWord = normalizedDesktopHeroWords.includes('tree');

const heroClassName = [
  'page-hero',
  'internal-hero',
  'service-hero',
  pageId === 'home' && 'homepage-hero',
  `hero-variant-${variant}`,
]
  .filter(Boolean)
  .join(' ');
const heroImage = resolveConfiguredImageAsset(brand.assets.heroImage);

const isHome = pageId === 'home';
const hasStats = isHome && !!(client.jobsCompleted || client.yearsInBusiness || client.googleRating);
---

<section class={heroClassName} data-page={pageId} data-section="hero" data-hero-variant={variant}>
  <div class="hero-frame" data-block="frame">
    <div class="hero-bleed subpage-hero-bleed" data-block="background">
      <HeroOutlineCopy words={outlineWords} />
      {variant !== 'abstract-no-image' && (
        <Image
          src={heroImage}
          alt=""
          aria-hidden="true"
          class="hero-accent-image"
          width={800}
          height={480}
          format={heroImageTransform.format}
          quality={heroImageTransform.quality}
          widths={heroImageTransform.widths}
          sizes={heroImageTransform.sizes}
          priority={true}
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      )}
      {isHome && (
        <>
          <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
          <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
          <div class="hero-orb hero-orb-3" aria-hidden="true"></div>
          <div class="hero-grid-overlay" aria-hidden="true"></div>
          <div class="hero-particle hero-particle-1" aria-hidden="true"></div>
          <div class="hero-particle hero-particle-2" aria-hidden="true"></div>
          <div class="hero-particle hero-particle-3" aria-hidden="true"></div>
          <div class="hero-particle hero-particle-4" aria-hidden="true"></div>
          <div class="hero-particle hero-particle-5" aria-hidden="true"></div>
          <div class="hero-particle hero-particle-6" aria-hidden="true"></div>
        </>
      )}
      <div class="hero-copy" data-block="content">
        <h1 data-block="title">
          <span class="hero-title-primary hero-title-primary-mobile"><HeroTitleWords text={titlePrimary} /></span>
          {titleSecondary && <span class="hero-title-secondary hero-title-secondary-mobile">{titleSecondary}</span>}
          <span class="hero-title-desktop">
            {desktopHeroWords.map((word, index) => (
              <>
                <span
                  class={
                    normalizedDesktopHeroWords[index] === 'tree' || (!desktopHeroHasTreeWord && index === 0)
                      ? 'hero-word-accent'
                      : undefined
                  }
                >
                  {word}
                </span>
                {index < desktopHeroWords.length - 1 ? ' ' : ''}
              </>
            ))}
          </span>
        </h1>
        {intro && <p class="hero-subcopy" data-block="intro">{intro}</p>}
        {resolvedDesktopIntro && <p class="hero-subcopy hero-subcopy-desktop" data-block="intro-desktop">{resolvedDesktopIntro}</p>}
        {cta.kind !== 'none' && (
          <div class="hero-cta-inline" data-block="cta-inline">
            {cta.kind === 'modal' ? (
              <button
                type="button"
                class="hero-cta"
                data-open-estimate-modal
                aria-haspopup="dialog"
                aria-controls={cta.target}
              >
                {cta.label}
              </button>
            ) : (
              <a href={cta.href} class="hero-cta">
                {cta.label}
              </a>
            )}

            <a
              href={`tel:${client.primaryPhoneHref}`}
              class="hero-cta hero-cta-secondary"
              aria-label={`Call ${client.businessName} at ${client.primaryPhoneDisplay}`}
            >
              {client.ctas.secondaryButtonLabel}
            </a>
          </div>
        )}
      </div>
      {isHome && (
        <div class="hero-mobile-panel" data-mobile-panel>
          <div class="hero-mobile-headline">
            <span class="hero-mobile-line-1">Local Tree</span>
            <span class="hero-mobile-line-2">Service</span>
            <span class="hero-mobile-line-3">Done Right.</span>
          </div>
          <p class="hero-mobile-subheading">Tree removal, trimming, stump grinding &amp; storm cleanup — handled by your local crew.</p>
          <div class="hero-mobile-ctas">
            {cta.kind === 'modal' ? (
              <button
                type="button"
                class="hero-cta hero-mobile-cta-primary"
                data-open-estimate-modal
                aria-haspopup="dialog"
                aria-controls={cta.target}
              >
                Get a Free Estimate →
              </button>
            ) : (cta.kind === 'link' || cta.kind === 'anchor') ? (
              <a href={cta.href} class="hero-cta hero-mobile-cta-primary">Get a Free Estimate →</a>
            ) : null}
            <a href={`tel:${client.primaryPhoneHref}`} class="hero-mobile-call">
              or call us: <strong>{client.ctas.secondaryButtonLabel}</strong>
            </a>
          </div>
          {hasStats && (
            <div class="hero-stats-row" data-stats>
              {client.jobsCompleted ? (
                <div class="hero-stat" data-target={client.jobsCompleted}>
                  <span class="hero-stat-number">
                    <span class="hero-stat-count">0</span><span class="hero-stat-suffix">+</span>
                  </span>
                  <div class="hero-stat-underline"></div>
                  <span class="hero-stat-label">Happy Clients</span>
                </div>
              ) : null}
              {client.yearsInBusiness ? (
                <div class="hero-stat" data-target={client.yearsInBusiness}>
                  <span class="hero-stat-number">
                    <span class="hero-stat-count">0</span><span class="hero-stat-suffix">yr</span>
                  </span>
                  <div class="hero-stat-underline"></div>
                  <span class="hero-stat-label">Experience</span>
                </div>
              ) : null}
              {client.googleRating ? (
                <div class="hero-stat" data-target={client.googleRating}>
                  <span class="hero-stat-number">
                    <span class="hero-stat-count">0</span><span class="hero-stat-suffix">★</span>
                  </span>
                  <div class="hero-stat-underline"></div>
                  <span class="hero-stat-label">Star Rated</span>
                </div>
              ) : null}
            </div>
          )}
          <div class="hero-diagonal-clip" aria-hidden="true">
            <svg viewBox="0 0 300 24" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M0 0 L300 16 L300 24 L0 24 Z" fill="#c8965a" />
            </svg>
          </div>
        </div>
      )}
    </div>
    {cta.kind !== 'none' && (
      <div class="hero-cta-wrap" data-block="cta">
        {cta.kind === 'modal' ? (
          <button
            type="button"
            class="hero-cta"
            data-open-estimate-modal
            aria-haspopup="dialog"
            aria-controls={cta.target}
          >
            {cta.label}
          </button>
        ) : (
          <a
            href={cta.href}
            class="hero-cta"
          >
            {cta.label}
          </a>
        )}
      </div>
    )}
  </div>
  {isHome && client.trustTicker.length > 0 && (
    <div class="hero-ticker-wrap" aria-label="Trust highlights">
      <div class="hero-ticker-track">
        {[...client.trustTicker, ...client.trustTicker].map((item) => (
          <span class="hero-ticker-item">
            <span class="hero-ticker-check" aria-hidden="true">✓</span>
            {item}
            <span class="hero-ticker-dot" aria-hidden="true"></span>
          </span>
        ))}
      </div>
    </div>
  )}
</section>
{isHome && (
  <script is:inline>
    (function () {
      var statsRow = document.querySelector('[data-stats]');
      if (!statsRow) return;

      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        statsRow.querySelectorAll('[data-target]').forEach(function (stat) {
          var target = parseInt(stat.dataset.target, 10);
          var countEl = stat.querySelector('.hero-stat-count');
          if (countEl) countEl.textContent = target;
          var underline = stat.querySelector('.hero-stat-underline');
          if (underline) underline.classList.add('active');
        });
        return;
      }

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            observer.disconnect();
            var stats = statsRow.querySelectorAll('[data-target]');
            stats.forEach(function (stat, index) {
              var target = parseInt(stat.dataset.target, 10);
              var countEl = stat.querySelector('.hero-stat-count');
              var underline = stat.querySelector('.hero-stat-underline');
              var delay = index * 200;
              var duration = 1800;
              var start = null;
              setTimeout(function () {
                function animate(timestamp) {
                  if (!start) start = timestamp;
                  var progress = Math.min((timestamp - start) / duration, 1);
                  var eased = 1 - Math.pow(1 - progress, 3);
                  var current = Math.round(target * eased);
                  if (countEl) countEl.textContent = current;
                  if (progress < 1) {
                    requestAnimationFrame(animate);
                  } else {
                    if (countEl) countEl.textContent = target;
                    if (underline) underline.classList.add('active');
                  }
                }
                requestAnimationFrame(animate);
              }, delay);
            });
          });
        },
        { threshold: 0.3 }
      );

      observer.observe(statsRow);
    })();
  </script>
)}
