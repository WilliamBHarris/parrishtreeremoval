---
import leafletCssHref from 'leaflet/dist/leaflet.css?url';
import { brand } from '../data/brand';

const parrishLat = 27.5806;
const parrishLng = -82.4251;
const manateeBounds = [
  [27.204, -82.704],
  [27.813, -82.053],
];
---

<figure class="service-area-map-shell">
  <div
    class="service-area-map-canvas"
    data-service-area-map
    data-lat={parrishLat}
    data-lng={parrishLng}
    data-bounds={JSON.stringify(manateeBounds)}
    aria-hidden="true"
    role="presentation"
  ></div>
  <div class="service-area-map-fade" aria-hidden="true"></div>
  <noscript>
    <img
      src={brand.assets.serviceAreaMap}
      alt="Illustrated map centered on Parrish, Florida"
      class="service-area-map"
      loading="lazy"
      decoding="async"
      width="1200"
      height="720"
    />
  </noscript>
  <figcaption class="service-area-map-attribution">
    Map data © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap contributors</a>
  </figcaption>
</figure>

<script define:vars={{ leafletCssHref }}>
  const mapNodes = document.querySelectorAll('[data-service-area-map]');
  let leafletCssLoaded;

  const ensureLeafletCss = () => {
    if (leafletCssLoaded) return leafletCssLoaded;

    const existingLink = document.querySelector('link[data-leaflet-styles]');
    if (existingLink instanceof HTMLLinkElement) {
      leafletCssLoaded = Promise.resolve();
      return leafletCssLoaded;
    }

    leafletCssLoaded = new Promise((resolve, reject) => {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = leafletCssHref;
      link.dataset.leafletStyles = 'true';
      link.onload = () => resolve();
      link.onerror = () => reject(new Error('Failed to load Leaflet styles.'));
      document.head.append(link);
    });

    return leafletCssLoaded;
  };

  const initializeMap = async (node) => {
    if (!(node instanceof HTMLElement) || node.dataset.mapBound === 'true') return;
    node.dataset.mapBound = 'true';

    const lat = Number(node.dataset.lat);
    const lng = Number(node.dataset.lng);
    const boundsData = node.dataset.bounds;

    if (!Number.isFinite(lat) || !Number.isFinite(lng) || !boundsData) return;

    await ensureLeafletCss();
    const { default: L } = await import('leaflet');
    const bounds = JSON.parse(boundsData);
    const map = L.map(node, {
      zoomControl: false,
      attributionControl: false,
      scrollWheelZoom: false,
      dragging: false,
      doubleClickZoom: false,
      boxZoom: false,
      keyboard: false,
      touchZoom: false,
      tap: true,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
    }).addTo(map);

    L.circle([lat, lng], {
      radius: 22000,
      color: '#8B6212',
      weight: 1.2,
      fillColor: '#43572E',
      fillOpacity: 0.12,
    }).addTo(map);

    const pinIcon = L.divIcon({
      className: 'service-area-pin',
      html: '<span></span>',
      iconSize: [28, 28],
      iconAnchor: [14, 28],
      popupAnchor: [0, -24],
    });

    L.marker([lat, lng], {
      icon: pinIcon,
      interactive: false,
      keyboard: false,
    }).addTo(map);

    map.fitBounds(bounds, {
      padding: [20, 20],
    });

    window.setTimeout(() => map.invalidateSize(), 0);
  };

  const observer =
    'IntersectionObserver' in window
      ? new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            observer.unobserve(entry.target);
            void initializeMap(entry.target);
          });
        }, { rootMargin: '240px 0px' })
      : null;

  mapNodes.forEach((node) => {
    if (!(node instanceof HTMLElement)) return;

    if (observer) {
      observer.observe(node);
      return;
    }

    void initializeMap(node);
  });
</script>
