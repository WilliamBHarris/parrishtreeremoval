<figure class="service-area-map-shell">
  <img
    src="/images/service-area-map-poster.svg"
    alt=""
    aria-hidden="true"
    class="service-area-map"
    loading="lazy"
    decoding="async"
    width="1200"
    height="720"
  />
  <div class="service-area-map-fade" aria-hidden="true"></div>
  <figcaption class="service-area-map-attribution">
    Map data © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap contributors</a>
  </figcaption>
</figure>
