---
import PageSection from './PageSection.astro';
import type { SectionTone } from '../data/client-questionnaire';

interface CardItem {
  title: string;
  description: string;
}

interface Props {
  pageId: string;
  section: string;
  title: string;
  items: CardItem[];
  columns?: 'default' | 'two';
  surfaceTone?: SectionTone;
}

const {
  pageId,
  section,
  title,
  items,
  columns = 'default',
  surfaceTone = 'base',
} = Astro.props;
---

<PageSection section={section} page={pageId} surfaceTone={surfaceTone}>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
  </div>

  <div class:list={['stack-grid', columns === 'two' && 'stack-grid-two']} data-block="cards">
    {items.map((item) => (
      <article class="stack-panel">
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</PageSection>
