---
import PageSection from './PageSection.astro';
import type { SectionTone } from '../data/client-questionnaire';

interface CardItem {
  title: string;
  description: string;
}

interface Props {
  pageId: string;
  section: string;
  title: string;
  items: CardItem[];
  columns?: 'default' | 'two';
  surfaceTone?: SectionTone;
}

const {
  pageId,
  section,
  title,
  items,
  columns = 'default',
  surfaceTone = 'base',
} = Astro.props;

const desktopIntroBySection: Record<string, string> = {
  'compare-services':
    'A clearer comparison of the main tree services so homeowners can match the right work to the condition of the tree, the property, the cleanup involved, and the overall project goals before requesting an estimate.',
  'before-you-submit':
    'A few practical details that help a tree service estimate move faster, clarify the scope of the work, improve the first review, and make the next step easier to schedule without unnecessary back-and-forth.',
  'what-homeowners-need':
    'The things homeowners usually care about first when choosing a local tree service company, comparing options, and deciding who to trust with the work on their property in Parrish and the surrounding area.',
};
---

<PageSection class="section-desktop-split" section={section} page={pageId} surfaceTone={surfaceTone}>
  <div class="clone-heading" data-block="heading">
    <h2 class="clone-kicker section-divider-title">{title}</h2>
    {desktopIntroBySection[section] && (
      <p class="section-lead section-desktop-lead clone-intro">
        {desktopIntroBySection[section]}
      </p>
    )}
  </div>

  <div class:list={['stack-grid', columns === 'two' && 'stack-grid-two']} data-block="cards">
    {items.map((item) => (
      <article class="stack-panel">
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</PageSection>
