---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { client } from '../data/client';
import { brand } from '../data/brand';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogImage?: string;
}

const {
  title = `${client.businessName} | Tree Removal and Trimming in ${client.primaryLocation}`,
  description = `Tree removal, trimming, stump grinding, and storm cleanup information for homeowners in ${client.primaryLocation}.`,
  schema,
  ogImage = brand.assets.ogImage
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? 'https://parrishtreeremoval.com';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const brandCssVars = `
  :root {
    --brand-primary: ${brand.colors.primary};
    --brand-secondary: ${brand.colors.secondary};
    --brand-accent: ${brand.colors.accent};
    --brand-highlight: ${brand.colors.highlight};
    --brand-page-bg: ${brand.colors.pageBg};
    --brand-page-bg-soft: ${brand.colors.pageBgSoft};
    --brand-surface: ${brand.colors.surface};
    --brand-surface-soft: ${brand.colors.surfaceSoft};
    --brand-text: ${brand.colors.text};
    --brand-text-soft: ${brand.colors.textSoft};
    --brand-heading: ${brand.colors.heading};
    --brand-line: ${brand.colors.line};
    --brand-line-strong: ${brand.colors.lineStrong};
    --brand-overlay: ${brand.colors.overlay};
    --brand-button-top: ${brand.colors.buttonTop};
    --brand-button-bottom: ${brand.colors.buttonBottom};
    --brand-accent-top: ${brand.colors.accentTop};
    --brand-accent-bottom: ${brand.colors.accentBottom};
  }
`;
const schemaList = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: client.siteName,
    url: siteUrl
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${siteUrl}#localbusiness`,
    name: client.businessName,
    url: siteUrl,
    telephone: client.primaryPhoneDisplay,
    areaServed: client.serviceAreas,
    description,
    image: ogImageUrl,
    serviceType: 'Tree removal, trimming, stump grinding, and storm cleanup'
  },
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no,address=no,email=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content={brand.colors.themeColor} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={brand.assets.faviconSvg} type="image/svg+xml" />
    <link rel="icon" href={brand.assets.faviconIco} sizes="any" />
    <link rel="canonical" href={canonical} />
    <style is:global set:html={brandCssVars}></style>
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={client.siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${client.businessName} service area map`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="sitemap" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaList)}></script>
  </head>
  <body>
    <div id="site-top" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
