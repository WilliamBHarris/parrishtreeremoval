---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogImage?: string;
}

const {
  title = 'Parrish Tree Removal | Tree Removal and Trimming in Parrish, FL',
  description = 'Tree removal, trimming, stump grinding, and storm cleanup information for homeowners in Parrish, Florida.',
  schema,
  ogImage = '/images/parrish-service-area-map.svg'
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? 'https://parrishtreeremoval.com';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const schemaList = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Parrish Tree Removal',
    url: siteUrl
  },
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${siteUrl}#localbusiness`,
    name: 'Parrish Tree Removal',
    url: siteUrl,
    telephone: '+1-800-555-0199',
    areaServed: ['Parrish, FL', 'Bradenton, FL', 'Palmetto, FL', 'Lakewood Ranch, FL'],
    description,
    image: ogImageUrl,
    serviceType: 'Tree removal, trimming, stump grinding, and storm cleanup'
  },
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0F2143" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Parrish Tree Removal" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaList)}></script>
  </head>
  <body>
    <div id="site-top" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <a
      href="tel:+18005550199"
      class="sticky-call-fab"
      aria-label="Call now"
      style="text-decoration:none;"
    >
      <svg
        viewBox="0 0 24 24"
        aria-hidden="true"
        focusable="false"
        style="display:block;width:26px;height:26px;fill:currentColor;"
      >
        <path
          d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24c1.07.36 2.22.55 3.41.55a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.3 21 3 13.7 3 4.5a1 1 0 0 1 1-1h3.51a1 1 0 0 1 1 1c0 1.19.19 2.34.55 3.41a1 1 0 0 1-.24 1z"
          fill="currentColor"
        ></path>
      </svg>
    </a>

  </body>
</html>
