---
import globalCss from '../styles/global.css?raw';
import siteInteractionsScript from '../lib/site/site-interactions.inline.js?raw';
import { transformSync } from 'esbuild';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EstimateForm from '../components/EstimateForm.astro';
import { client } from '../data/client';
import { brand } from '../data/brand';
import { pageContent } from '../data/pages';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogImage?: string;
  robots?: string;
  showSiteChrome?: boolean;
  criticalImage?: {
    src: string;
    srcSet?: string;
    sizes?: string;
    type?: string;
  };
}

const {
  title = `${client.businessName} | Tree Removal and Trimming in ${client.primaryLocation}`,
  description = `Tree removal, trimming, stump grinding, and storm cleanup information for homeowners in ${client.primaryLocation}.`,
  schema,
  ogImage = brand.assets.ogImage,
  robots = 'index,follow,max-image-preview:large',
  showSiteChrome = true,
  criticalImage,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? `https://${client.websiteDomain}`;
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const socialProfileLinks = Object.values(client.social.profiles).filter((value): value is string => Boolean(value));
const modalContent = pageContent.home.modal;
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteUrl}#localbusiness`,
  name: client.legalBusinessName,
  url: siteUrl,
  telephone: client.primaryPhoneDisplay,
  areaServed: client.serviceAreas,
  description,
  image: ogImageUrl,
  ...(client.social.serviceTypeSummary ? { serviceType: client.social.serviceTypeSummary } : {}),
  ...(socialProfileLinks.length > 0 ? { sameAs: socialProfileLinks } : {}),
};
const brandCssVars = `
  :root {
    --brand-primary: ${brand.colors.primary};
    --brand-secondary: ${brand.colors.secondary};
    --brand-accent: ${brand.colors.accent};
    --brand-highlight: ${brand.colors.highlight};
    --brand-page-bg: ${brand.colors.pageBg};
    --brand-page-bg-soft: ${brand.colors.pageBgSoft};
    --brand-surface: ${brand.colors.surface};
    --brand-surface-soft: ${brand.colors.surfaceSoft};
    --brand-text: ${brand.colors.text};
    --brand-text-soft: ${brand.colors.textSoft};
    --brand-heading: ${brand.colors.heading};
    --brand-line: ${brand.colors.line};
    --brand-line-strong: ${brand.colors.lineStrong};
    --brand-overlay: ${brand.colors.overlay};
    --brand-button-top: ${brand.colors.buttonTop};
    --brand-button-bottom: ${brand.colors.buttonBottom};
    --brand-accent-top: ${brand.colors.accentTop};
    --brand-accent-bottom: ${brand.colors.accentBottom};
  }
`;
const fontFaceCss = `
  @font-face {
    font-family: 'Barlow Condensed';
    src: url('/fonts/barlow-condensed-400-latin.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Barlow Condensed';
    src: url('/fonts/barlow-condensed-700-latin.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Barlow Condensed';
    src: url('/fonts/barlow-condensed-800-latin.woff2') format('woff2');
    font-weight: 800;
    font-style: normal;
    font-display: swap;
  }
`;
const schemaList = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: client.siteName,
    url: siteUrl
  },
  localBusinessSchema,
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])
];
const bodyClasses = [
  showSiteChrome ? 'layout-site-chrome' : 'layout-no-site-chrome',
  `template-color-${brand.presets.colorTemplate}`,
  `template-section-title-${brand.presets.sectionTitleStyle}`,
  `template-card-surface-${brand.presets.cardSurface}`,
  `template-card-border-${brand.presets.cardBorderStyle}`,
  `template-button-border-${brand.presets.buttonBorderStyle}`,
  `template-section-frame-${brand.presets.sectionFrameStyle}`,
];
const minifiedCss = transformSync(`${brandCssVars}\n${fontFaceCss}\n${globalCss}`, {
  loader: 'css',
  minify: true,
}).code;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="format-detection" content="telephone=no,address=no,email=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content={brand.colors.themeColor} />
    <link rel="preload" href="/fonts/barlow-condensed-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/barlow-condensed-700-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/barlow-condensed-800-latin.woff2" as="font" type="font/woff2" crossorigin />
    {criticalImage && (
      <link
        rel="preload"
        as="image"
        href={criticalImage.src}
        imagesrcset={criticalImage.srcSet}
        imagesizes={criticalImage.sizes}
        type={criticalImage.type}
        fetchpriority="high"
      />
    )}
    <link rel="icon" href={brand.assets.faviconSvg} type="image/svg+xml" />
    <link rel="icon" href={brand.assets.faviconIco} sizes="any" />
    <link rel="canonical" href={canonical} />
    <style is:global set:html={minifiedCss}></style>
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={client.siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={brand.assets.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={brand.assets.ogImageAlt} />
    <link rel="sitemap" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaList)}></script>
  </head>
  <body class={bodyClasses.join(' ')}>
    <div id="site-top" aria-hidden="true"></div>
    <a href="#main-content" class="skip-link">Skip to content</a>
    {showSiteChrome && <Header />}
    <main id="main-content">
      <slot />
    </main>
    <div
      id="estimate-modal"
      class="estimate-modal"
      data-estimate-modal
      aria-hidden="true"
      hidden
      inert
    >
      <div class="estimate-modal-scrim" data-close-estimate-modal></div>
      <div
        class="estimate-modal-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="estimate-modal-title"
      >
        <div class="estimate-modal-sheet">
          <div class="estimate-modal-handle-wrap" aria-hidden="true">
            <div class="estimate-modal-handle"></div>
          </div>
          <div class="estimate-modal-header">
            <div class="estimate-modal-header-left">
              <div class="estimate-modal-eyebrow">
                <span class="estimate-modal-eyebrow-dot"></span>
                Free Estimate
              </div>
              <h2 id="estimate-modal-title" class="estimate-modal-title">
                Tell Us
                <em>About Your</em>
                Project.
              </h2>
            </div>
            <button
              type="button"
              class="estimate-modal-close"
              aria-label="Close estimate form"
              data-close-estimate-modal
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(1,42,20,0.5)" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <path d="M18 6L6 18M6 6l12 12"></path>
              </svg>
            </button>
          </div>
          <p class="estimate-modal-sub">We'll follow up same day — usually within a few hours.</p>
        <EstimateForm
          heading={modalContent.heading}
          intro={modalContent.intro}
          buttonLabel={modalContent.buttonLabel}
          headingId="estimate-modal-title"
          variant="premium-modal"
          hideIntro={true}
        />
        </div>
      </div>
    </div>
    {showSiteChrome && <Footer />}
    <script is:inline set:html={siteInteractionsScript}></script>
  </body>
</html>
