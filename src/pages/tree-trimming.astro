---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tree Trimming In Parrish, FL | Parrish Tree Removal"
  description="Tree trimming and pruning information for homeowners in Parrish, Florida."
>
  <section class="internal-hero">
    <div class="internal-hero-shell">
      <span class="eyebrow">Tree Trimming</span>
      <h1>Tree trimming support for clearance, shape, and maintenance</h1>
      <p>
        Trimming requests commonly focus on overhang reduction, shape improvement, and
        keeping growth away from structures or traffic areas.
      </p>
      <div class="inline-actions">
        <a href="/contact" class="btn-primary">Ask About Trimming</a>
      </div>
    </div>
  </section>

  <div class="page-shell">
    <section class="page-section">
      <div class="section-heading">
        <h2 class="section-title-reveal">Helpful Trimming Details</h2>
      </div>
      <div class="page-card">
        <ul class="list-copy">
          <li>Which side of the tree needs attention?</li>
          <li>Is the concern mostly about roof, driveway, or walkway clearance?</li>
          <li>Are one or several trees involved in the same request?</li>
          <li>Would cleanup or additional services be needed at the same time?</li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
