---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SubpageIntroSection from '../components/SubpageIntroSection.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import ContactDirectSection from '../components/ContactDirectSection.astro';
import { pageContent } from '../data/pages';
import { getHeroCriticalImage } from '../lib/site/critical-image';

const contactPage = pageContent.contact;
const criticalImage = await getHeroCriticalImage();
---

<BaseLayout
  title={contactPage.title}
  description={contactPage.description}
  criticalImage={criticalImage}
>
  <HeroSection
    pageId="contact"
    titlePrimary={contactPage.hero.titlePrimary}
    titleSecondary={contactPage.hero.titleSecondary}
    intro={contactPage.hero.intro}
    outlineWords={contactPage.hero.outlineWords}
    variant={contactPage.hero.variant}
    cta={contactPage.hero.cta}
  />

  <div class="page-shell" data-page="contact">
    <SubpageIntroSection
      pageId="contact"
      eyebrow="Contact"
      lines={['Tell us the job.', 'Share the details.']}
      accentLine="We follow up fast."
      body="Reach out with the service, timing, and property details. We will review it quickly and get you a clear next step without the runaround."
      surfaceTone="olive"
    />

    <ContactFormSection pageId="contact" surfaceTone="base" />

    <ContactDirectSection pageId="contact" surfaceTone="olive" />
  </div>
</BaseLayout>
