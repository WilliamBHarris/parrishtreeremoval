---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import CardGridSection from '../components/CardGridSection.astro';
import EstimateFormSection from '../components/EstimateFormSection.astro';
import RelatedServicesSection from '../components/RelatedServicesSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { servicePages } from '../data/services';
import { getHeroCriticalImage } from '../lib/site/critical-image';

const contactPage = pageContent.contact;
const criticalImage = await getHeroCriticalImage();
---

<BaseLayout
  title={contactPage.title}
  description={contactPage.description}
  criticalImage={criticalImage}
>
  <HeroSection
    pageId="contact"
    titlePrimary={contactPage.hero.titlePrimary}
    titleSecondary={contactPage.hero.titleSecondary}
    intro={contactPage.hero.intro}
    outlineWords={contactPage.hero.outlineWords}
    variant={contactPage.hero.variant}
    cta={contactPage.hero.cta}
  />

  <div class="page-shell" data-page="contact">
    <EstimateFormSection
      pageId="contact"
      title="Send Project Details"
      heading={contactPage.estimateForm.heading}
      intro={contactPage.estimateForm.intro}
      buttonLabel={contactPage.estimateForm.buttonLabel}
      surfaceTone="base"
    />

    <CardGridSection
      pageId="contact"
      section="before-you-submit"
      title="Before You Submit"
      items={contactPage.beforeYouSubmit}
      surfaceTone="warm"
    />

    <HomepageWhyChoose pageId="contact" surfaceTone="cool" />

    <HomepageProcess pageId="contact" surfaceTone="olive" />

    <RelatedServicesSection
      pageId="contact"
      ariaLabel="Service links"
      links={[
        { href: `/${servicePages.treeRemoval.slug}`, label: servicePages.treeRemoval.cardTitle },
        { href: `/${servicePages.stumpGrinding.slug}`, label: servicePages.stumpGrinding.cardTitle },
        { href: `/${servicePages.treeTrimming.slug}`, label: servicePages.treeTrimming.cardTitle },
        { href: `/${servicePages.stormCleanup.slug}`, label: servicePages.stormCleanup.cardTitle },
      ]}
      surfaceTone="base"
    />

    <ServiceAreaSection pageId="contact" surfaceTone="cool" />
  </div>
</BaseLayout>
