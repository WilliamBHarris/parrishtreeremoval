---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import ServicesSection from '../components/ServicesSection.astro';
import CardGridSection from '../components/CardGridSection.astro';
import InfoListSection from '../components/InfoListSection.astro';
import EstimateFormSection from '../components/EstimateFormSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { templateConfig } from '../data/client-questionnaire';
import { serviceCardList } from '../data/services';
import { getHeroCriticalImage } from '../lib/site/critical-image';

const servicesPage = pageContent.services;
const criticalImage = await getHeroCriticalImage();
---

<BaseLayout
  title={servicesPage.title}
  description={servicesPage.description}
  criticalImage={criticalImage}
>
  <HeroSection
    pageId="services"
    titlePrimary={servicesPage.hero.titlePrimary}
    titleSecondary={servicesPage.hero.titleSecondary}
    intro={servicesPage.hero.intro}
    outlineWords={servicesPage.hero.outlineWords}
    variant={servicesPage.hero.variant}
    cta={servicesPage.hero.cta}
  />

  <div class="page-shell" data-page="services">
    <ServicesSection
      pageId="services"
      sectionKey="services-overview"
      title="Our Services"
      services={serviceCardList}
      variant={templateConfig.presets.services}
      summaryMode="overview"
      surfaceTone="base"
    />

    <CardGridSection
      pageId="services"
      section="compare-services"
      title="Compare Services"
      items={servicesPage.compareCards}
      surfaceTone="warm"
    />

    <HomepageWhyChoose pageId="services" surfaceTone="cool" />

    <HomepageProcess pageId="services" surfaceTone="olive" />

    <InfoListSection
      pageId="services"
      section="estimate-tips"
      title="Estimate Tips"
      items={servicesPage.estimateTips}
      softCard={true}
      surfaceTone="base"
    />

    <EstimateFormSection
      pageId="services"
      title="Request A Free Estimate"
      heading={servicesPage.estimateForm.heading}
      intro={servicesPage.estimateForm.intro}
      buttonLabel={servicesPage.estimateForm.buttonLabel}
      surfaceTone="warm"
    />

    <ServiceAreaSection pageId="services" surfaceTone="cool" />
  </div>
</BaseLayout>
