---
import BaseLayout from '../layouts/BaseLayout.astro';
import EstimateForm from '../components/EstimateForm.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import PageSection from '../components/PageSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { serviceCardList } from '../data/services';

const servicesPage = pageContent.services;
---

<BaseLayout
  title={servicesPage.title}
  description={servicesPage.description}
>
  <section class="page-hero internal-hero service-hero">
    <div class="hero-frame">
      <div class="hero-bleed subpage-hero-bleed">
        <div class="hero-copy">
          <h1>
            <span class="hero-title-primary">Tree Services</span>
            <span class="hero-title-secondary">in Parrish, FL</span>
          </h1>
          <p class="hero-subcopy">{servicesPage.heroIntro}</p>
        </div>
      </div>
      <div class="hero-cta-wrap">
        <a href="/contact" class="hero-cta">Free Estimate</a>
      </div>
    </div>
  </section>

  <div class="page-shell" data-page="services">
    <PageSection section="services-overview" page="services">
      <div class="clone-heading">
        <h2 class="clone-kicker section-divider-title">Our Services</h2>
      </div>

      <div class="service-grid">
        {serviceCardList.map((service) => (
          <article class="service-card">
            <div class="service-icon" aria-hidden="true">{service.icon}</div>
            <h3>{service.cardTitle}</h3>
            <p>{service.servicesOverviewSummary}</p>
            <a href={`/${service.slug}`} class="service-link" aria-label={`Learn more about ${service.heroTitle}`}>Learn more</a>
          </article>
        ))}
      </div>
    </PageSection>

    <PageSection section="compare-services" page="services">
      <div class="clone-heading">
        <h2 class="clone-kicker section-divider-title">Compare Services</h2>
      </div>

      <div class="stack-grid">
        {servicesPage.compareCards.map((item) => (
          <article class="stack-panel compare-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </PageSection>

    <HomepageWhyChoose pageId="services" />

    <HomepageProcess pageId="services" />

    <PageSection section="estimate-tips" page="services">
      <div class="clone-heading">
        <h2 class="clone-kicker section-divider-title">Estimate Tips</h2>
      </div>
      <div class="page-card page-card-soft">
        <ul class="list-copy">
          {servicesPage.estimateTips.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </PageSection>

    <PageSection id="estimate-form" section="estimate-form" page="services">
      <div class="clone-heading">
        <h2 class="clone-kicker section-divider-title">Request A Free Estimate</h2>
      </div>
      <EstimateForm
        heading={servicesPage.estimateForm.heading}
        intro={servicesPage.estimateForm.intro}
        buttonLabel={servicesPage.estimateForm.buttonLabel}
      />
    </PageSection>

    <ServiceAreaSection pageId="services" />
  </div>
</BaseLayout>
