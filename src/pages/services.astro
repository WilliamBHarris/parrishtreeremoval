---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SubpageIntroSection from '../components/SubpageIntroSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import EstimateCtaSection from '../components/EstimateCtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { client } from '../data/client';
import { clientIntake } from '../data/client-intake';
import { templateConfig } from '../data/client-questionnaire';
import { serviceCardList } from '../data/services';
import { getHeroCriticalImage } from '../lib/site/critical-image';
import { createFaqSchema } from '../lib/site/schema';

const servicesPage = pageContent.services;
const criticalImage = await getHeroCriticalImage();
const servicesFaqSchema = createFaqSchema(clientIntake.pages.services.sections.faq.items);
---

<BaseLayout
  title={servicesPage.title}
  description={servicesPage.description}
  schema={servicesFaqSchema ?? undefined}
  criticalImage={criticalImage}
>
  <HeroSection
    pageId="services"
    titlePrimary={servicesPage.hero.titlePrimary}
    titleSecondary={servicesPage.hero.titleSecondary}
    intro={servicesPage.hero.intro}
    outlineWords={servicesPage.hero.outlineWords}
    variant={servicesPage.hero.variant}
    cta={servicesPage.hero.cta}
  />

  <div class="page-shell" data-page="services">
    <SubpageIntroSection
      pageId="services"
      eyebrow="Services Overview"
      lines={['Find the right service.', 'Get clear answers.']}
      accentLine="Start with confidence."
      body="Compare the main tree service options, understand what fits the property, and move into the next step with a clearer picture of the work."
      surfaceTone="olive"
    />

    <ServicesSection
      pageId="services"
      sectionKey="services-overview"
      title="Our Services"
      services={serviceCardList}
      variant={templateConfig.presets.services}
      summaryMode="overview"
      surfaceTone="base"
    />

    <HomepageWhyChoose pageId="services" surfaceTone="cool" />

    <HomepageProcess pageId="services" surfaceTone="olive" />

    <EstimateCtaSection
      pageId="services"
      eyebrow="Free Estimate"
      heading="Tell Us About The Job"
      intro={client.sharedContent.estimateSectionLead}
      buttonLabel={client.ctas.heroEstimate}
      surfaceTone="base"
    />

    <FaqSection pageId="services" items={clientIntake.pages.services.sections.faq.items} surfaceTone="base" />

    <ServiceAreaSection pageId="services" surfaceTone="cool" />
  </div>
</BaseLayout>
