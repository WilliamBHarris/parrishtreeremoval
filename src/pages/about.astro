---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SubpageIntroSection from '../components/SubpageIntroSection.astro';
import AboutStorySection from '../components/AboutStorySection.astro';
import AboutTeamSection from '../components/AboutTeamSection.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { getHeroCriticalImage } from '../lib/site/critical-image';

const aboutPage = pageContent.about;
const criticalImage = await getHeroCriticalImage();
---

<BaseLayout
  title={aboutPage.title}
  description={aboutPage.description}
  criticalImage={criticalImage}
>
  <HeroSection
    pageId="about"
    titlePrimary={aboutPage.hero.titlePrimary}
    titleSecondary={aboutPage.hero.titleSecondary}
    intro={aboutPage.hero.intro}
    outlineWords={aboutPage.hero.outlineWords}
    variant={aboutPage.hero.variant}
    cta={aboutPage.hero.cta}
  />

  <div class="page-shell" data-page="about">
    <SubpageIntroSection
      pageId="about"
      eyebrow="About Us"
      lines={['Local roots.', 'Clear communication.']}
      accentLine="Work done right."
      body="We built this company around dependable service, practical help, and a cleaner customer experience from first estimate through final cleanup."
      surfaceTone="olive"
    />

    <AboutStorySection pageId="about" surfaceTone="olive" />

    <AboutTeamSection pageId="about" surfaceTone="base" />

    <HomepageWhyChoose pageId="about" surfaceTone="warm" />

    <ServiceAreaSection pageId="about" surfaceTone="cool" />
  </div>
</BaseLayout>
