---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import CardGridSection from '../components/CardGridSection.astro';
import InfoListSection from '../components/InfoListSection.astro';
import RelatedServicesSection from '../components/RelatedServicesSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { servicePages } from '../data/services';

const aboutPage = pageContent.about;
---

<BaseLayout
  title={aboutPage.title}
  description={aboutPage.description}
>
  <HeroSection
    pageId="about"
    titlePrimary={aboutPage.hero.titlePrimary}
    titleSecondary={aboutPage.hero.titleSecondary}
    intro={aboutPage.hero.intro}
    outlineWords={aboutPage.hero.outlineWords}
    variant={aboutPage.hero.variant}
    cta={aboutPage.hero.cta}
  />

  <div class="page-shell" data-page="about">
    <CardGridSection
      pageId="about"
      section="what-homeowners-need"
      title="What Homeowners Need"
      items={aboutPage.homeownerNeeds}
      surfaceTone="base"
    />

    <HomepageWhyChoose pageId="about" surfaceTone="warm" />

    <HomepageProcess pageId="about" surfaceTone="cool" />

    <InfoListSection
      pageId="about"
      section="how-requests-work"
      title="How Requests Work"
      items={aboutPage.howRequestsWork}
      softCard={true}
      surfaceTone="olive"
    />

    <RelatedServicesSection
      pageId="about"
      ariaLabel="Service page links"
      links={[
        { href: `/${servicePages.treeRemoval.slug}`, label: servicePages.treeRemoval.cardTitle },
        { href: `/${servicePages.treeTrimming.slug}`, label: servicePages.treeTrimming.cardTitle },
        { href: `/${servicePages.stumpGrinding.slug}`, label: servicePages.stumpGrinding.cardTitle },
      ]}
      surfaceTone="base"
    />

    <ServiceAreaSection pageId="about" surfaceTone="cool" />
  </div>
</BaseLayout>
