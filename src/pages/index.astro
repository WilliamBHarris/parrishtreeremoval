---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import EstimateForm from '../components/EstimateForm.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import EstimateCtaSection from '../components/EstimateCtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { serviceCardList } from '../data/services';
import { heroImageTransform } from '../data/heroMedia';
import heroImage from '../assets/hero-image.png';

const homePage = pageContent.home;
const homepageCriticalImage = await getImage({
  src: heroImage,
  width: 800,
  height: 480,
  format: heroImageTransform.format,
  quality: heroImageTransform.quality,
  widths: heroImageTransform.widths,
  sizes: heroImageTransform.sizes,
});
---

<BaseLayout
  title={homePage.title}
  description={homePage.description}
  criticalImage={{
    src: homepageCriticalImage.src,
    srcSet: homepageCriticalImage.srcSet.attribute,
    sizes: heroImageTransform.sizes,
    type: 'image/avif',
  }}
>
  <HeroSection
    pageId="home"
    titlePrimary={homePage.hero.titlePrimary}
    titleSecondary={homePage.hero.titleSecondary}
    intro={homePage.hero.intro}
    outlineWords={homePage.hero.outlineWords}
    variant={homePage.hero.variant}
    cta={homePage.hero.cta}
  />

  <div class="page-shell" data-page="home">
    <section class="page-section trust-badges-section" aria-label="Helpful project highlights" data-section="trust-badges" data-page="home">
      <div class="badge-row">
        {homePage.trustBadges.map((badge) => <span>{badge}</span>)}
      </div>
    </section>

    <ServicesSection
      pageId="home"
      sectionId="services"
      title="Our Services"
      lead={homePage.servicesLead}
      services={serviceCardList}
      variant="grid-cards"
      surfaceTone="base"
    />

    <HomepageWhyChoose pageId="home" surfaceTone="warm" />

    <HomepageProcess pageId="home" surfaceTone="cool" />

    <EstimateCtaSection
      pageId="home"
      sectionId="estimate-cta"
      eyebrow={homePage.estimateCta.eyebrow}
      heading={homePage.estimateCta.heading}
      intro={homePage.estimateCta.intro}
      buttonLabel={homePage.estimateCta.buttonLabel}
      surfaceTone="olive"
    />

    <FaqSection pageId="home" items={homePage.faq} surfaceTone="base" />

    <ServiceAreaSection pageId="home" surfaceTone="cool" />
  </div>

  <section
    id="estimate-modal"
    class="estimate-modal"
    data-estimate-modal
    aria-hidden="true"
    hidden
    inert
  >
    <div class="estimate-modal-scrim" data-close-estimate-modal></div>
    <div
      class="estimate-modal-dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="estimate-modal-title"
    >
      <button
        type="button"
        class="estimate-modal-close"
        aria-label="Close estimate form"
        data-close-estimate-modal
      >
        Close
      </button>
      <EstimateForm
        heading={homePage.modal.heading}
        intro={homePage.modal.intro}
        buttonLabel={homePage.modal.buttonLabel}
        headingId="estimate-modal-title"
      />
    </div>
  </section>

  <script is:inline>
    (() => {
      if (window.__estimateModalLoaderBound) return;
      window.__estimateModalLoaderBound = true;

      let loaded;
      const loadEstimateModal = () => loaded ??= import('/scripts/estimate-modal.js');
      const primeTriggers = document.querySelectorAll('[data-open-estimate-modal]');

      primeTriggers.forEach((trigger) => {
        trigger.addEventListener('click', async (event) => {
          if (!loaded) {
            event.preventDefault();
            await loadEstimateModal();
            trigger.click();
          }
        }, { once: true });
        trigger.addEventListener('pointerenter', loadEstimateModal, { once: true, passive: true });
        trigger.addEventListener('touchstart', loadEstimateModal, { once: true, passive: true });
        trigger.addEventListener('focus', loadEstimateModal, { once: true, passive: true });
      });
    })();
  </script>
</BaseLayout>
