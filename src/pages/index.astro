---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import EstimateForm from '../components/EstimateForm.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import PageSection from '../components/PageSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { serviceCardList } from '../data/services';
import heroImage from '../assets/hero-image.png';

const homePage = pageContent.home;
---

<BaseLayout
  title={homePage.title}
  description={homePage.description}
>
  <section class="page-hero">
    <div class="hero-frame">
      <div class="hero-bleed">
        <Image
          src={heroImage}
          alt="Tree service crew cutting and loading storm-damaged wood in a residential yard"
          class="hero-image"
          loading="eager"
          fetchpriority="high"
          formats={['avif', 'webp']}
          quality={65}
          widths={[480, 768, 1024]}
          sizes="100vw"
        />

        <div class="hero-copy">
          <h1>
            <span class="hero-title-primary">{homePage.hero.titlePrimary}</span>
            <span class="hero-title-secondary">{homePage.hero.titleSecondary}</span>
          </h1>
          <p class="hero-subcopy">{homePage.hero.intro}</p>
        </div>
      </div>

      <div class="hero-cta-wrap">
        <button
          type="button"
          class="hero-cta"
          data-open-estimate-modal
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          Get Free Estimate
        </button>
      </div>
    </div>
  </section>

  <div class="page-shell" data-page="home">
    <section class="page-section trust-badges-section" aria-label="Helpful project highlights" data-section="trust-badges" data-page="home">
      <div class="badge-row">
        {homePage.trustBadges.map((badge) => <span>{badge}</span>)}
      </div>
    </section>

    <PageSection id="services" section="services" page="home">
      <div class="clone-heading">
        <h2 class="clone-kicker section-divider-title">Our Services</h2>
      </div>

      <p class="section-lead">{homePage.servicesLead}</p>

      <div class="service-grid">
        {serviceCardList.map((service) => (
          <article class="service-card">
            <div class="service-icon" aria-hidden="true">{service.icon}</div>
            <h3>{service.cardTitle}</h3>
            <p>{service.serviceCardSummary}</p>
            <a href={`/${service.slug}`} class="service-link">
              Learn more
              <span class="sr-only"> about {service.heroTitle}</span>
            </a>
          </article>
        ))}
      </div>
    </PageSection>

    <HomepageWhyChoose pageId="home" />

    <HomepageProcess pageId="home" />

    <PageSection id="estimate-cta" class="estimate-cta-section" section="estimate-cta" page="home">
      <div class="estimate-cta-card">
        <h2 class="clone-kicker section-divider-title">{homePage.estimateCta.eyebrow}</h2>
        <p class="estimate-cta-heading">{homePage.estimateCta.heading}</p>
        <p>{homePage.estimateCta.intro}</p>
        <button
          type="button"
          class="btn-primary"
          data-open-estimate-modal
          aria-haspopup="dialog"
          aria-controls="estimate-modal"
        >
          {homePage.estimateCta.buttonLabel}
        </button>
      </div>
    </PageSection>

    <PageSection id="faq" section="faq" page="home">
      <div class="clone-heading">
        <h2 class="clone-kicker section-divider-title">FAQ</h2>
      </div>

      <div class="faq-list">
        {homePage.faq.map((item) => (
          <article class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </PageSection>

    <ServiceAreaSection pageId="home" />
  </div>

  <section
    id="estimate-modal"
    class="estimate-modal"
    data-estimate-modal
    aria-hidden="true"
    hidden
    inert
  >
    <div class="estimate-modal-scrim" data-close-estimate-modal></div>
    <div
      class="estimate-modal-dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="estimate-modal-title"
    >
      <button
        type="button"
        class="estimate-modal-close"
        aria-label="Close estimate form"
        data-close-estimate-modal
      >
        Close
      </button>
      <EstimateForm
        heading={homePage.modal.heading}
        intro={homePage.modal.intro}
        buttonLabel={homePage.modal.buttonLabel}
        headingId="estimate-modal-title"
      />
    </div>
  </section>

  <script type="module" src="/scripts/estimate-modal.js"></script>
</BaseLayout>
