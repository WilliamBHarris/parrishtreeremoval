---
import BaseLayout from '../layouts/BaseLayout.astro';
import DesktopHomepage from '../components/DesktopHomepage.astro';
import HomepageProcess from '../components/HomepageProcess.astro';
import HomepageWhyChoose from '../components/HomepageWhyChoose.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import EstimateCtaSection from '../components/EstimateCtaSection.astro';
import FaqSection from '../components/FaqSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { pageContent } from '../data/pages';
import { templateConfig } from '../data/client-questionnaire';
import { serviceCardList } from '../data/services';
import { getHeroCriticalImage } from '../lib/site/critical-image';
import { createFaqSchema } from '../lib/site/schema';

const homePage = pageContent.home;
const homepageCriticalImage = await getHeroCriticalImage();
const homeFaqSchema = createFaqSchema(homePage.faq);
---

<BaseLayout
  title={homePage.title}
  description={homePage.description}
  schema={homeFaqSchema ?? undefined}
  bodyClass="homepage-desktop-redesign"
  criticalImage={{
    src: homepageCriticalImage.src,
    srcSet: homepageCriticalImage.srcSet,
    sizes: homepageCriticalImage.sizes,
    type: homepageCriticalImage.type,
  }}
>
  <DesktopHomepage />

  <div class="home-mobile-stack">
    <HeroSection
      pageId="home"
      titlePrimary={homePage.hero.titlePrimary}
      titleSecondary={homePage.hero.titleSecondary}
      intro={homePage.hero.intro}
      outlineWords={homePage.hero.outlineWords}
      variant={homePage.hero.variant}
      cta={homePage.hero.cta}
    />

    <div class="page-shell" data-page="home">
      <ServicesSection
        pageId="home"
        sectionId="services"
        title="Our Services"
        lead={homePage.servicesLead}
        services={serviceCardList}
        variant={templateConfig.presets.services}
        surfaceTone="base"
      />

      <HomepageWhyChoose pageId="home" surfaceTone="warm" />

      <HomepageProcess pageId="home" surfaceTone="cool" />

      <EstimateCtaSection
        pageId="home"
        sectionId="estimate-cta"
        eyebrow={homePage.estimateCta.eyebrow}
        heading={homePage.estimateCta.heading}
        intro={homePage.estimateCta.intro}
        buttonLabel={homePage.estimateCta.buttonLabel}
        surfaceTone="olive"
      />

      <FaqSection pageId="home" items={homePage.faq} surfaceTone="base" />

      <ServiceAreaSection pageId="home" surfaceTone="cool" />
    </div>
  </div>
</BaseLayout>
