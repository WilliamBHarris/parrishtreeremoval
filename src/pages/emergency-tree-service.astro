---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Storm Cleanup And Emergency Tree Service In Parrish, FL | Parrish Tree Removal"
  description="Storm cleanup and urgent tree service information for homeowners in Parrish, Florida."
>
  <section class="internal-hero">
    <div class="internal-hero-shell">
      <span class="eyebrow">Storm Cleanup</span>
      <h1>Storm cleanup and urgent tree issue guidance</h1>
      <p>
        Severe weather can change a tree project quickly. Clear notes about access,
        debris, and visible hazards help shape the next step.
      </p>
      <div class="inline-actions">
        <a href="/contact" class="btn-primary">Start An Urgent Request</a>
      </div>
    </div>
  </section>

  <div class="page-shell">
    <section class="page-section">
      <div class="section-heading">
        <h2 class="section-title-reveal">What To Report After A Storm</h2>
      </div>
      <div class="page-card">
        <ul class="list-copy">
          <li>Whether limbs or debris are blocking access to the home or driveway.</li>
          <li>If anything is resting on a structure, fence, or vehicle.</li>
          <li>Whether the tree appears split, uprooted, or newly unstable.</li>
          <li>Any immediate safety concerns that should be noted in the request.</li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
