---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import EstimateForm from '../../components/EstimateForm.astro';
import HeroSection from '../../components/HeroSection.astro';
import ServicesSection from '../../components/ServicesSection.astro';
import HomepageProcess from '../../components/HomepageProcess.astro';
import HomepageWhyChoose from '../../components/HomepageWhyChoose.astro';
import FaqSection from '../../components/FaqSection.astro';
import ServiceAreaSection from '../../components/ServiceAreaSection.astro';
import EstimateCtaSection from '../../components/EstimateCtaSection.astro';
import EstimateFormSection from '../../components/EstimateFormSection.astro';
import CardGridSection from '../../components/CardGridSection.astro';
import InfoListSection from '../../components/InfoListSection.astro';
import ServiceInfoSection from '../../components/ServiceInfoSection.astro';
import RelatedServicesSection from '../../components/RelatedServicesSection.astro';
import { pageContent } from '../../data/pages';
import { serviceCardList, servicePages } from '../../data/services';
import { siteStylePresets, variantOptions } from '../../data/client-questionnaire';

const homePage = pageContent.home;
const servicesPage = pageContent.services;
const contactPage = pageContent.contact;
const presetEntries = Object.values(siteStylePresets);
const defaultPreset = siteStylePresets['preset-a-baseline'];
const previewSections = [
  { key: 'header', label: 'Header' },
  { key: 'hero', label: 'Hero' },
  { key: 'whyChoose', label: 'Why Choose Us' },
  { key: 'services', label: 'Services' },
  { key: 'process', label: 'Process' },
  { key: 'serviceArea', label: 'Service Area' },
  { key: 'faq', label: 'FAQ' },
  { key: 'estimateCta', label: 'Estimate CTA' },
  { key: 'relatedServices', label: 'Related Services' },
  { key: 'cardGrid', label: 'Card Grid' },
  { key: 'infoList', label: 'Info List' },
  { key: 'serviceInfo', label: 'Service Info' },
  { key: 'estimateForm', label: 'Estimate Form' },
] as const;

const previewState = {
  presets: presetEntries.map((preset) => ({
    id: preset.id,
    label: preset.label,
    description: preset.description,
    useCase: preset.useCase,
    header: preset.header,
    hero: preset.hero,
    colorTemplate: preset.colorTemplate,
    headingTypography: preset.headingTypography,
    bodyTypography: preset.bodyTypography,
    sectionTitleStyle: preset.sectionTitleStyle,
    cardSurface: preset.cardSurface,
    cardBorderStyle: preset.cardBorderStyle,
    buttonBorderStyle: preset.buttonBorderStyle,
    sectionFrameStyle: preset.sectionFrameStyle,
    estimateCta: preset.estimateCta,
    relatedServices: preset.relatedServices,
    whyChoose: preset.whyChoose,
    services: preset.services,
    faq: preset.faq,
    process: preset.process,
    serviceArea: preset.serviceArea,
  })),
  labels: {
    header: Object.fromEntries(variantOptions.header.map((option) => [option.value, option.label])),
    colorTemplate: Object.fromEntries(variantOptions.colorTemplate.map((option) => [option.value, option.label])),
    headingTypography: Object.fromEntries(variantOptions.headingTypography.map((option) => [option.value, option.label])),
    bodyTypography: Object.fromEntries(variantOptions.bodyTypography.map((option) => [option.value, option.label])),
    sectionTitleStyle: Object.fromEntries(variantOptions.sectionTitleStyle.map((option) => [option.value, option.label])),
    cardSurface: Object.fromEntries(variantOptions.cardSurface.map((option) => [option.value, option.label])),
    cardBorderStyle: Object.fromEntries(variantOptions.cardBorderStyle.map((option) => [option.value, option.label])),
    buttonBorderStyle: Object.fromEntries(variantOptions.buttonBorderStyle.map((option) => [option.value, option.label])),
    sectionFrameStyle: Object.fromEntries(variantOptions.sectionFrameStyle.map((option) => [option.value, option.label])),
    services: Object.fromEntries(variantOptions.services.map((option) => [option.value, option.label])),
    faq: Object.fromEntries(variantOptions.faq.map((option) => [option.value, option.label])),
    process: Object.fromEntries(variantOptions.process.map((option) => [option.value, option.label])),
    serviceArea: Object.fromEntries(variantOptions.serviceArea.map((option) => [option.value, option.label])),
  },
  allowedVariants: {
    header: variantOptions.header.map((option) => option.value),
    hero: variantOptions.hero.map((option) => option.value),
    estimateCta: variantOptions.estimateCta.map((option) => option.value),
    colorTemplate: variantOptions.colorTemplate.map((option) => option.value),
    headingTypography: variantOptions.headingTypography.map((option) => option.value),
    bodyTypography: variantOptions.bodyTypography.map((option) => option.value),
    sectionTitleStyle: variantOptions.sectionTitleStyle.map((option) => option.value),
    cardSurface: variantOptions.cardSurface.map((option) => option.value),
    cardBorderStyle: variantOptions.cardBorderStyle.map((option) => option.value),
    buttonBorderStyle: variantOptions.buttonBorderStyle.map((option) => option.value),
    sectionFrameStyle: variantOptions.sectionFrameStyle.map((option) => option.value),
    services: variantOptions.services.map((option) => option.value),
    faq: variantOptions.faq.map((option) => option.value),
    process: variantOptions.process.map((option) => option.value),
    serviceArea: variantOptions.serviceArea.map((option) => option.value),
  },
  sections: previewSections,
};
---

<BaseLayout
  title="Internal Template Preview"
  description="Internal-only template preview for preset and section variant comparisons."
  robots="noindex,nofollow,noarchive"
  showSiteChrome={false}
>
  <div class="page-shell template-preview-shell" data-page="internal-template-preview">
    <div class="template-preview-workspace">
      <section class="template-preview-intro">
        <p class="template-preview-eyebrow">Internal Tooling</p>
        <h1>Template Preview</h1>
        <p>
          Compare real preset bundles and section variants using the live framework components.
          Preset A is the current live Template A source of truth; the controls below let you preview alternate preset defaults, global visual-system settings, or section-level overrides without the public site chrome getting in the way.
        </p>
      </section>

      <section class="template-preview-toolbar" aria-label="Template preview controls" data-preview-root>
        <div class="template-preview-controls">
          <label class="template-preview-control">
            <span>Preview mode</span>
            <select data-preview-mode>
              <option value="sections">Isolated sections</option>
              <option value="full-page">Full-page flow</option>
            </select>
          </label>

          <label class="template-preview-control">
            <span>Preset bundle</span>
            <select data-preview-preset>
              {presetEntries.map((preset) => (
                <option value={preset.id} selected={preset.id === defaultPreset.id}>{preset.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Header</span>
            <select data-preview-override="header">
              <option value="preset">Follow preset</option>
              {variantOptions.header.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Heading type</span>
            <select data-preview-override="headingTypography">
              <option value="preset">Follow preset</option>
              {variantOptions.headingTypography.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Body type</span>
            <select data-preview-override="bodyTypography">
              <option value="preset">Follow preset</option>
              {variantOptions.bodyTypography.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Section titles</span>
            <select data-preview-override="sectionTitleStyle">
              <option value="preset">Follow preset</option>
              {variantOptions.sectionTitleStyle.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Color template</span>
            <select data-preview-override="colorTemplate">
              <option value="preset">Follow preset</option>
              {variantOptions.colorTemplate.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Card surface</span>
            <select data-preview-override="cardSurface">
              <option value="preset">Follow preset</option>
              {variantOptions.cardSurface.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Card border</span>
            <select data-preview-override="cardBorderStyle">
              <option value="preset">Follow preset</option>
              {variantOptions.cardBorderStyle.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Button border</span>
            <select data-preview-override="buttonBorderStyle">
              <option value="preset">Follow preset</option>
              {variantOptions.buttonBorderStyle.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Section frame</span>
            <select data-preview-override="sectionFrameStyle">
              <option value="preset">Follow preset</option>
              {variantOptions.sectionFrameStyle.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Services</span>
            <select data-preview-override="services">
              <option value="preset">Follow preset</option>
              {variantOptions.services.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>FAQ</span>
            <select data-preview-override="faq">
              <option value="preset">Follow preset</option>
              {variantOptions.faq.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Process</span>
            <select data-preview-override="process">
              <option value="preset">Follow preset</option>
              {variantOptions.process.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>

          <label class="template-preview-control">
            <span>Service Area</span>
            <select data-preview-override="serviceArea">
              <option value="preset">Follow preset</option>
              {variantOptions.serviceArea.map((option) => (
                <option value={option.value}>{option.label}</option>
              ))}
            </select>
          </label>
        </div>

        <div class="template-preview-accordion">
          <button
            type="button"
            class="template-preview-accordion-trigger"
            data-preview-accordion-trigger="visibility"
            aria-expanded="false"
            aria-controls="template-preview-visibility-panel"
          >
            <span>Section visibility</span>
            <span class="template-preview-accordion-chevron" aria-hidden="true">▾</span>
          </button>
          <div
            id="template-preview-visibility-panel"
            class="template-preview-accordion-panel template-preview-visibility"
            data-preview-accordion-panel="visibility"
            hidden
          >
            <div class="template-preview-visibility-grid">
              {previewSections.map((section) => (
                <label class="template-preview-visibility-item">
                  <input
                    type="checkbox"
                    value={section.key}
                    data-preview-section-toggle={section.key}
                    checked
                  />
                  <span>{section.label}</span>
                </label>
              ))}
            </div>
          </div>
        </div>

        <div class="template-preview-accordion">
          <button
            type="button"
            class="template-preview-accordion-trigger"
            data-preview-accordion-trigger="ordering"
            aria-expanded="false"
            aria-controls="template-preview-ordering-panel"
          >
            <span>Section order</span>
            <span class="template-preview-accordion-chevron" aria-hidden="true">▾</span>
          </button>
          <div
            id="template-preview-ordering-panel"
            class="template-preview-accordion-panel template-preview-ordering"
            data-preview-accordion-panel="ordering"
            hidden
          >
            <div class="template-preview-order-list" data-preview-order-list>
              {previewSections.map((section, index) => (
                <div class="template-preview-order-item" data-preview-order-item={section.key}>
                  <span class="template-preview-order-label">{section.label}</span>
                  <div class="template-preview-order-actions">
                    <button
                      type="button"
                      class="template-preview-order-button"
                      data-preview-order-up={section.key}
                      aria-label={`Move ${section.label} up`}
                      disabled={index === 0}
                    >
                      Up
                    </button>
                    <button
                      type="button"
                      class="template-preview-order-button"
                      data-preview-order-down={section.key}
                      aria-label={`Move ${section.label} down`}
                      disabled={index === previewSections.length - 1}
                    >
                      Down
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="template-preview-accordion">
          <button
            type="button"
            class="template-preview-accordion-trigger"
            data-preview-accordion-trigger="summary"
            aria-expanded="false"
            aria-controls="template-preview-summary-panel"
          >
            <span>Active preset</span>
            <span class="template-preview-accordion-chevron" aria-hidden="true">▾</span>
          </button>
          <div
            id="template-preview-summary-panel"
            class="template-preview-accordion-panel template-preview-summary"
            data-preview-accordion-panel="summary"
            hidden
          >
            <div class="template-preview-summary-main">
              <h2 data-summary-preset-label>{defaultPreset.label}</h2>
              <p data-summary-preset-description>{defaultPreset.description}</p>
              <p class="template-preview-summary-note" data-summary-preset-use-case>{defaultPreset.useCase}</p>
            </div>

            <dl class="template-preview-summary-grid">
              <div>
                <dt>Header</dt>
                <dd data-summary-header></dd>
              </div>
              <div>
                <dt>Color Template</dt>
                <dd data-summary-colorTemplate></dd>
              </div>
              <div>
                <dt>Heading Type</dt>
                <dd data-summary-headingTypography></dd>
              </div>
              <div>
                <dt>Body Type</dt>
                <dd data-summary-bodyTypography></dd>
              </div>
              <div>
                <dt>Section Titles</dt>
                <dd data-summary-sectionTitleStyle></dd>
              </div>
              <div>
                <dt>Card Surface</dt>
                <dd data-summary-cardSurface></dd>
              </div>
              <div>
                <dt>Card Borders</dt>
                <dd data-summary-cardBorderStyle></dd>
              </div>
              <div>
                <dt>Button Borders</dt>
                <dd data-summary-buttonBorderStyle></dd>
              </div>
              <div>
                <dt>Section Frames</dt>
                <dd data-summary-sectionFrameStyle></dd>
              </div>
              <div>
                <dt>Services</dt>
                <dd data-summary-services></dd>
              </div>
              <div>
                <dt>FAQ</dt>
                <dd data-summary-faq></dd>
              </div>
              <div>
                <dt>Process</dt>
                <dd data-summary-process></dd>
              </div>
              <div>
                <dt>Service Area</dt>
                <dd data-summary-serviceArea></dd>
              </div>
            </dl>
          </div>
        </div>
      </section>
    </div>

    <div class="template-preview-canvas">
    <section class="template-preview-stage" data-preview-mode-panel="sections">
      <div class="template-preview-block" data-preview-section="header">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Header</h2>
        </div>
        {variantOptions.header.map((option) => (
          <div
            class="template-preview-panel template-preview-panel-header"
            data-preview-kind="header"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.header}
          >
            <Header
              variant={option.value}
              previewMode={true}
              instanceId={`preview-header-${option.value}`}
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="hero">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Hero</h2>
        </div>
        {variantOptions.hero.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="hero"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.hero}
          >
            <HeroSection
              pageId={`preview-section-hero-${option.value}`}
              titlePrimary={homePage.hero.titlePrimary}
              titleSecondary={homePage.hero.titleSecondary}
              intro={homePage.hero.intro}
              outlineWords={homePage.hero.outlineWords}
              variant={option.value}
              cta={homePage.hero.cta}
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="whyChoose">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Why Choose Us</h2>
        </div>
        {variantOptions.whyChoose.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="whyChoose"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.whyChoose}
          >
            <HomepageWhyChoose pageId={`preview-why-choose-${option.value}`} variant={option.value} surfaceTone="cool" />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="services">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Services</h2>
        </div>
        {variantOptions.services.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="services"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.services}
          >
            <ServicesSection
              pageId={`preview-services-${option.value}`}
              sectionId={`preview-services-${option.value}`}
              title="Our Services"
              lead={homePage.servicesLead}
              services={serviceCardList}
              variant={option.value}
              surfaceTone="base"
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="process">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Process</h2>
        </div>
        {variantOptions.process.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="process"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.process}
          >
            <HomepageProcess
              pageId={`preview-process-${option.value}`}
              variant={option.value}
              surfaceTone="cool"
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="faq">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>FAQ</h2>
        </div>
        {variantOptions.faq.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="faq"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.faq}
          >
            <FaqSection
              pageId={`preview-faq-${option.value}`}
              items={homePage.faq}
              variant={option.value}
              surfaceTone="base"
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="serviceArea">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Service Area</h2>
        </div>
        {variantOptions.serviceArea.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="serviceArea"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.serviceArea}
          >
            <ServiceAreaSection
              pageId={`preview-service-area-${option.value}`}
              variant={option.value}
              surfaceTone="cool"
              lookupInputId={`preview-service-area-zip-${option.value}`}
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="estimateCta">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Estimate CTA</h2>
        </div>
        {variantOptions.estimateCta.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="estimateCta"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.estimateCta}
          >
            <EstimateCtaSection
              pageId={`preview-estimate-cta-${option.value}`}
              sectionId={`preview-estimate-cta-${option.value}`}
              eyebrow={homePage.estimateCta.eyebrow}
              heading={homePage.estimateCta.heading}
              intro={homePage.estimateCta.intro}
              buttonLabel={homePage.estimateCta.buttonLabel}
              variant={option.value}
              surfaceTone="olive"
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="relatedServices">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Related Services</h2>
        </div>
        {variantOptions.relatedServices.map((option) => (
          <div
            class="template-preview-panel"
            data-preview-kind="relatedServices"
            data-preview-variant={option.value}
            hidden={option.value !== defaultPreset.relatedServices}
          >
            <RelatedServicesSection
              pageId={`preview-related-services-${option.value}`}
              links={servicePages.treeRemoval.relatedServices}
              variant={option.value}
              surfaceTone="base"
            />
          </div>
        ))}
      </div>

      <div class="template-preview-block" data-preview-section="cardGrid">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Card Grid</h2>
        </div>
        <div class="template-preview-panel">
          <CardGridSection
            pageId="preview-card-grid"
            section="compare-services"
            title="Compare Services"
            items={servicesPage.compareCards}
            surfaceTone="base"
          />
        </div>
      </div>

      <div class="template-preview-block" data-preview-section="infoList">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Info List</h2>
        </div>
        <div class="template-preview-panel">
          <InfoListSection
            pageId="preview-info-list"
            section="estimate-tips"
            title="Estimate Tips"
            items={servicesPage.estimateTips}
            surfaceTone="base"
          />
        </div>
      </div>

      <div class="template-preview-block" data-preview-section="serviceInfo">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Service Info</h2>
        </div>
        <div class="template-preview-panel">
          <ServiceInfoSection
            pageId="preview-service-info"
            section="whats-included"
            title="What’s Included"
            items={servicePages.treeRemoval.whatsIncluded}
            layout={servicePages.treeRemoval.includedLayout}
            surfaceTone="base"
          />
        </div>
      </div>

      <div class="template-preview-block" data-preview-section="estimateForm">
        <div class="template-preview-block-head">
          <p class="template-preview-block-kicker">Section Preview</p>
          <h2>Estimate Form</h2>
        </div>
        <div class="template-preview-panel">
          <EstimateFormSection
            pageId="preview-estimate-form"
            sectionId="preview-estimate-form"
            title="Get in Touch"
            heading={contactPage.estimateForm.heading}
            intro={contactPage.estimateForm.intro}
            buttonLabel={contactPage.estimateForm.buttonLabel}
            surfaceTone="base"
          />
        </div>
      </div>
    </section>

    <section class="template-preview-full-flow" data-preview-mode-panel="full-page" hidden>
      <div class="template-preview-block-head">
        <p class="template-preview-block-kicker">Assembled Preview</p>
