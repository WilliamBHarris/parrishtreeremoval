  <script is:inline>
    (() => {
      if (window.__templatePreviewEstimateModalLoaderBound) return;
      window.__templatePreviewEstimateModalLoaderBound = true;

      let loaded;
      const loadEstimateModal = () => loaded ??= import('/scripts/estimate-modal.js');

      document.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const trigger = target.closest('[data-open-estimate-modal]');
        if (!(trigger instanceof HTMLElement) || loaded) return;

        event.preventDefault();
        await loadEstimateModal();
        trigger.click();
      }, true);

      document.addEventListener('pointerenter', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest('[data-open-estimate-modal]')) return;
        void loadEstimateModal();
      }, { passive: true, capture: true });

      document.addEventListener('touchstart', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest('[data-open-estimate-modal]')) return;
        void loadEstimateModal();
      }, { passive: true, capture: true });

      document.addEventListener('focusin', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (!target.closest('[data-open-estimate-modal]')) return;
        void loadEstimateModal();
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-preview-root]');
      const dataNode = document.getElementById('template-preview-data');
      if (!(root instanceof HTMLElement) || !(dataNode instanceof HTMLScriptElement) || root.dataset.previewBound === 'true') return;
      root.dataset.previewBound = 'true';

      const previewData = JSON.parse(dataNode.textContent || '{}');
      const presetSelect = root.querySelector('[data-preview-preset]');
      const modeSelect = root.querySelector('[data-preview-mode]');
      if (!(presetSelect instanceof HTMLSelectElement)) return;
      if (!(modeSelect instanceof HTMLSelectElement)) return;

      const overrideKeys = [
        'header',
        'colorTemplate',
        'headingTypography',
        'bodyTypography',
        'sectionTitleStyle',
        'cardSurface',
        'cardBorderStyle',
        'buttonBorderStyle',
        'sectionFrameStyle',
        'services',
        'faq',
        'process',
        'serviceArea',
      ];
      const overrideSelects = Object.fromEntries(
        overrideKeys.map((key) => [key, root.querySelector(`[data-preview-override="${key}"]`)]),
      );
      const sectionToggleInputs = Array.from(document.querySelectorAll('[data-preview-section-toggle]'));
      const orderList = root.querySelector('[data-preview-order-list]');
      const defaultSectionOrder = (previewData.sections || []).map((section) => section.key);
      let sectionOrderState = [...defaultSectionOrder];

      const presetMap = Object.fromEntries((previewData.presets || []).map((preset) => [preset.id, preset]));
      const labelMaps = previewData.labels || {};
      const allowedVariants = previewData.allowedVariants || {};
      const validPresetIds = new Set(Object.keys(presetMap));
      const previewSectionKeys = new Set((previewData.sections || []).map((section) => section.key));
      const bodyClassPrefixes = [
        'template-color-',
        'template-heading-',
        'template-body-',
        'template-section-title-',
        'template-card-surface-',
        'template-card-border-',
        'template-button-border-',
        'template-section-frame-',
      ];

      const summaryPresetLabel = root.querySelector('[data-summary-preset-label]');
      const summaryPresetDescription = root.querySelector('[data-summary-preset-description]');
      const summaryPresetUseCase = root.querySelector('[data-summary-preset-use-case]');
      const accordionButtons = Array.from(root.querySelectorAll('[data-preview-accordion-trigger]'));

      const setAccordionState = (accordionKey, isOpen) => {
        const button = root.querySelector(`[data-preview-accordion-trigger="${accordionKey}"]`);
        const panel = root.querySelector(`[data-preview-accordion-panel="${accordionKey}"]`);
        const wrapper = button?.closest('.template-preview-accordion');

        if (!(button instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

        button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        panel.hidden = !isOpen;
        panel.setAttribute('aria-hidden', isOpen ? 'false' : 'true');

        if (wrapper instanceof HTMLElement) {
          wrapper.classList.toggle('is-open', isOpen);
        }
      };

      const syncPreviewSectionVisibility = (activeVariants, enabledSections) => {
        document.querySelectorAll('[data-preview-section], [data-preview-kind]').forEach((panel) => {
          if (!(panel instanceof HTMLElement)) return;

          const sectionKey = panel.dataset.previewSection;
          const kind = panel.dataset.previewKind;
          const variant = panel.dataset.previewVariant;
          const sectionVisible = sectionKey ? enabledSections.has(sectionKey) : true;
          const variantVisible = kind && variant ? activeVariants[kind] === variant : true;
          const isVisible = sectionVisible && variantVisible;

          panel.hidden = !isVisible;
          panel.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
        });
      };

      const syncSectionOrder = () => {
        const orderMap = new Map(sectionOrderState.map((key, index) => [key, index + 1]));

        document.querySelectorAll('[data-preview-section]').forEach((panel) => {
          if (!(panel instanceof HTMLElement)) return;
          const sectionKey = panel.dataset.previewSection;
          if (!sectionKey) return;
          panel.style.order = String(orderMap.get(sectionKey) ?? defaultSectionOrder.length + 1);
        });

        if (!(orderList instanceof HTMLElement)) return;

        sectionOrderState.forEach((key, index) => {
          const item = orderList.querySelector(`[data-preview-order-item="${key}"]`);
          if (!(item instanceof HTMLElement)) return;
          item.style.order = String(index + 1);

          const upButton = item.querySelector(`[data-preview-order-up="${key}"]`);
          const downButton = item.querySelector(`[data-preview-order-down="${key}"]`);

          if (upButton instanceof HTMLButtonElement) {
            upButton.disabled = index === 0;
          }

          if (downButton instanceof HTMLButtonElement) {
            downButton.disabled = index === sectionOrderState.length - 1;
          }
        });
      };

      const moveSection = (sectionKey, direction) => {
        const currentIndex = sectionOrderState.indexOf(sectionKey);
        if (currentIndex < 0) return;

        const nextIndex = currentIndex + direction;
        if (nextIndex < 0 || nextIndex >= sectionOrderState.length) return;

        const nextOrder = [...sectionOrderState];
        const [moved] = nextOrder.splice(currentIndex, 1);
        nextOrder.splice(nextIndex, 0, moved);
        sectionOrderState = nextOrder;
        syncPreview();
      };

      const previewShell = document.querySelector('.template-preview-shell');

      const setPreviewMode = (mode) => {
        if (previewShell instanceof HTMLElement) {
          previewShell.dataset.previewMode = mode;
        }

        document.querySelectorAll('[data-preview-mode-panel]').forEach((panel) => {
          if (!(panel instanceof HTMLElement)) return;
          const isActive = panel.dataset.previewModePanel === mode;
          panel.hidden = !isActive;
          panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        });
      };

      const describeSelection = (kind, variant, followsPreset) => {
        const label = labelMaps[kind]?.[variant] || variant;
        return followsPreset ? `${label} (preset)` : `${label} (manual override)`;
      };

      const applyPreviewBodyClasses = (activeValues) => {
        bodyClassPrefixes.forEach((prefix) => {
          document.body.classList.forEach((className) => {
            if (className.startsWith(prefix)) {
              document.body.classList.remove(className);
            }
          });
        });

        document.body.classList.add(`template-color-${activeValues.colorTemplate}`);
        document.body.classList.add(`template-heading-${activeValues.headingTypography}`);
        document.body.classList.add(`template-body-${activeValues.bodyTypography}`);
        document.body.classList.add(`template-section-title-${activeValues.sectionTitleStyle}`);
        document.body.classList.add(`template-card-surface-${activeValues.cardSurface}`);
        document.body.classList.add(`template-card-border-${activeValues.cardBorderStyle}`);
        document.body.classList.add(`template-button-border-${activeValues.buttonBorderStyle}`);
        document.body.classList.add(`template-section-frame-${activeValues.sectionFrameStyle}`);
      };

      const restoreStateFromQuery = () => {
        const params = new URLSearchParams(window.location.search);
        const modeFromQuery = params.get('mode');
        const presetFromQuery = params.get('preset');
        const sectionOrderFromQuery = (params.get('sectionOrder') || '')
          .split(',')
          .map((value) => value.trim())
          .filter((value) => previewSectionKeys.has(value));
        const hiddenSections = new Set(
          (params.get('hiddenSections') || '')
            .split(',')
            .map((value) => value.trim())
            .filter((value) => previewSectionKeys.has(value)),
        );

        modeSelect.value = modeFromQuery === 'full-page' ? 'full-page' : 'sections';
        if (sectionOrderFromQuery.length === defaultSectionOrder.length) {
          sectionOrderState = [...sectionOrderFromQuery];
        } else {
          sectionOrderState = [...defaultSectionOrder];
        }

        if (presetFromQuery && validPresetIds.has(presetFromQuery)) {
          presetSelect.value = presetFromQuery;
        } else {
          presetSelect.value = presetSelect.options[0]?.value || '';
        }

        overrideKeys.forEach((kind) => {
          const select = overrideSelects[kind];
          if (!(select instanceof HTMLSelectElement)) return;

          const queryValue = params.get(kind);
          const validVariants = new Set(allowedVariants[kind] || []);

          if (queryValue === 'preset' || queryValue === null) {
            select.value = 'preset';
            return;
          }

          select.value = validVariants.has(queryValue) ? queryValue : 'preset';
        });

        sectionToggleInputs.forEach((input) => {
          if (!(input instanceof HTMLInputElement)) return;
          input.checked = !hiddenSections.has(input.value);
        });
      };

      const syncQueryString = () => {
        const params = new URLSearchParams();

        if (modeSelect.value === 'full-page') {
          params.set('mode', 'full-page');
        }

        if (presetSelect.value && validPresetIds.has(presetSelect.value)) {
          params.set('preset', presetSelect.value);
        }

        overrideKeys.forEach((kind) => {
          const select = overrideSelects[kind];
          if (!(select instanceof HTMLSelectElement)) return;

          const validVariants = new Set(allowedVariants[kind] || []);
          if (select.value === 'preset' || !validVariants.has(select.value)) return;

          params.set(kind, select.value);
        });

        const hiddenSections = sectionToggleInputs
          .filter((input) => input instanceof HTMLInputElement && !input.checked)
          .map((input) => input.value);

        if (hiddenSections.length > 0) {
          params.set('hiddenSections', hiddenSections.join(','));
        }

        if (sectionOrderState.join(',') !== defaultSectionOrder.join(',')) {
          params.set('sectionOrder', sectionOrderState.join(','));
        }

        const nextQuery = params.toString();
        const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ''}${window.location.hash}`;
        window.history.replaceState({}, '', nextUrl);
      };

      const syncPreview = () => {
        const activePreset = presetMap[presetSelect.value];
        if (!activePreset) return;

        if (summaryPresetLabel instanceof HTMLElement) summaryPresetLabel.textContent = activePreset.label;
        if (summaryPresetDescription instanceof HTMLElement) summaryPresetDescription.textContent = activePreset.description;
        if (summaryPresetUseCase instanceof HTMLElement) summaryPresetUseCase.textContent = activePreset.useCase;

        setPreviewMode(modeSelect.value);

        const activeVariants = {
          header: activePreset.header,
          hero: activePreset.hero,
          estimateCta: activePreset.estimateCta,
          whyChoose: activePreset.whyChoose,
          relatedServices: activePreset.relatedServices,
        };

        overrideKeys.forEach((kind) => {
          const select = overrideSelects[kind];
          const summaryNode = root.querySelector(`[data-summary-${kind}]`);
          if (!(select instanceof HTMLSelectElement)) return;

          const followsPreset = select.value === 'preset';
          const variant = followsPreset ? activePreset[kind] : select.value;
          activeVariants[kind] = variant;

          if (summaryNode instanceof HTMLElement) {
            summaryNode.textContent = describeSelection(kind, variant, followsPreset);
          }
        });
        const enabledSections = new Set(
          sectionToggleInputs
            .filter((input) => input instanceof HTMLInputElement && input.checked)
            .map((input) => input.value),
        );
        syncSectionOrder();
        syncPreviewSectionVisibility(activeVariants, enabledSections);

        applyPreviewBodyClasses({
          colorTemplate:
            overrideSelects.colorTemplate instanceof HTMLSelectElement && overrideSelects.colorTemplate.value !== 'preset'
              ? overrideSelects.colorTemplate.value
              : activePreset.colorTemplate,
          headingTypography:
            overrideSelects.headingTypography instanceof HTMLSelectElement && overrideSelects.headingTypography.value !== 'preset'
              ? overrideSelects.headingTypography.value
              : activePreset.headingTypography,
          bodyTypography:
            overrideSelects.bodyTypography instanceof HTMLSelectElement && overrideSelects.bodyTypography.value !== 'preset'
              ? overrideSelects.bodyTypography.value
              : activePreset.bodyTypography,
          sectionTitleStyle:
            overrideSelects.sectionTitleStyle instanceof HTMLSelectElement && overrideSelects.sectionTitleStyle.value !== 'preset'
              ? overrideSelects.sectionTitleStyle.value
              : activePreset.sectionTitleStyle,
          cardSurface:
            overrideSelects.cardSurface instanceof HTMLSelectElement && overrideSelects.cardSurface.value !== 'preset'
              ? overrideSelects.cardSurface.value
              : activePreset.cardSurface,
          cardBorderStyle:
            overrideSelects.cardBorderStyle instanceof HTMLSelectElement && overrideSelects.cardBorderStyle.value !== 'preset'
              ? overrideSelects.cardBorderStyle.value
              : activePreset.cardBorderStyle,
          buttonBorderStyle:
            overrideSelects.buttonBorderStyle instanceof HTMLSelectElement && overrideSelects.buttonBorderStyle.value !== 'preset'
              ? overrideSelects.buttonBorderStyle.value
              : activePreset.buttonBorderStyle,
          sectionFrameStyle:
            overrideSelects.sectionFrameStyle instanceof HTMLSelectElement && overrideSelects.sectionFrameStyle.value !== 'preset'
              ? overrideSelects.sectionFrameStyle.value
              : activePreset.sectionFrameStyle,
        });

        syncQueryString();
        window.dispatchEvent(new Event('resize'));
      };

      presetSelect.addEventListener('change', syncPreview);
      modeSelect.addEventListener('change', syncPreview);
      overrideKeys.forEach((kind) => {
        const select = overrideSelects[kind];
        if (select instanceof HTMLSelectElement) {
          select.addEventListener('change', syncPreview);
        }
      });
      sectionToggleInputs.forEach((input) => {
        if (input instanceof HTMLInputElement) {
          input.addEventListener('change', syncPreview);
        }
      });
      if (orderList instanceof HTMLElement) {
        orderList.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;

          const upKey = target.getAttribute('data-preview-order-up');
          if (upKey) {
            moveSection(upKey, -1);
            return;
          }

          const downKey = target.getAttribute('data-preview-order-down');
          if (downKey) {
            moveSection(downKey, 1);
          }
        });
      }

      accordionButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        const accordionKey = button.dataset.previewAccordionTrigger;
        if (!accordionKey) return;

        setAccordionState(accordionKey, button.getAttribute('aria-expanded') === 'true');
        button.addEventListener('click', () => {
          const isOpen = button.getAttribute('aria-expanded') === 'true';
          setAccordionState(accordionKey, !isOpen);
        });
      });

      restoreStateFromQuery();
      syncPreview();
    })();
  </script>

