---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Stump Grinding In Parrish, FL | Parrish Tree Removal"
  description="Stump grinding information for Parrish homeowners looking to finish cleanup after a tree has been removed."
>
  <section class="internal-hero">
    <div class="internal-hero-shell">
      <span class="eyebrow">Stump Grinding</span>
      <h1>Stump grinding information for cleaner post-removal results</h1>
      <p>
        Stump work often comes up after a removal when the remaining yard still feels
        unfinished or harder to use.
      </p>
      <div class="inline-actions">
        <a href="/contact" class="btn-primary">Ask About Stump Work</a>
      </div>
    </div>
  </section>

  <div class="page-shell">
    <section class="page-section">
      <div class="section-heading">
        <h2 class="section-title-reveal">What To Include In A Stump Request</h2>
      </div>
      <div class="page-card">
        <ul class="list-copy">
          <li>Approximate stump width or the size of the removed tree.</li>
          <li>Nearby fencing, irrigation, patios, or tight access points.</li>
          <li>Whether the goal is open yard space, replanting, or general cleanup.</li>
          <li>If there are multiple stumps in different parts of the property.</li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
