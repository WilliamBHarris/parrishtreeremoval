---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tree Removal In Parrish, FL | Parrish Tree Removal"
  description="Tree removal information for homeowners in Parrish, Florida dealing with damaged, unwanted, or difficult trees."
>
  <section class="internal-hero">
    <div class="internal-hero-shell">
      <span class="eyebrow">Tree Removal</span>
      <h1>Tree removal information for changing property conditions</h1>
      <p>
        Removal requests often begin when a tree starts affecting safety, access, or
        long-term plans for the yard.
      </p>
      <div class="inline-actions">
        <a href="/contact" class="btn-primary">Ask About Removal</a>
      </div>
    </div>
  </section>

  <div class="page-shell">
    <section class="page-section">
      <div class="section-heading">
        <h2 class="section-title-reveal">Common Removal Questions</h2>
      </div>
      <div class="page-card">
        <ul class="list-copy">
          <li>Is the tree dead, leaning, or declining after recent weather?</li>
          <li>Does it crowd a structure, driveway, fence, or planned yard improvement?</li>
          <li>Would cleanup or stump work likely be part of the same project?</li>
          <li>Is access straightforward or limited by gates, ground conditions, or layout?</li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
